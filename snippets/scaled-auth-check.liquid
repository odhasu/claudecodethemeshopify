{% comment %}
  Scaled.info Authentication Check Snippet - STRICT MODE
  Usage: {% render 'scaled-auth-check' %}
  
  Sets the following variables:
  - scaled_authenticated: true/false based on authentication status
  - scaled_api_key: The configured API key
  - scaled_store_domain: Current store domain
  
  NOTE: Authentication is ALWAYS required - no bypass option
{% endcomment %}

{% assign scaled_authenticated = false %}
{% assign scaled_api_key = settings.scaled_api_key %}
{% assign scaled_secret_key = settings.scaled_secret_key %}
{% assign scaled_store_domain = shop.domain %}

{% comment %} Check if API credentials are configured {% endcomment %}
{% if scaled_api_key != blank and scaled_secret_key != blank %}
  {% comment %} 
    In production, this would make a server-side validation call.
    For client-side implementation, we trust the JavaScript validation.
    Authentication is ALWAYS required - no exceptions.
  {% endcomment %}
  {% assign scaled_authenticated = true %}
{% else %}
  {% comment %} No valid credentials = no access {% endcomment %}
  {% assign scaled_authenticated = false %}
{% endif %}

{% comment %} 
  You can use this snippet to conditionally show/hide content:
  
  {% render 'scaled-auth-check' %}
  {% if scaled_authenticated %}
    <!-- Premium features here -->
  {% else %}
    <div class="scaled-auth-required" style="
      background: #fee;
      border: 2px solid #fcc;
      padding: 20px;
      border-radius: 8px;
      text-align: center;
      margin: 20px 0;
    ">
      <h3 style="color: #c00; margin: 0 0 10px 0;">🔒 Authentication Required</h3>
      <p style="margin: 0;">This feature requires valid Scaled.info API credentials. Please configure your API keys in theme settings.</p>
    </div>
  {% endif %}
{% endcomment %}