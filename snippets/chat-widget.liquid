{%- if settings.chat_enabled -%}
{%- liquid
  assign btn_bg = settings.chat_btn_bg | default: '#39ff14'
  assign btn_size = settings.chat_btn_size | default: 60
  assign chat_width = settings.chat_window_width | default: 380
-%}

<style>
  .chat-fab {
    position: fixed;
    bottom: {{ settings.chat_bottom | default: 24 }}px;
    right: {{ settings.chat_right | default: 24 }}px;
    width: {{ btn_size }}px;
    height: {{ btn_size }}px;
    border-radius: 50%;
    background: {{ btn_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 160;
    box-shadow: 0 4px 20px rgba(57,255,20,0.3);
    cursor: pointer;
    transition: transform 0.2s;
    border: none;
  }
  .chat-fab:hover { transform: scale(1.08); }
  .chat-fab svg { width: 28px; height: 28px; color: #000; }
  .chat-fab-dot {
    position: absolute;
    top: 4px; right: 4px;
    width: 12px; height: 12px;
    border-radius: 50%;
    background: #22c55e;
    border: 2px solid #000;
    animation: chatPulseDot 1.5s ease-in-out infinite;
  }
  @keyframes chatPulseDot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.4); }
  }

  .chat-window {
    position: fixed;
    bottom: {{ settings.chat_bottom | default: 24 | plus: btn_size | plus: 12 }}px;
    right: {{ settings.chat_right | default: 24 }}px;
    width: {{ chat_width }}px;
    max-height: 500px;
    background: {{ settings.chat_window_bg | default: '#111111' }};
    border: 1px solid #2a2a2a;
    border-radius: 16px;
    z-index: 161;
    display: none;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(0,0,0,0.5);
  }
  .chat-window.open { display: flex; }
  .chat-header {
    padding: 16px;
    background: #0a0a0a;
    border-bottom: 1px solid #2a2a2a;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .chat-avatar {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: {{ btn_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .chat-avatar svg { width: 20px; height: 20px; color: #000; }
  .chat-header-info { flex: 1; }
  .chat-header-name { font-weight: 700; font-size: 14px; }
  .chat-header-status { font-size: 12px; color: #22c55e; display: flex; align-items: center; gap: 4px; }
  .chat-header-status::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #22c55e;
    animation: chatPulseDot 1.5s ease-in-out infinite;
  }
  .chat-close-btn { background: none; border: none; color: #fff; font-size: 20px; cursor: pointer; padding: 4px; }
  .chat-messages {
    flex: 1;
    padding: 16px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-height: 320px;
  }
  .chat-msg {
    padding: 10px 14px;
    border-radius: 12px;
    font-size: 14px;
    line-height: 1.5;
    max-width: 85%;
  }
  .chat-msg.bot {
    background: #1a1a1a;
    align-self: flex-start;
    border-bottom-left-radius: 4px;
  }
  .chat-msg.user {
    background: {{ btn_bg }};
    color: #000;
    align-self: flex-end;
    border-bottom-right-radius: 4px;
  }
  .chat-msg a { color: {{ btn_bg }}; font-weight: 700; text-decoration: underline; }
  .chat-typing {
    align-self: flex-start;
    padding: 10px 14px;
    background: #1a1a1a;
    border-radius: 12px;
    border-bottom-left-radius: 4px;
    display: flex;
    gap: 4px;
    align-items: center;
  }
  .chat-typing span {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #555;
    animation: typingBounce 1.4s ease-in-out infinite;
  }
  .chat-typing span:nth-child(2) { animation-delay: 0.2s; }
  .chat-typing span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes typingBounce {
    0%, 60%, 100% { transform: translateY(0); }
    30% { transform: translateY(-6px); }
  }
  .chat-input-area {
    padding: 12px 16px;
    border-top: 1px solid #2a2a2a;
    display: flex;
    gap: 8px;
  }
  .chat-input {
    flex: 1;
    padding: 10px 14px;
    border-radius: 999px;
    border: 1px solid #2a2a2a;
    background: #0a0a0a;
    color: #fff;
    font-size: 14px;
    outline: none;
  }
  .chat-send {
    width: 40px; height: 40px;
    border-radius: 50%;
    background: {{ btn_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    cursor: pointer;
  }
  .chat-send svg { width: 18px; height: 18px; color: #000; }

  @media (max-width: 768px) {
    .chat-window {
      inset: 0;
      width: 100%;
      max-height: 100%;
      border-radius: 0;
      bottom: 0; right: 0;
    }
    .chat-window.open { position: fixed; }
  }
</style>

<button class="chat-fab" id="chat-fab" aria-label="Open chat">
  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/></svg>
  <span class="chat-fab-dot"></span>
</button>

<div class="chat-window" id="chat-window">
  <div class="chat-header">
    <div class="chat-avatar">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/></svg>
    </div>
    <div class="chat-header-info">
      <div class="chat-header-name">{{ settings.chat_name | default: 'Reselling Assistant' }}</div>
      <div class="chat-header-status">Online now</div>
    </div>
    <button class="chat-close-btn" id="chat-close">&times;</button>
  </div>
  <div class="chat-messages" id="chat-messages">
    <div class="chat-msg bot">{{ settings.chat_greeting | default: "yooo whats good! u looking to start reselling? lmk if u need help picking the right suppliers 🔥" }}</div>
  </div>
  <div class="chat-input-area">
    <input class="chat-input" id="chat-input" placeholder="{{ settings.chat_placeholder | default: 'Ask me anything...' }}" onkeypress="if(event.key==='Enter')sendChatMsg()">
    <button class="chat-send" onclick="sendChatMsg()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
    </button>
  </div>
</div>

<script>
(function() {
  var fab = document.getElementById('chat-fab');
  var win = document.getElementById('chat-window');
  var close = document.getElementById('chat-close');
  fab.addEventListener('click', function() { win.classList.toggle('open'); });
  close.addEventListener('click', function() { win.classList.remove('open'); });

  /* ── Custom context from theme settings ── */
  var customContext = {{ settings.chat_context | default: '' | json }};
  var sellingPoints = {{ settings.chat_selling_points | default: '' | json }};
  var customKeywords = {{ settings.chat_custom_keywords | default: '' | json }};

  /* ── Parse custom keywords from settings ── */
  var extraKeywords = {};
  if (customKeywords) {
    var lines = customKeywords.split('\n');
    for (var i = 0; i < lines.length; i++) {
      var parts = lines[i].split('|');
      if (parts.length >= 2) {
        var trigger = parts[0].trim().toLowerCase();
        var response = parts.slice(1).join('|').trim();
        if (trigger && response) extraKeywords[trigger] = response;
      }
    }
  }

  /* ── Smart Chatbot Engine — talks like a real person ── */
  var keywords = {
    // Greetings
    'hello|hi|hey|yo|sup|whats up|wassup|whats good': [
      "yooo whats good! u looking to get into reselling or u already in the game?",
      "ayy whats up! need help picking the right suppliers? im here for u",
      "heyyy! welcome, u tryna start making money reselling? lmk what u need 💪"
    ],
    // Price / cost
    'price|cost|how much|expensive|cheap|afford|money|pay|worth': [
      "bro the prices are crazy good for what u get.. like actual verified suppliers that nobody else has. check em out <a href='/collections/all'>right here</a>",
      "honestly its a steal for the value.. most ppl spend way more finding suppliers on their own. <a href='/collections/all'>peep the options</a> and see what fits ur budget",
      "trust me the ROI on these is insane.. u make back what u paid on literally ur first flip 🔥"
    ],
    // Legit / scam / trust
    'legit|scam|trust|real|fake|honest|reliable|sketchy|cap': [
      "nah bro this is 100% legit no cap.. every single supplier is personally verified and tested. peep the reviews if u dont believe me 💯",
      "i get it u gotta be careful out here.. but fr every supplier we list is tested and verified. thousands of ppl already using em successfully",
      "yo thats valid to ask.. we wouldnt put our name on anything thats not legit. all suppliers are personally verified and working rn"
    ],
    // Refund / return
    'refund|return|money back|cancel': [
      "since its digital theres no refunds but fr u wont need one.. the suppliers are all verified and working. ur gonna love it",
      "no refunds on digital products but tbh nobody asks for em cuz the lists actually work 😤 check the reviews"
    ],
    // Delivery / receive / how
    'deliver|receive|get|how do i|access|download|email|instant|when': [
      "its instant bro! soon as u buy, supplier links hit ur email right away. no waiting around ⚡",
      "u get everything sent to ur email instantly after purchase.. like literally within minutes. easy as that"
    ],
    // Which / recommend / best / popular
    'which|recommend|best|popular|suggest|what should|starter|beginner|first': [
      "if ur just starting out id say go with a single category first to test it out.. whats ur vibe? clothing? tech? accessories?",
      "honestly our most popular one covers multiple categories so u can figure out what works best for u. what are u tryna resell?",
      "depends what ur into fr.. lmk what category interests u and ill point u to the right one 🎯"
    ],
    // Clothing / fashion
    'cloth|fashion|shirt|hoodie|shoe|sneaker|apparel|wear|drip|fit': [
      "yooo clothing is goated for reselling rn.. streetwear, designer, sneakers - margins are crazy. <a href='/collections/all'>check our clothing suppliers</a> 🔥",
      "bro clothing reselling is where its at.. our suppliers got stuff that retails for 10x what u pay wholesale. <a href='/collections/all'>peep em here</a>"
    ],
    // Electronics / tech
    'electronic|tech|phone|laptop|headphone|airpod|watch|gadget': [
      "tech is huge rn bro.. watches, airpods, headphones all flip for crazy margins. <a href='/collections/all'>check the tech suppliers</a> 💰",
      "electronics reselling hits different.. our suppliers got stuff u cant find anywhere else. <a href='/collections/all'>take a look</a>"
    ],
    // Jewelry / accessories
    'jewel|accessor|bracelet|necklace|ring|chain|moissanite|cologne|perfume': [
      "accessories and jewelry got insane margins bro.. moissanite especially. ppl pay retail and u get it for pennies. <a href='/collections/all'>see whats available</a>",
      "cologne and jewelry is easy money fr.. low investment high return. <a href='/collections/all'>check the suppliers</a> 🔥"
    ],
    // All / everything
    'all|everything|every|complete|full|mega|ultimate': [
      "if u want the whole bag just grab the full supplier list.. covers every single category. best value by far <a href='/collections/all'>right here</a> 💪",
      "go big or go home right? 😤 the full list gives u access to everything. <a href='/collections/all'>check it out</a>"
    ],
    // How to start / reselling
    'start|begin|new|resell|flip|sell|hustle|side|how to': [
      "its easy fr.. 1) grab a supplier list 2) pick products u like 3) list em on ur own store or marketplace 4) profit 💰 want help choosing?",
      "bro starting is the easiest part.. just pick a category u fw, grab the suppliers, and start listing. most ppl overthink it tbh"
    ],
    // Profit / earnings
    'profit|earn|make money|income|roi|margin': [
      "our resellers see 2-5x margins easy.. some ppl making $1k+ their first month no cap. its all about picking the right niche",
      "the margins are crazy bro.. u buy wholesale for like $5-10 and sell retail for $30-50. do the math 📈"
    ],
    // Thanks / bye
    'thank|thanks|thx|bye|later|peace|cya|appreciate': [
      "ayy no problem! good luck with the reselling bro lets get this bread 🍞💰",
      "bet! lmk if u ever need anything else. go make that money 🚀",
      "aye anytime! rooting for u fr 💪 go get it"
    ],
    // Yes / sure / ok
    '^yes$|^yeah$|^sure$|^ok$|^yep$|^yea$|^bet$|^fs$|^fasho$': [
      "bet! <a href='/collections/all'>check out the suppliers</a> and grab what fits ur goals 🎯",
      "lessgo! head over to <a href='/collections/all'>the collection</a> and pick ur favorite 🔥"
    ],
    // No / nah
    '^no$|^nah$|^nope$|^im good$|^nvm$': [
      "aight no worries bro just browsing is cool too.. im here if u change ur mind 🤙",
      "all good! take ur time and lmk if u got questions later 💪"
    ],
    // Support / help / contact
    'support|help|contact|issue|problem|question': [
      "yo what do u need help with? im right here.. if its something specific u can also hit up our contact page",
      "bro lmk whats going on ill try to help u out rn 🤝"
    ],
    // Urgency / FOMO
    'think about|maybe later|not sure|idk|deciding': [
      "i feel u but fr prices go up soon and 99% of ppl just browse and never take action... dont be that guy 😭",
      "ngl bro the longer u wait the more money ur leaving on the table.. just sayin 📉",
      "take ur time but real talk.. most successful resellers started by just going for it. u got this 💪"
    ]
  };

  var fallbacks = [
    "yo you need help picking the right supplier? lmk what category ur interested in 🎯",
    "yo whats good, u looking to get into reselling? i can help u figure out where to start",
    "aight bet, if u want to check out what we got head to <a href='/collections/all'>the collection</a>. anything specific ur looking for?",
    "bro lmk if u have any questions, im here 💪 what category interests u most?",
    "99% of people just browse and never take action... dont be that guy 😭 lmk how i can help u get started"
  ];

  var fallbackIndex = 0;
  var conversationHistory = [];

  function pickRandom(arr) {
    if (typeof arr === 'string') return arr;
    return arr[Math.floor(Math.random() * arr.length)];
  }

  function findResponse(text) {
    var lower = text.toLowerCase().replace(/[^a-z0-9\s]/g, '');
    conversationHistory.push(lower);

    /* Check custom keywords from settings first */
    for (var trigger in extraKeywords) {
      if (lower.indexOf(trigger) !== -1) {
        return extraKeywords[trigger];
      }
    }

    /* Check built-in keyword patterns */
    for (var pattern in keywords) {
      if (new RegExp(pattern, 'i').test(lower)) {
        return pickRandom(keywords[pattern]);
      }
    }

    /* If custom context exists, use it as context-aware fallback */
    if (customContext && conversationHistory.length <= 3) {
      return "yo good question! " + customContext.split('.')[0].toLowerCase().trim() + ".. lmk if u want more details 🔥";
    }

    var resp = fallbacks[fallbackIndex % fallbacks.length];
    fallbackIndex++;
    return resp;
  }

  function showTyping() {
    var messages = document.getElementById('chat-messages');
    var typing = document.createElement('div');
    typing.className = 'chat-typing';
    typing.id = 'chat-typing';
    typing.innerHTML = '<span></span><span></span><span></span>';
    messages.appendChild(typing);
    messages.scrollTop = messages.scrollHeight;
  }

  function hideTyping() {
    var t = document.getElementById('chat-typing');
    if (t) t.remove();
  }

  window.sendChatMsg = function() {
    var input = document.getElementById('chat-input');
    var messages = document.getElementById('chat-messages');
    var text = input.value.trim();
    if (!text) return;

    var userMsg = document.createElement('div');
    userMsg.className = 'chat-msg user';
    userMsg.textContent = text;
    messages.appendChild(userMsg);
    input.value = '';
    messages.scrollTop = messages.scrollHeight;

    showTyping();

    var delay = 800 + Math.random() * 1200;
    setTimeout(function() {
      hideTyping();
      var botMsg = document.createElement('div');
      botMsg.className = 'chat-msg bot';
      botMsg.innerHTML = findResponse(text);
      messages.appendChild(botMsg);
      messages.scrollTop = messages.scrollHeight;
    }, delay);
  };
})();
</script>
{%- endif -%}
