{% comment %}
  Section: Custom Footer
  Version: 1.0 - Production Ready
{% endcomment %}

{%- liquid
  assign background_color = section.settings.background_color | default: '#000000'
  assign text_color = section.settings.text_color | default: '#E9E9E9'
  assign accent_color = section.settings.accent_color | default: '#7C3AED'
  assign subtle_text_color = section.settings.subtle_text_color | default: '#AAAAAA'
  assign border_color = section.settings.border_color | default: '#2A2A2A'
  
  assign current_year = 'now' | date: '%Y'
  assign copyright_text = section.settings.copyright_text | replace: '{{ year }}', current_year
-%}

{%- style -%}
  .footer-{{ section.id }} {
    background-color: {{ background_color }};
    color: {{ text_color }};
    font-family: 'Poppins', sans-serif;
    padding: 0;
    padding-top: 20px;
  }

  .footer-{{ section.id }} .footer-separator {
    width: 100%;
    height: 2px;
    background: {{ accent_color }};
    margin-bottom: 20px;
  }

  .footer-{{ section.id }} .footer-container {
    max-width: 1200px;
    margin: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 15px;
  }

  .footer-{{ section.id }} .footer-links {
    display: flex;
    justify-content: center;
    gap: 50px;
    margin-bottom: 15px;
    width: 100%;
    flex-wrap: wrap;
  }

  .footer-{{ section.id }} .footer-column {
    text-align: left;
  }

  .footer-{{ section.id }} .footer-column h4 {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 10px;
    color: {{ text_color }};
  }

  .footer-{{ section.id }} .footer-column ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-{{ section.id }} .footer-column ul li {
    margin-bottom: 8px;
  }

  .footer-{{ section.id }} .footer-column ul li a {
    color: {{ text_color }};
    text-decoration: none;
    font-size: 14px;
    transition: color 0.2s ease-out;
  }

  .footer-{{ section.id }} .footer-column ul li a:hover,
  .footer-{{ section.id }} .footer-column ul li a:active {
    color: {{ accent_color }};
  }

  .footer-{{ section.id }} .footer-bottom {
    width: 100%;
    text-align: center;
    font-size: 14px;
    color: {{ subtle_text_color }};
    border-top: 1px solid {{ border_color }};
    padding: 15px 0;
    margin-top: 20px;
  }

  .footer-{{ section.id }} .footer-bottom p {
    margin: 5px 0;
  }

  .footer-{{ section.id }} .design-credit {
    font-size: 13px;
    color: {{ subtle_text_color }};
  }

  /* 🔥 POPPING CTA LINK */
  .footer-{{ section.id }} .design-credit a {
    color: #ffffff !important;
    font-weight: 700 !important;
    text-decoration: underline;
    transition: color 0.2s ease-out;
  }

  .footer-{{ section.id }} .design-credit a:hover {
    color: {{ accent_color }};
  }

  @media (max-width: 768px) {
    .footer-{{ section.id }} .footer-links {
      flex-direction: column;
      align-items: center;
      gap: 25px;
    }

    .footer-{{ section.id }} .footer-column {
      text-align: center;
    }
  }
{%- endstyle -%}

<footer class="footer-{{ section.id }}">
  {%- if section.settings.show_top_separator -%}
    <div class="footer-separator"></div>
  {%- endif -%}

  <div class="footer-container">
    {%- if section.blocks.size > 0 -%}
      <div class="footer-links">
        {%- for block in section.blocks -%}
          <div class="footer-column" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h4>{{ block.settings.heading | escape }}</h4>
            {%- endif -%}

            {%- if block.settings.menu != blank -%}
              <ul>
                {%- for link in block.settings.menu.links -%}
                  <li>
                    <a href="{{ link.url }}">{{ link.title | escape }}</a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="footer-bottom">
      {%- if section.settings.copyright_text != blank -%}
        <p>{{ copyright_text }}</p>
      {%- endif -%}

      <p class="design-credit">
        <a href="https://www.instagram.com/og.vendorss_/" target="_blank" rel="noopener noreferrer">
          Start making money on Shopify →
        </a>
      </p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Custom Footer",
  "tag": "footer",
  "class": "shopify-section-footer",
  "settings": [
    { "type": "header", "content": "Color Settings" },
    { "type": "color", "id": "background_color", "label": "Background Color", "default": "#000000" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#E9E9E9" },
    { "type": "color", "id": "accent_color", "label": "Accent & Hover Color", "default": "#7C3AED" },
    { "type": "color", "id": "subtle_text_color", "label": "Subtle Text Color", "default": "#AAAAAA" },
    { "type": "color", "id": "border_color", "label": "Bottom Border Color", "default": "#2A2A2A" },
    { "type": "header", "content": "Layout & Content" },
    { "type": "checkbox", "id": "show_top_separator", "label": "Show Top Separator Line", "default": true },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "© {{ year }} aynjilflipz. All rights reserved."
    }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Link Column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Column Heading", "default": "Quick Links" },
        { "type": "link_list", "id": "menu", "label": "Select Menu" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Footer",
      "blocks": [
        { "type": "link_column" },
        { "type": "link_column", "settings": { "heading": "Policies" } }
      ]
    }
  ]
}
{% endschema %}
