{%- unless template.name == 'index' or section.settings.show_on_all_pages -%}
  {%- style -%}.vx-shell[data-vx-section="urgency-bar"] { display: none !important; }{%- endstyle -%}
{%- endunless -%}

<section class="vx-shell vx-shell--loading" data-vx-section="urgency-bar">
  <div class="vx-editor-preview"><div class="vx-section-loader"><div class="vx-loader__spinner"></div></div></div>
</section>

<script type="application/json" data-vx-settings="urgency-bar">
{
  "reveal_on_scroll": {{ section.settings.reveal_on_scroll | json }},
  "reveal_distance": {{ section.settings.reveal_distance | default: 80 }},
  "show_on_all_pages": {{ section.settings.show_on_all_pages | json }},
  "bg_color": {{ section.settings.bg_color | default: '#000000' | json }},
  "text_color": {{ section.settings.text_color | default: '#ffffff' | json }},
  "accent_color": {{ section.settings.accent_color | default: '#39ff14' | json }},
  "icon_color": {{ section.settings.icon_color | default: '#39ff14' | json }},
  "dot_color": {{ section.settings.dot_color | default: '#39ff14' | json }},
  "divider_color": {{ section.settings.divider_color | default: '#333333' | json }},
  "border_color": {{ section.settings.border_color | default: '#1a1a1a' | json }},
  "bar_height": {{ section.settings.bar_height | default: 36 }},
  "font_size": {{ section.settings.font_size | default: 13 }},
  "scroll_speed": {{ section.settings.scroll_speed | default: 30 }},
  "min_viewers": {{ section.settings.min_viewers | default: 10 }},
  "max_viewers": {{ section.settings.max_viewers | default: 100 }},
  "show_countdown": {{ section.settings.show_countdown | json }},
  "show_rating": {{ section.settings.show_rating | json }},
  "show_viewers": {{ section.settings.show_viewers | json }},
  "show_private": {{ section.settings.show_private | json }},
  "show_personally_verified": {{ section.settings.show_personally_verified | json }},
  "countdown_prefix": {{ section.settings.countdown_prefix | default: 'Price goes up in' | json }},
  "rating_value": {{ section.settings.rating_value | default: '4.96/5' | json }},
  "rating_count": {{ section.settings.rating_count | default: '2,400+' | json }},
  "viewers_text": {{ section.settings.viewers_text | default: 'people viewing right now' | json }},
  "private_text": {{ section.settings.private_text | default: 'Private suppliers not found anywhere else' | json }},
  "personally_verified_text": {{ section.settings.personally_verified_text | default: 'All suppliers personally verified' | json }},
  "blocks": [
    {%- for block in section.blocks -%}
      {%- if block.type == 'custom_item' -%}
        {"type":"custom_item","settings":{"text":{{ block.settings.text | json }}}}{% unless forloop.last %},{% endunless %}
      {%- endif -%}
    {%- endfor -%}
  ]
}
</script>

{% schema %}
{
  "name": "Urgency Bar",
  "tag": "section",
  "class": "urgency-bar-section",
  "settings": [
    { "type": "header", "content": "Behavior" },
    { "type": "checkbox", "id": "reveal_on_scroll", "label": "Hide at top, reveal on scroll", "default": true, "info": "Bar slides in from above when user scrolls down" },
    { "type": "range", "id": "reveal_distance", "label": "Scroll distance to reveal (px)", "min": 20, "max": 300, "step": 10, "default": 80, "info": "How far the user scrolls before bar appears" },
    { "type": "header", "content": "Visibility" },
    { "type": "checkbox", "id": "show_on_all_pages", "label": "Show on all pages (not just homepage)", "default": false },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#000000" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#39ff14" },
    { "type": "color", "id": "icon_color", "label": "Icon color", "default": "#39ff14" },
    { "type": "color", "id": "dot_color", "label": "Pulsing dot color", "default": "#39ff14" },
    { "type": "color", "id": "divider_color", "label": "Divider dot color", "default": "#333333" },
    { "type": "color", "id": "border_color", "label": "Bottom border color", "default": "#1a1a1a" },
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "bar_height", "label": "Bar height (px)", "min": 24, "max": 60, "step": 2, "default": 36 },
    { "type": "range", "id": "font_size", "label": "Font size (px)", "min": 10, "max": 18, "step": 1, "default": 13 },
    { "type": "range", "id": "scroll_speed", "label": "Scroll speed (seconds)", "min": 10, "max": 80, "step": 5, "default": 30 },
    { "type": "header", "content": "Viewer Count" },
    { "type": "range", "id": "min_viewers", "label": "Min viewers", "min": 1, "max": 50, "step": 1, "default": 10 },
    { "type": "range", "id": "max_viewers", "label": "Max viewers", "min": 20, "max": 100, "step": 5, "default": 100 },
    { "type": "header", "content": "Toggle Items" },
    { "type": "checkbox", "id": "show_verified", "label": "Show 'Fully verified'", "default": false },
    { "type": "checkbox", "id": "show_countdown", "label": "Show countdown timer", "default": true },
    { "type": "checkbox", "id": "show_rating", "label": "Show rating", "default": true },
    { "type": "checkbox", "id": "show_viewers", "label": "Show live viewers", "default": true },
    { "type": "checkbox", "id": "show_private", "label": "Show 'Private suppliers'", "default": true },
    { "type": "checkbox", "id": "show_personally_verified", "label": "Show 'Personally verified'", "default": true },
    { "type": "header", "content": "Custom Text" },
    { "type": "text", "id": "verified_text", "label": "Verified text", "default": "Fully verified" },
    { "type": "text", "id": "countdown_prefix", "label": "Countdown prefix", "default": "Price goes up in" },
    { "type": "text", "id": "rating_value", "label": "Rating value", "default": "4.96/5" },
    { "type": "text", "id": "rating_count", "label": "Rating count", "default": "2,400+" },
    { "type": "text", "id": "viewers_text", "label": "Viewers suffix", "default": "people viewing right now" },
    { "type": "text", "id": "private_text", "label": "Private text", "default": "Private suppliers not found anywhere else" },
    { "type": "text", "id": "personally_verified_text", "label": "Personally verified text", "default": "All suppliers personally verified" }
  ],
  "blocks": [
    {
      "type": "custom_item",
      "name": "Custom Item",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Custom announcement text" }
      ]
    }
  ],
  "presets": [
    { "name": "Urgency Bar" }
  ]
}
{% endschema %}
