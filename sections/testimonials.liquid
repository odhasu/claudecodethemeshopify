{%- liquid
  assign title = section.settings.title | default: 'What Our Customers Say'
  assign title_color = section.settings.title_color | default: '#ffffff'
  assign speed = section.settings.scroll_speed | default: 20
  assign img_height = section.settings.image_height | default: 250
  assign img_height_2x = img_height | times: 2
  assign img_height_mobile = section.settings.image_height_mobile | default: 180
  assign img_radius = section.settings.image_radius | default: 12
  assign bg_color = section.settings.bg_color | default: '#000000'
  assign padding_top = section.settings.padding_top | default: 60
  assign padding_bottom = section.settings.padding_bottom | default: 60
  assign gap = section.settings.gap | default: 16
  assign max_width = section.settings.max_width | default: 1400
-%}

<style>
  .testimonials-section {
    background: {{ bg_color }};
    padding: {{ padding_top }}px 0 {{ padding_bottom }}px;
    overflow: hidden;
  }
  .testimonials-title {
    text-align: center;
    font-family: var(--font-heading);
    font-size: clamp(24px, 4vw, 36px);
    text-transform: uppercase;
    color: {{ title_color }};
    margin-bottom: 32px;
    padding: 0 20px;
  }
  .testimonials-track-wrapper {
    position: relative;
    max-width: {{ max_width }}px;
    margin: 0 auto;
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }
  .testimonials-track {
    display: flex;
    gap: {{ gap }}px;
    width: max-content;
    animation: testimonialScroll {{ speed }}s linear infinite;
  }
  .testimonials-track:hover { animation-play-state: paused; }
  .testimonials-track img {
    height: {{ img_height }}px;
    width: auto;
    border-radius: {{ img_radius }}px;
    object-fit: cover;
    flex-shrink: 0;
  }
  @media (max-width: 768px) {
    .testimonials-track img { height: {{ img_height_mobile }}px; }
  }
  @keyframes testimonialScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>

<section class="testimonials-section">
  {%- if title != blank -%}
    <h2 class="testimonials-title">{{ title }}</h2>
  {%- endif -%}
  <div class="testimonials-track-wrapper">
    <div class="testimonials-track">
      {%- comment -%} First pass — all images {%- endcomment -%}
      {%- for i in (1..20) -%}
        {%- assign img_key = 'image_' | append: i -%}
        {%- assign img = section.settings[img_key] -%}
        {%- if img != blank -%}
          <img src="{{ img | image_url: height: img_height_2x }}" alt="Customer testimonial {{ i }}" loading="lazy">
        {%- endif -%}
      {%- endfor -%}
      {%- comment -%} Duplicate for seamless loop {%- endcomment -%}
      {%- for i in (1..20) -%}
        {%- assign img_key = 'image_' | append: i -%}
        {%- assign img = section.settings[img_key] -%}
        {%- if img != blank -%}
          <img src="{{ img | image_url: height: img_height_2x }}" alt="Customer testimonial {{ i }}" loading="lazy">
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Section Settings" },
    { "type": "text", "id": "title", "label": "Section Headline", "default": "What Our Customers Say" },
    { "type": "color", "id": "title_color", "label": "Title color", "default": "#ffffff" },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#000000" },
    { "type": "range", "id": "scroll_speed", "label": "Scroll Speed (seconds)", "min": 10, "max": 60, "step": 5, "default": 20 },
    { "type": "range", "id": "max_width", "label": "Content Max Width", "min": 800, "max": 1800, "step": 50, "default": 1400 },
    { "type": "range", "id": "image_height", "label": "Image Height", "min": 150, "max": 400, "step": 10, "default": 250 },
    { "type": "range", "id": "image_height_mobile", "label": "Image height mobile (px)", "min": 100, "max": 300, "step": 10, "default": 180 },
    { "type": "range", "id": "image_radius", "label": "Image border radius (px)", "min": 0, "max": 24, "step": 2, "default": 12 },
    { "type": "range", "id": "gap", "label": "Gap between images (px)", "min": 8, "max": 32, "step": 4, "default": 16 },
    { "type": "range", "id": "padding_top", "label": "Top padding (px)", "min": 0, "max": 120, "step": 10, "default": 60 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding (px)", "min": 0, "max": 120, "step": 10, "default": 60 },
    { "type": "header", "content": "Testimonial Images" },
    { "type": "image_picker", "id": "image_1", "label": "Image 1" },
    { "type": "image_picker", "id": "image_2", "label": "Image 2" },
    { "type": "image_picker", "id": "image_3", "label": "Image 3" },
    { "type": "image_picker", "id": "image_4", "label": "Image 4" },
    { "type": "image_picker", "id": "image_5", "label": "Image 5" },
    { "type": "image_picker", "id": "image_6", "label": "Image 6" },
    { "type": "image_picker", "id": "image_7", "label": "Image 7" },
    { "type": "image_picker", "id": "image_8", "label": "Image 8" },
    { "type": "image_picker", "id": "image_9", "label": "Image 9" },
    { "type": "image_picker", "id": "image_10", "label": "Image 10" },
    { "type": "image_picker", "id": "image_11", "label": "Image 11" },
    { "type": "image_picker", "id": "image_12", "label": "Image 12" },
    { "type": "image_picker", "id": "image_13", "label": "Image 13" },
    { "type": "image_picker", "id": "image_14", "label": "Image 14" },
    { "type": "image_picker", "id": "image_15", "label": "Image 15" },
    { "type": "image_picker", "id": "image_16", "label": "Image 16" },
    { "type": "image_picker", "id": "image_17", "label": "Image 17" },
    { "type": "image_picker", "id": "image_18", "label": "Image 18" },
    { "type": "image_picker", "id": "image_19", "label": "Image 19" },
    { "type": "image_picker", "id": "image_20", "label": "Image 20" }
  ],
  "presets": [
    { "name": "Testimonials" }
  ]
}
{% endschema %}
