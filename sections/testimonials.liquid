{%- liquid
  assign has_images = false
  for i in (1..20)
    assign img_key = 'image_' | append: i
    if section.settings[img_key] != blank
      assign has_images = true
      break
    endif
  endfor
-%}

{%- if has_images -%}
<style>
  #testimonials-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    overflow: hidden;
  }

  #testimonials-{{ section.id }} .tm-heading {
    font-family: 'Clash Grotesk', sans-serif;
    font-weight: 700;
    font-size: 28px;
    text-transform: uppercase;
    color: {{ section.settings.title_color }};
    text-align: center;
    margin: 0 0 32px;
    padding: 0 20px;
  }

  #testimonials-{{ section.id }} .tm-wrapper {
    position: relative;
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    overflow: hidden;
  }

  #testimonials-{{ section.id }} .tm-wrapper::before,
  #testimonials-{{ section.id }} .tm-wrapper::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 80px;
    z-index: 2;
    pointer-events: none;
  }

  #testimonials-{{ section.id }} .tm-wrapper::before {
    left: 0;
    background: linear-gradient(to right, {{ section.settings.bg_color }}, transparent);
  }

  #testimonials-{{ section.id }} .tm-wrapper::after {
    right: 0;
    background: linear-gradient(to left, {{ section.settings.bg_color }}, transparent);
  }

  #testimonials-{{ section.id }} .tm-track {
    display: flex;
    gap: {{ section.settings.gap }}px;
    width: max-content;
    animation: tm-scroll-{{ section.id }} {{ section.settings.scroll_speed }}s linear infinite;
  }

  #testimonials-{{ section.id }} .tm-wrapper:hover .tm-track {
    animation-play-state: paused;
  }

  #testimonials-{{ section.id }} .tm-track img {
    height: {{ section.settings.image_height }}px;
    width: auto;
    border-radius: {{ section.settings.image_radius }}px;
    object-fit: cover;
    display: block;
    flex-shrink: 0;
  }

  @keyframes tm-scroll-{{ section.id }} {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (max-width: 749px) {
    #testimonials-{{ section.id }} .tm-track img {
      height: {{ section.settings.image_height_mobile }}px;
    }
  }
</style>

<div id="testimonials-{{ section.id }}">
  <h2 class="tm-heading">{{ section.settings.title }}</h2>
  <div class="tm-wrapper">
    <div class="tm-track">
      {%- comment -%} First set {%- endcomment -%}
      {%- for i in (1..20) -%}
        {%- assign img_key = 'image_' | append: i -%}
        {%- if section.settings[img_key] != blank -%}
          <img src="{{ section.settings[img_key] | image_url: height: 500 }}" alt="Customer testimonial {{ i }}" loading="lazy">
        {%- endif -%}
      {%- endfor -%}
      {%- comment -%} Duplicate set for seamless loop {%- endcomment -%}
      {%- for i in (1..20) -%}
        {%- assign img_key = 'image_' | append: i -%}
        {%- if section.settings[img_key] != blank -%}
          <img src="{{ section.settings[img_key] | image_url: height: 500 }}" alt="Customer testimonial {{ i }}" loading="lazy">
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Section Settings" },
    { "type": "text", "id": "title", "label": "Section Headline", "default": "What Our Customers Say" },
    { "type": "color", "id": "title_color", "label": "Title color", "default": "#ffffff" },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#000000" },
    { "type": "range", "id": "scroll_speed", "label": "Scroll Speed (seconds)", "min": 10, "max": 60, "step": 5, "default": 20 },
    { "type": "range", "id": "max_width", "label": "Content Max Width", "min": 800, "max": 1800, "step": 50, "default": 1400 },
    { "type": "range", "id": "image_height", "label": "Image Height", "min": 150, "max": 400, "step": 10, "default": 250 },
    { "type": "range", "id": "image_height_mobile", "label": "Image height mobile (px)", "min": 100, "max": 300, "step": 10, "default": 180 },
    { "type": "range", "id": "image_radius", "label": "Image border radius (px)", "min": 0, "max": 24, "step": 2, "default": 12 },
    { "type": "range", "id": "gap", "label": "Gap between images (px)", "min": 8, "max": 32, "step": 4, "default": 16 },
    { "type": "range", "id": "padding_top", "label": "Top padding (px)", "min": 0, "max": 120, "step": 10, "default": 60 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding (px)", "min": 0, "max": 120, "step": 10, "default": 60 },
    { "type": "header", "content": "Testimonial Images" },
    { "type": "image_picker", "id": "image_1", "label": "Image 1" },
    { "type": "image_picker", "id": "image_2", "label": "Image 2" },
    { "type": "image_picker", "id": "image_3", "label": "Image 3" },
    { "type": "image_picker", "id": "image_4", "label": "Image 4" },
    { "type": "image_picker", "id": "image_5", "label": "Image 5" },
    { "type": "image_picker", "id": "image_6", "label": "Image 6" },
    { "type": "image_picker", "id": "image_7", "label": "Image 7" },
    { "type": "image_picker", "id": "image_8", "label": "Image 8" },
    { "type": "image_picker", "id": "image_9", "label": "Image 9" },
    { "type": "image_picker", "id": "image_10", "label": "Image 10" },
    { "type": "image_picker", "id": "image_11", "label": "Image 11" },
    { "type": "image_picker", "id": "image_12", "label": "Image 12" },
    { "type": "image_picker", "id": "image_13", "label": "Image 13" },
    { "type": "image_picker", "id": "image_14", "label": "Image 14" },
    { "type": "image_picker", "id": "image_15", "label": "Image 15" },
    { "type": "image_picker", "id": "image_16", "label": "Image 16" },
    { "type": "image_picker", "id": "image_17", "label": "Image 17" },
    { "type": "image_picker", "id": "image_18", "label": "Image 18" },
    { "type": "image_picker", "id": "image_19", "label": "Image 19" },
    { "type": "image_picker", "id": "image_20", "label": "Image 20" }
  ],
  "presets": [
    { "name": "Testimonials" }
  ]
}
{% endschema %}
