{%- liquid
  assign logo_height   = section.settings.logo_height   | default: 28
  assign brand_text    = section.settings.brand_text    | default: shop.name
  assign brand_size    = section.settings.brand_font_size | default: 16
  assign brand_color   = section.settings.brand_color   | default: '#ffffff'
  assign nav_color     = section.settings.nav_color     | default: '#aaaaaa'
  assign nav_hover     = section.settings.nav_hover_color | default: '#ffffff'
  assign icon_color    = section.settings.icon_color    | default: '#ffffff'
  assign bar_bg        = section.settings.bar_bg        | default: '#000000'
  assign bar_height    = section.settings.bar_height    | default: 56
  assign bar_border    = section.settings.bar_border    | default: 'none'
  assign show_cart     = section.settings.show_cart
  assign badge_bg      = section.settings.badge_bg      | default: settings.color_accent | default: '#39ff14'
  assign badge_color   = section.settings.badge_text_color | default: '#000000'
-%}

<style>
  /* ── Bar ──────────────────────────────────────────────────── */
  .lv-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 200;
    background: {{ bar_bg }};
    height: {{ bar_height }}px;
    display: flex;
    align-items: center;
    {%- if bar_border == 'bottom' %}
    border-bottom: 1px solid {{ section.settings.border_color | default: '#1a1a1a' }};
    {%- endif %}
  }

  .lv-header-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    width: 100%;
    padding: 0 {{ section.settings.padding_x | default: 24 }}px;
  }

  /* ── Logo / Brand ─────────────────────────────────────────── */
  .lv-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    justify-content: flex-start;
  }
  .lv-logo img {
    height: {{ logo_height }}px;
    width: auto;
    display: block;
  }
  .lv-brand {
    font-family: var(--font-heading, 'DM Sans', sans-serif);
    font-size: {{ brand_size }}px;
    font-weight: 800;
    font-style: italic;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: {{ brand_color }};
    white-space: nowrap;
    text-decoration: none;
    line-height: 1;
  }

  /* ── Nav (center) ─────────────────────────────────────────── */
  .lv-nav {
    display: flex;
    align-items: center;
    gap: {{ section.settings.nav_gap | default: 28 }}px;
    justify-content: center;
  }
  .lv-nav a {
    font-size: {{ section.settings.nav_font_size | default: 14 }}px;
    font-weight: {{ section.settings.nav_font_weight | default: 400 }};
    color: {{ nav_color }};
    text-decoration: none;
    transition: color 0.15s;
    white-space: nowrap;
    line-height: 1;
  }
  .lv-nav a:hover { color: {{ nav_hover }}; }

  /* ── Right side — cart ───────────────────────────────────── */
  .lv-right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 12px;
  }
  .lv-cart {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ icon_color }};
    text-decoration: none;
    line-height: 1;
  }
  .lv-cart svg {
    width: 20px;
    height: 20px;
    display: block;
  }
  .lv-cart-badge {
    position: absolute;
    top: -6px; right: -7px;
    background: {{ badge_bg }};
    color: {{ badge_color }};
    font-size: 9px;
    font-weight: 800;
    min-width: 15px;
    height: 15px;
    border-radius: 999px;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 0 3px;
    line-height: 1;
  }
  .lv-cart-badge.active { display: flex; }

  /* ── Spacer ───────────────────────────────────────────────── */
  .lv-header-spacer { height: {{ bar_height }}px; }

  /* ── Mobile ───────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .lv-header-inner {
      padding: 0 16px;
    }
    .lv-nav {
      gap: 18px;
    }
    .lv-nav a {
      font-size: 13px;
    }
    .lv-brand {
      font-size: {{ brand_size | minus: 2 }}px;
    }
  }
</style>

<div class="lv-header-spacer"></div>

<header class="lv-header" role="banner">
  <div class="lv-header-inner">

    <!-- LEFT: Logo / Brand -->
    <a href="/" class="lv-logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: height: 80 }}"
          alt="{{ shop.name }}"
          width="auto"
          height="{{ logo_height }}"
        >
      {%- else -%}
        <span class="lv-brand">{{ brand_text }}</span>
      {%- endif -%}
    </a>

    <!-- CENTER: Nav -->
    <nav class="lv-nav" aria-label="Main navigation">
      {%- if section.settings.nav_link_1_text != blank -%}
        <a href="{{ section.settings.nav_link_1_url | default: '/' }}">{{ section.settings.nav_link_1_text }}</a>
      {%- endif -%}
      {%- if section.settings.nav_link_2_text != blank -%}
        <a href="{{ section.settings.nav_link_2_url | default: '/collections/all' }}">{{ section.settings.nav_link_2_text }}</a>
      {%- endif -%}
      {%- if section.settings.nav_link_3_text != blank -%}
        <a href="{{ section.settings.nav_link_3_url }}">{{ section.settings.nav_link_3_text }}</a>
      {%- endif -%}
      {%- if section.settings.nav_link_4_text != blank -%}
        <a href="{{ section.settings.nav_link_4_url }}">{{ section.settings.nav_link_4_text }}</a>
      {%- endif -%}
      {%- if section.settings.nav_link_1_text == blank and section.settings.nav_link_2_text == blank -%}
        <a href="/">Home</a>
        <a href="/collections/all">Products</a>
      {%- endif -%}
    </nav>

    <!-- RIGHT: Cart -->
    <div class="lv-right">
      {%- if show_cart != false -%}
        <a href="/cart" class="lv-cart" aria-label="Cart" id="lv-cart">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 001.99 1.61h9.72a2 2 0 001.99-1.76l1.07-7.68H6"/>
          </svg>
          <span class="lv-cart-badge" id="lv-cart-badge"></span>
        </a>
      {%- endif -%}
    </div>

  </div>
</header>

<script>
(function() {
  var badge = document.getElementById('lv-cart-badge');
  if (badge) {
    fetch('/cart.js')
      .then(function(r) { return r.json(); })
      .then(function(c) {
        if (c.item_count > 0) {
          badge.textContent = c.item_count;
          badge.classList.add('active');
        }
      })
      .catch(function() {});
  }
})();
</script>

{% schema %}
{
  "name": "Header Bar",
  "tag": "header",
  "class": "vx-header-wrapper",
  "settings": [
    { "type": "header", "content": "Logo" },
    { "type": "image_picker", "id": "logo", "label": "Logo image", "info": "If blank, brand text is shown" },
    { "type": "range", "id": "logo_height", "label": "Logo height (px)", "min": 16, "max": 56, "step": 2, "default": 28 },
    { "type": "text", "id": "brand_text", "label": "Brand text (if no logo)" },
    { "type": "range", "id": "brand_font_size", "label": "Brand font size (px)", "min": 11, "max": 28, "step": 1, "default": 16 },
    { "type": "color", "id": "brand_color", "label": "Brand text color", "default": "#ffffff" },
    { "type": "header", "content": "Bar" },
    { "type": "color", "id": "bar_bg", "label": "Background color", "default": "#000000" },
    { "type": "range", "id": "bar_height", "label": "Bar height (px)", "min": 44, "max": 80, "step": 4, "default": 56 },
    { "type": "range", "id": "padding_x", "label": "Side padding (px)", "min": 12, "max": 60, "step": 4, "default": 24 },
    { "type": "select", "id": "bar_border", "label": "Bottom border", "default": "none", "options": [
      { "value": "none", "label": "None" },
      { "value": "bottom", "label": "Show border" }
    ]},
    { "type": "color", "id": "border_color", "label": "Border color", "default": "#1a1a1a" },
    { "type": "header", "content": "Navigation" },
    { "type": "color", "id": "nav_color", "label": "Link color", "default": "#aaaaaa" },
    { "type": "color", "id": "nav_hover_color", "label": "Link hover color", "default": "#ffffff" },
    { "type": "range", "id": "nav_font_size", "label": "Font size (px)", "min": 11, "max": 18, "step": 1, "default": 14 },
    { "type": "select", "id": "nav_font_weight", "label": "Font weight", "default": "400", "options": [
      { "value": "300", "label": "Light" },
      { "value": "400", "label": "Regular" },
      { "value": "500", "label": "Medium" },
      { "value": "600", "label": "Semibold" }
    ]},
    { "type": "range", "id": "nav_gap", "label": "Gap between links (px)", "min": 12, "max": 56, "step": 4, "default": 28 },
    { "type": "text", "id": "nav_link_1_text", "label": "Link 1 text", "default": "Home" },
    { "type": "url",  "id": "nav_link_1_url",  "label": "Link 1 URL" },
    { "type": "text", "id": "nav_link_2_text", "label": "Link 2 text", "default": "Products" },
    { "type": "url",  "id": "nav_link_2_url",  "label": "Link 2 URL" },
    { "type": "text", "id": "nav_link_3_text", "label": "Link 3 text" },
    { "type": "url",  "id": "nav_link_3_url",  "label": "Link 3 URL" },
    { "type": "text", "id": "nav_link_4_text", "label": "Link 4 text" },
    { "type": "url",  "id": "nav_link_4_url",  "label": "Link 4 URL" },
    { "type": "header", "content": "Cart" },
    { "type": "checkbox", "id": "show_cart", "label": "Show cart icon", "default": true },
    { "type": "color", "id": "icon_color", "label": "Cart icon color", "default": "#ffffff" },
    { "type": "color", "id": "badge_bg", "label": "Cart badge background", "default": "#39ff14" },
    { "type": "color", "id": "badge_text_color", "label": "Cart badge text", "default": "#000000" }
  ],
  "presets": [
    { "name": "Header Bar" }
  ]
}
{% endschema %}
