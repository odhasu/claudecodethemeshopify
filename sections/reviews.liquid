<style>
  #reviews-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  #reviews-{{ section.id }} .reviews__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }
  #reviews-{{ section.id }} .reviews__header {
    text-align: center;
  }
  #reviews-{{ section.id }} .reviews__title {
    font-family: var(--font-heading, 'Clash Grotesk', sans-serif);
    font-weight: 700;
    font-size: 28px;
    text-transform: uppercase;
    color: {{ section.settings.title_color }};
    margin: 0;
    line-height: 1.2;
  }
  #reviews-{{ section.id }} .reviews__subtitle {
    color: {{ section.settings.subtitle_color }};
    font-size: 15px;
    margin: 8px 0 0;
    line-height: 1.4;
  }
  #reviews-{{ section.id }} .reviews__rating-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 16px;
    flex-wrap: wrap;
  }
  #reviews-{{ section.id }} .reviews__stars-display {
    display: flex;
    gap: 2px;
  }
  #reviews-{{ section.id }} .reviews__stars-display svg {
    width: 18px;
    height: 18px;
    fill: {{ section.settings.star_color }};
  }
  #reviews-{{ section.id }} .reviews__rating-num {
    font-weight: 700;
    font-size: 15px;
    color: {{ section.settings.title_color }};
  }
  #reviews-{{ section.id }} .reviews__rating-count {
    color: {{ section.settings.subtitle_color }};
    font-size: 14px;
  }
  #reviews-{{ section.id }} .reviews__write-btn {
    display: inline-block;
    margin-top: 16px;
    background: {{ section.settings.write_btn_bg }};
    color: {{ section.settings.write_btn_text_color }};
    font-weight: 700;
    font-size: 13px;
    text-transform: uppercase;
    padding: 12px 28px;
    border-radius: 50px;
    border: none;
    cursor: pointer;
    letter-spacing: 0.03em;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }
  #reviews-{{ section.id }} .reviews__write-btn:hover {
    opacity: 0.9;
  }
  #reviews-{{ section.id }} .reviews__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: 16px;
    margin-top: 32px;
  }
  @media (max-width: 768px) {
    #reviews-{{ section.id }} .reviews__grid {
      grid-template-columns: 1fr;
    }
  }
  #reviews-{{ section.id }} .reviews__card {
    background: {{ section.settings.card_bg }};
    border: 1px solid {{ section.settings.card_border }};
    border-radius: 12px;
    padding: {{ section.settings.card_padding }}px;
  }
  #reviews-{{ section.id }} .reviews__card-header {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  #reviews-{{ section.id }} .reviews__avatar {
    width: {{ section.settings.avatar_size }}px;
    height: {{ section.settings.avatar_size }}px;
    min-width: {{ section.settings.avatar_size }}px;
    border-radius: 50%;
    background: {{ section.settings.avatar_bg }};
    color: {{ section.settings.avatar_text_color }};
    font-weight: 700;
    font-size: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-transform: uppercase;
    line-height: 1;
  }
  #reviews-{{ section.id }} .reviews__reviewer-info {
    display: flex;
    flex-direction: column;
  }
  #reviews-{{ section.id }} .reviews__reviewer-name {
    font-weight: 600;
    font-size: 14px;
    color: {{ section.settings.title_color }};
    line-height: 1.3;
  }
  #reviews-{{ section.id }} .reviews__reviewer-date {
    color: #6b7280;
    font-size: 12px;
    line-height: 1.3;
    margin-top: 2px;
  }
  #reviews-{{ section.id }} .reviews__card-stars {
    display: flex;
    gap: 2px;
    margin-top: 8px;
  }
  #reviews-{{ section.id }} .reviews__card-stars svg {
    width: 14px;
    height: 14px;
    fill: {{ section.settings.star_color }};
  }
  #reviews-{{ section.id }} .reviews__card-text {
    color: {{ section.settings.subtitle_color }};
    font-size: 14px;
    line-height: 1.5;
    margin-top: 8px;
  }

  /* Modal styles */
  #reviews-{{ section.id }} .reviews__modal-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.7);
    z-index: 9999;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }
  #reviews-{{ section.id }} .reviews__modal-overlay.is-open {
    display: flex;
  }
  #reviews-{{ section.id }} .reviews__modal {
    background: {{ section.settings.card_bg }};
    border: 1px solid {{ section.settings.card_border }};
    border-radius: 16px;
    padding: 32px;
    max-width: 480px;
    width: 100%;
    position: relative;
  }
  #reviews-{{ section.id }} .reviews__modal-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    color: {{ section.settings.subtitle_color }};
    cursor: pointer;
    font-size: 20px;
    line-height: 1;
    padding: 4px;
  }
  #reviews-{{ section.id }} .reviews__modal-title {
    font-family: var(--font-heading, 'Clash Grotesk', sans-serif);
    font-weight: 700;
    font-size: 20px;
    color: {{ section.settings.title_color }};
    margin: 0 0 20px;
  }
  #reviews-{{ section.id }} .reviews__modal-field {
    margin-bottom: 16px;
  }
  #reviews-{{ section.id }} .reviews__modal-label {
    display: block;
    color: {{ section.settings.subtitle_color }};
    font-size: 13px;
    margin-bottom: 6px;
    font-weight: 500;
  }
  #reviews-{{ section.id }} .reviews__modal-input,
  #reviews-{{ section.id }} .reviews__modal-textarea {
    width: 100%;
    background: #0a0a0a;
    border: 1px solid {{ section.settings.card_border }};
    border-radius: 8px;
    padding: 10px 14px;
    color: {{ section.settings.title_color }};
    font-size: 14px;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s ease;
    box-sizing: border-box;
  }
  #reviews-{{ section.id }} .reviews__modal-input:focus,
  #reviews-{{ section.id }} .reviews__modal-textarea:focus {
    border-color: {{ section.settings.write_btn_bg }};
  }
  #reviews-{{ section.id }} .reviews__modal-textarea {
    resize: vertical;
    min-height: 100px;
  }
  #reviews-{{ section.id }} .reviews__modal-stars {
    display: flex;
    gap: 4px;
  }
  #reviews-{{ section.id }} .reviews__modal-stars svg {
    width: 24px;
    height: 24px;
    fill: #333;
    cursor: pointer;
    transition: fill 0.15s ease;
  }
  #reviews-{{ section.id }} .reviews__modal-stars svg.active {
    fill: {{ section.settings.star_color }};
  }
  #reviews-{{ section.id }} .reviews__modal-submit {
    display: block;
    width: 100%;
    margin-top: 8px;
    background: {{ section.settings.write_btn_bg }};
    color: {{ section.settings.write_btn_text_color }};
    font-weight: 700;
    font-size: 14px;
    text-transform: uppercase;
    padding: 14px;
    border-radius: 50px;
    border: none;
    cursor: pointer;
    letter-spacing: 0.03em;
    transition: opacity 0.2s ease;
  }
  #reviews-{{ section.id }} .reviews__modal-submit:hover {
    opacity: 0.9;
  }
</style>

{%- capture star_svg -%}
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
{%- endcapture -%}

<div id="reviews-{{ section.id }}">
  <div class="reviews__container">
    <div class="reviews__header">
      <h2 class="reviews__title">{{ section.settings.title }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="reviews__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
      <div class="reviews__rating-row">
        <div class="reviews__stars-display">
          {{ star_svg }}{{ star_svg }}{{ star_svg }}{{ star_svg }}{{ star_svg }}
        </div>
        <span class="reviews__rating-num">{{ section.settings.rating }}</span>
        <span class="reviews__rating-count">({{ section.settings.review_count }} reviews)</span>
      </div>
      <button class="reviews__write-btn" data-reviews-open-modal>WRITE A REVIEW</button>
    </div>

    <div class="reviews__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'review' -%}
          <div class="reviews__card" {{ block.shopify_attributes }}>
            <div class="reviews__card-header">
              <div class="reviews__avatar">
                {%- assign name_str = block.settings.name | default: 'AN' -%}
                {%- assign initials = name_str | slice: 0, 2 -%}
                {{ initials }}
              </div>
              <div class="reviews__reviewer-info">
                <span class="reviews__reviewer-name">{{ block.settings.name }}</span>
                {%- if block.settings.date != blank -%}
                  <span class="reviews__reviewer-date">{{ block.settings.date }}</span>
                {%- endif -%}
              </div>
            </div>
            <div class="reviews__card-stars">
              {%- assign star_count = block.settings.stars | default: 5 -%}
              {%- for i in (1..5) -%}
                {%- if i <= star_count -%}
                  {{ star_svg }}
                {%- endif -%}
              {%- endfor -%}
            </div>
            {%- if block.settings.text != blank -%}
              <p class="reviews__card-text">{{ block.settings.text }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Review modal -->
    <div class="reviews__modal-overlay" data-reviews-modal>
      <div class="reviews__modal">
        <button class="reviews__modal-close" data-reviews-close-modal>&times;</button>
        <h3 class="reviews__modal-title">Write a Review</h3>
        <div class="reviews__modal-field">
          <label class="reviews__modal-label">Name</label>
          <input type="text" class="reviews__modal-input" placeholder="Your name">
        </div>
        <div class="reviews__modal-field">
          <label class="reviews__modal-label">Rating</label>
          <div class="reviews__modal-stars" data-reviews-modal-stars>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" data-star="1"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" data-star="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" data-star="3"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" data-star="4"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" data-star="5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </div>
        </div>
        <div class="reviews__modal-field">
          <label class="reviews__modal-label">Review</label>
          <textarea class="reviews__modal-textarea" placeholder="Share your experience..."></textarea>
        </div>
        <button class="reviews__modal-submit">Submit Review</button>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    var section = document.getElementById('reviews-{{ section.id }}');
    if (!section) return;

    var modal = section.querySelector('[data-reviews-modal]');
    var openBtn = section.querySelector('[data-reviews-open-modal]');
    var closeBtn = section.querySelector('[data-reviews-close-modal]');
    var starsContainer = section.querySelector('[data-reviews-modal-stars]');
    var stars = starsContainer ? starsContainer.querySelectorAll('svg') : [];

    if (openBtn && modal) {
      openBtn.addEventListener('click', function() {
        modal.classList.add('is-open');
      });
    }

    if (closeBtn && modal) {
      closeBtn.addEventListener('click', function() {
        modal.classList.remove('is-open');
      });
    }

    if (modal) {
      modal.addEventListener('click', function(e) {
        if (e.target === modal) {
          modal.classList.remove('is-open');
        }
      });
    }

    // Star rating interaction
    var selectedRating = 0;
    stars.forEach(function(star) {
      star.addEventListener('click', function() {
        selectedRating = parseInt(star.getAttribute('data-star'));
        stars.forEach(function(s) {
          var val = parseInt(s.getAttribute('data-star'));
          if (val <= selectedRating) {
            s.classList.add('active');
          } else {
            s.classList.remove('active');
          }
        });
      });

      star.addEventListener('mouseenter', function() {
        var hoverVal = parseInt(star.getAttribute('data-star'));
        stars.forEach(function(s) {
          var val = parseInt(s.getAttribute('data-star'));
          if (val <= hoverVal) {
            s.classList.add('active');
          } else {
            s.classList.remove('active');
          }
        });
      });
    });

    if (starsContainer) {
      starsContainer.addEventListener('mouseleave', function() {
        stars.forEach(function(s) {
          var val = parseInt(s.getAttribute('data-star'));
          if (val <= selectedRating) {
            s.classList.add('active');
          } else {
            s.classList.remove('active');
          }
        });
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Reviews",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "title", "label": "Title", "default": "Customer Reviews" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "See what our customers are saying" },
    { "type": "text", "id": "rating", "label": "Average rating", "default": "4.9" },
    { "type": "text", "id": "review_count", "label": "Total reviews", "default": "15" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "title_color", "label": "Title color", "default": "#ffffff" },
    { "type": "color", "id": "subtitle_color", "label": "Subtitle color", "default": "#9ca3af" },
    { "type": "color", "id": "star_color", "label": "Star color", "default": "#fbbf24" },
    { "type": "color", "id": "card_bg", "label": "Card background", "default": "#111111" },
    { "type": "color", "id": "card_border", "label": "Card border", "default": "#2a2a2a" },
    { "type": "color", "id": "avatar_bg", "label": "Avatar background", "default": "#19d400" },
    { "type": "color", "id": "avatar_text_color", "label": "Avatar text color", "default": "#000000" },
    { "type": "color", "id": "write_btn_bg", "label": "Write review button bg", "default": "#19d400" },
    { "type": "color", "id": "write_btn_text_color", "label": "Write review button text", "default": "#000000" },
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "columns", "label": "Columns", "min": 1, "max": 4, "step": 1, "default": 3 },
    { "type": "range", "id": "avatar_size", "label": "Avatar size (px)", "min": 28, "max": 56, "step": 4, "default": 40 },
    { "type": "range", "id": "card_padding", "label": "Card padding (px)", "min": 12, "max": 32, "step": 4, "default": 20 },
    { "type": "range", "id": "padding_top", "label": "Top padding (px)", "min": 0, "max": 120, "step": 10, "default": 60 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding (px)", "min": 0, "max": 120, "step": 10, "default": 60 }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "text", "id": "name", "label": "Reviewer name", "default": "John D." },
        { "type": "text", "id": "date", "label": "Date", "default": "2 weeks ago" },
        { "type": "range", "id": "stars", "label": "Star rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "textarea", "id": "text", "label": "Review text", "default": "Amazing vendor list! Already made back my investment." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reviews",
      "blocks": [
        { "type": "review", "settings": { "name": "Alex M.", "date": "1 week ago", "stars": 5, "text": "Best vendor list I've ever purchased. Made my money back in the first week!" } },
        { "type": "review", "settings": { "name": "Sarah K.", "date": "2 weeks ago", "stars": 5, "text": "Incredible value. The suppliers are legit and the prices are unbeatable." } },
        { "type": "review", "settings": { "name": "Mike R.", "date": "3 weeks ago", "stars": 5, "text": "Was skeptical at first but these vendors are 100% real. Already made sales!" } }
      ]
    }
  ]
}
{% endschema %}
