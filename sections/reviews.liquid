<section class="vx-shell vx-shell--loading" data-vx-section="reviews">
  <div class="vx-editor-preview"><div class="vx-section-loader"><div class="vx-loader__spinner"></div></div></div>
</section>

<script type="application/json" data-vx-settings="reviews">
{
  "title": {{ section.settings.title | default: 'Customer Reviews' | json }},
  "subtitle": {{ section.settings.subtitle | default: 'See what our customers are saying' | json }},
  "rating": {{ section.settings.rating | default: '4.9' | json }},
  "review_count": {{ section.settings.review_count | default: '15' | json }},
  "title_color": {{ section.settings.title_color | default: '#ffffff' | json }},
  "subtitle_color": {{ section.settings.subtitle_color | default: '#9ca3af' | json }},
  "star_color": {{ section.settings.star_color | default: '#fbbf24' | json }},
  "card_bg": {{ section.settings.card_bg | default: '#111111' | json }},
  "card_border": {{ section.settings.card_border | default: '#2a2a2a' | json }},
  "avatar_bg": {{ section.settings.avatar_bg | default: '#39ff14' | json }},
  "avatar_text_color": {{ section.settings.avatar_text_color | default: '#000000' | json }},
  "write_btn_bg": {{ section.settings.write_btn_bg | default: '#39ff14' | json }},
  "write_btn_text_color": {{ section.settings.write_btn_text_color | default: '#000000' | json }},
  "columns": {{ section.settings.columns | default: 3 }},
  "avatar_size": {{ section.settings.avatar_size | default: 40 }},
  "card_padding": {{ section.settings.card_padding | default: 20 }},
  "padding_top": {{ section.settings.padding_top | default: 60 }},
  "padding_bottom": {{ section.settings.padding_bottom | default: 60 }},
  "blocks": [
    {%- for block in section.blocks -%}
      {%- if block.type == 'review' -%}
        {"type":"review","settings":{"name":{{ block.settings.name | json }},"date":{{ block.settings.date | json }},"stars":{{ block.settings.stars | default: 5 }},"text":{{ block.settings.text | json }}}}{% unless forloop.last %},{% endunless %}
      {%- endif -%}
    {%- endfor -%}
  ]
}
</script>

{% schema %}
{
  "name": "Reviews",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "title", "label": "Title", "default": "Customer Reviews" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "See what our customers are saying" },
    { "type": "text", "id": "rating", "label": "Average rating", "default": "4.9" },
    { "type": "text", "id": "review_count", "label": "Total reviews", "default": "15" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "title_color", "label": "Title color", "default": "#ffffff" },
    { "type": "color", "id": "subtitle_color", "label": "Subtitle color", "default": "#9ca3af" },
    { "type": "color", "id": "star_color", "label": "Star color", "default": "#fbbf24" },
    { "type": "color", "id": "card_bg", "label": "Card background", "default": "#111111" },
    { "type": "color", "id": "card_border", "label": "Card border", "default": "#2a2a2a" },
    { "type": "color", "id": "avatar_bg", "label": "Avatar background", "default": "#39ff14" },
    { "type": "color", "id": "avatar_text_color", "label": "Avatar text color", "default": "#000000" },
    { "type": "color", "id": "write_btn_bg", "label": "Write review button bg", "default": "#39ff14" },
    { "type": "color", "id": "write_btn_text_color", "label": "Write review button text", "default": "#000000" },
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "columns", "label": "Columns", "min": 1, "max": 4, "step": 1, "default": 3 },
    { "type": "range", "id": "avatar_size", "label": "Avatar size (px)", "min": 28, "max": 56, "step": 4, "default": 40 },
    { "type": "range", "id": "card_padding", "label": "Card padding (px)", "min": 12, "max": 32, "step": 4, "default": 20 },
    { "type": "range", "id": "padding_top", "label": "Top padding (px)", "min": 0, "max": 120, "step": 10, "default": 60 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding (px)", "min": 0, "max": 120, "step": 10, "default": 60 }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "text", "id": "name", "label": "Reviewer name", "default": "John D." },
        { "type": "text", "id": "date", "label": "Date", "default": "2 weeks ago" },
        { "type": "range", "id": "stars", "label": "Star rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "textarea", "id": "text", "label": "Review text", "default": "Amazing vendor list! Already made back my investment." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reviews",
      "blocks": [
        { "type": "review", "settings": { "name": "Alex M.", "date": "1 week ago", "stars": 5, "text": "Best vendor list I've ever purchased. Made my money back in the first week!" } },
        { "type": "review", "settings": { "name": "Sarah K.", "date": "2 weeks ago", "stars": 5, "text": "Incredible value. The suppliers are legit and the prices are unbeatable." } },
        { "type": "review", "settings": { "name": "Mike R.", "date": "3 weeks ago", "stars": 5, "text": "Was skeptical at first but these vendors are 100% real. Already made sales!" } }
      ]
    }
  ]
}
{% endschema %}
