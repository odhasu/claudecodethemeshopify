{%- liquid
  assign title = section.settings.title | default: 'Join Our Community'
  assign subtitle = section.settings.subtitle | default: 'Get exclusive tips, early access to new vendors, and connect with other resellers.'
  assign btn_text = section.settings.button_text | default: 'Join Discord'
  assign btn_link = section.settings.button_link | default: '#'
  assign accent = section.settings.accent_color | default: '#39ff14'
  assign title_color = section.settings.title_color | default: '#ffffff'
  assign subtitle_color = section.settings.subtitle_color | default: '#9ca3af'
  assign btn_bg = section.settings.button_bg | default: '#39ff14'
  assign btn_text_color = section.settings.button_text_color | default: '#000000'
  assign card_bg = section.settings.card_bg | default: '#111111'
  assign card_border = section.settings.card_border | default: '#2a2a2a'
  assign show_icon = section.settings.show_discord_icon
  assign show_glow = section.settings.show_glow
  assign glow_color = section.settings.glow_color | default: '#39ff14'
  assign glow_intensity = section.settings.glow_intensity | default: 20
  assign max_width = section.settings.max_width | default: 700
  assign btn_radius = section.settings.button_radius | default: 12
  assign btn_padding_x = section.settings.button_padding_x | default: 40
  assign btn_padding_y = section.settings.button_padding_y | default: 20
  assign btn_font_size = section.settings.button_font_size | default: 18
  assign title_size = section.settings.title_font_size | default: 32
  assign subtitle_size = section.settings.subtitle_font_size | default: 15
  assign show_members = section.settings.show_member_count
  assign member_count = section.settings.member_count | default: '500+'
  assign member_label = section.settings.member_label | default: 'members'
-%}

<style>
  .discord-section {
    padding: {{ section.settings.padding_top | default: 60 }}px 20px {{ section.settings.padding_bottom | default: 60 }}px;
    display: flex;
    justify-content: center;
  }
  .discord-card {
    max-width: {{ max_width }}px;
    width: 100%;
    background: {{ card_bg }};
    border: 1px solid {{ card_border }};
    border-radius: {{ section.settings.card_radius | default: 20 }}px;
    padding: {{ section.settings.card_padding | default: 48 }}px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  {%- if show_glow %}
  .discord-card::before {
    content: '';
    position: absolute;
    top: -50%;
    left: 50%;
    transform: translateX(-50%);
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, {{ glow_color }}{{ glow_intensity | times: 255 | divided_by: 100 | round | append: '' }} 0%, transparent 70%);
    opacity: 0.{{ glow_intensity }};
    pointer-events: none;
    z-index: 0;
  }
  {%- endif %}
  .discord-card > * { position: relative; z-index: 1; }

  .discord-icon {
    width: {{ section.settings.icon_size | default: 56 }}px;
    height: {{ section.settings.icon_size | default: 56 }}px;
    margin: 0 auto {{ section.settings.icon_margin | default: 20 }}px;
    color: {{ section.settings.icon_color | default: '#5865F2' }};
  }

  .discord-title {
    font-family: var(--font-heading);
    font-size: clamp(22px, 4vw, {{ title_size }}px);
    font-weight: 900;
    text-transform: uppercase;
    color: {{ title_color }};
    margin-bottom: 12px;
    letter-spacing: -0.02em;
  }
  .discord-subtitle {
    color: {{ subtitle_color }};
    font-size: {{ subtitle_size }}px;
    line-height: 1.6;
    margin-bottom: 28px;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .discord-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: {{ btn_padding_y }}px {{ btn_padding_x }}px;
    background: {{ btn_bg }};
    color: {{ btn_text_color }};
    font-size: {{ btn_font_size }}px;
    font-weight: {{ section.settings.button_font_weight | default: '700' }};
    border-radius: {{ btn_radius }}px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    transition: transform 0.2s, box-shadow 0.3s, background 0.2s;
    box-shadow: 0 0 {{ glow_intensity }}px rgba({{ btn_bg | color_extract: 'red' }},{{ btn_bg | color_extract: 'green' }},{{ btn_bg | color_extract: 'blue' }},0.3);
    border: none;
    cursor: pointer;
  }
  .discord-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 {{ glow_intensity | plus: 10 }}px rgba({{ btn_bg | color_extract: 'red' }},{{ btn_bg | color_extract: 'green' }},{{ btn_bg | color_extract: 'blue' }},0.5);
  }
  .discord-btn svg {
    width: {{ section.settings.btn_icon_size | default: 24 }}px;
    height: {{ section.settings.btn_icon_size | default: 24 }}px;
  }

  .discord-members {
    margin-top: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: 14px;
    color: {{ subtitle_color }};
  }
  .discord-members-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #22c55e;
    animation: discordPulse 2s ease-in-out infinite;
  }
  @keyframes discordPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  .discord-members strong {
    color: #fff;
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .discord-card { padding: 32px 20px; }
    .discord-btn {
      padding: {{ btn_padding_y | minus: 4 }}px {{ btn_padding_x | minus: 8 }}px;
      font-size: {{ btn_font_size | minus: 2 }}px;
    }
  }
</style>

<section class="discord-section">
  <div class="discord-card">
    {%- if show_icon %}
    <div class="discord-icon">
      <svg viewBox="0 0 24 24" fill="currentColor">
        <path d="M20.317 4.369a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.369a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
      </svg>
    </div>
    {%- endif %}

    <h2 class="discord-title">{{ title }}</h2>
    <p class="discord-subtitle">{{ subtitle }}</p>

    <a href="{{ btn_link }}" target="_blank" rel="noopener noreferrer" class="discord-btn">
      {%- if section.settings.show_btn_icon %}
      <svg viewBox="0 0 24 24" fill="currentColor">
        <path d="M20.317 4.369a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.369a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
      </svg>
      {%- endif %}
      {{ btn_text }}
    </a>

    {%- if show_members %}
    <div class="discord-members">
      <span class="discord-members-dot"></span>
      <strong>{{ member_count }}</strong> {{ member_label }}
    </div>
    {%- endif %}
  </div>
</section>

{% schema %}
{
  "name": "Discord Community",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "title", "label": "Title", "default": "Join Our Community" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Get exclusive tips, early access to new vendors, and connect with other resellers." },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Join Discord" },
    { "type": "url", "id": "button_link", "label": "Discord invite link" },
    { "type": "header", "content": "Discord Icon (above title)" },
    { "type": "checkbox", "id": "show_discord_icon", "label": "Show Discord icon", "default": true },
    { "type": "color", "id": "icon_color", "label": "Icon color", "default": "#5865F2" },
    { "type": "range", "id": "icon_size", "label": "Icon size (px)", "min": 32, "max": 80, "step": 4, "default": 56 },
    { "type": "range", "id": "icon_margin", "label": "Icon bottom margin (px)", "min": 8, "max": 40, "step": 4, "default": 20 },
    { "type": "header", "content": "Member Count" },
    { "type": "checkbox", "id": "show_member_count", "label": "Show member count", "default": true },
    { "type": "text", "id": "member_count", "label": "Member count", "default": "500+" },
    { "type": "text", "id": "member_label", "label": "Member label", "default": "members" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "title_color", "label": "Title color", "default": "#ffffff" },
    { "type": "color", "id": "subtitle_color", "label": "Subtitle color", "default": "#9ca3af" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#39ff14" },
    { "type": "color", "id": "card_bg", "label": "Card background", "default": "#111111" },
    { "type": "color", "id": "card_border", "label": "Card border", "default": "#2a2a2a" },
    { "type": "header", "content": "Button Style" },
    { "type": "color", "id": "button_bg", "label": "Button background", "default": "#39ff14" },
    { "type": "color", "id": "button_text_color", "label": "Button text color", "default": "#000000" },
    { "type": "checkbox", "id": "show_btn_icon", "label": "Show Discord icon in button", "default": true },
    { "type": "range", "id": "btn_icon_size", "label": "Button icon size (px)", "min": 16, "max": 36, "step": 2, "default": 24 },
    { "type": "range", "id": "button_radius", "label": "Button border radius (px)", "min": 0, "max": 999, "step": 1, "default": 12 },
    { "type": "range", "id": "button_padding_x", "label": "Button horizontal padding (px)", "min": 16, "max": 60, "step": 4, "default": 40 },
    { "type": "range", "id": "button_padding_y", "label": "Button vertical padding (px)", "min": 10, "max": 30, "step": 2, "default": 20 },
    { "type": "range", "id": "button_font_size", "label": "Button font size (px)", "min": 13, "max": 24, "step": 1, "default": 18 },
    { "type": "select", "id": "button_font_weight", "label": "Button font weight", "default": "700", "options": [
      { "value": "400", "label": "Normal" },
      { "value": "600", "label": "Semi-bold" },
      { "value": "700", "label": "Bold" },
      { "value": "800", "label": "Extra Bold" },
      { "value": "900", "label": "Black" }
    ]},
    { "type": "header", "content": "Title Style" },
    { "type": "range", "id": "title_font_size", "label": "Title font size (px)", "min": 20, "max": 48, "step": 2, "default": 32 },
    { "type": "range", "id": "subtitle_font_size", "label": "Subtitle font size (px)", "min": 12, "max": 20, "step": 1, "default": 15 },
    { "type": "header", "content": "Card Layout" },
    { "type": "range", "id": "max_width", "label": "Max width (px)", "min": 400, "max": 1000, "step": 50, "default": 700 },
    { "type": "range", "id": "card_radius", "label": "Card border radius (px)", "min": 0, "max": 32, "step": 2, "default": 20 },
    { "type": "range", "id": "card_padding", "label": "Card padding (px)", "min": 20, "max": 80, "step": 4, "default": 48 },
    { "type": "header", "content": "Glow Effect" },
    { "type": "checkbox", "id": "show_glow", "label": "Show glow behind card", "default": true },
    { "type": "color", "id": "glow_color", "label": "Glow color", "default": "#39ff14" },
    { "type": "range", "id": "glow_intensity", "label": "Glow intensity (%)", "min": 5, "max": 50, "step": 5, "default": 20 },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Top padding (px)", "min": 0, "max": 120, "step": 10, "default": 60 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding (px)", "min": 0, "max": 120, "step": 10, "default": 60 }
  ],
  "presets": [
    { "name": "Discord Community" }
  ]
}
{% endschema %}
