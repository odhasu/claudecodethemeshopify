{%- liquid
  assign pt = section.settings.padding_top | default: 120
  assign pb = section.settings.padding_bottom | default: 80
-%}

<section
  class="hero-section{% if settings.anim_scroll_reveal %} reveal{% endif %}"
  data-section-id="{{ section.id }}"
  style="padding-top: {{ pt }}px; padding-bottom: {{ pb }}px;{% if section.settings.background_image != blank %} background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');{% endif %}"
>
  <div class="hero-inner">
    <h1 class="hero-title">
      {%- if section.settings.title_before != blank -%}
        <span class="hero-title-before">{{ section.settings.title_before }}</span>
      {%- endif -%}
      {%- if section.settings.title_accent != blank -%}
        <span class="hero-title-accent">{{ section.settings.title_accent }}</span>
      {%- endif -%}
      {%- if section.settings.title_after != blank -%}
        <span class="hero-title-after">{{ section.settings.title_after }}</span>
      {%- endif -%}
    </h1>

    {%- if section.settings.trust_count != blank -%}
      <div class="hero-trust{% if settings.anim_scroll_reveal %} reveal{% endif %}">
        {%- if section.settings.show_avatars -%}
          <div class="hero-avatars">
            <span class="hero-avatar" style="background: #e74c3c;">J</span>
            <span class="hero-avatar" style="background: #3498db;">M</span>
            <span class="hero-avatar" style="background: #f39c12;">K</span>
          </div>
        {%- endif -%}
        <span class="hero-trust-text">
          {{ section.settings.trust_prefix | default: 'Join' }}
          <strong class="hero-trust-count{% if section.settings.show_glow %} glow{% endif %}">{{ section.settings.trust_count }}+</strong>
          {{ section.settings.trust_suffix | default: 'people' }}
        </span>
      </div>
    {%- endif -%}

    {%- if section.settings.cta_text != blank -%}
      <div class="hero-cta{% if settings.anim_scroll_reveal %} reveal{% endif %}">
        <a href="{{ section.settings.cta_link }}" class="hero-button">
          {{ section.settings.cta_text }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: 60vh;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    overflow: hidden;
  }

  .hero-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10,10,10,0.6) 0%, rgba(10,10,10,0.9) 100%);
    z-index: 0;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: var(--page-max-width);
    padding: 0 var(--page-side-padding);
    width: 100%;
  }

  .hero-title {
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    font-size: var(--font-h1-size);
    line-height: 1.05;
    text-transform: var(--font-heading-transform);
    margin-bottom: 24px;
  }

  .hero-title-before,
  .hero-title-after {
    color: var(--color-text-primary);
    display: block;
  }

  .hero-title-accent {
    color: var(--color-accent);
    display: block;
  }

  .hero-trust {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 32px;
    font-size: 16px;
    color: var(--color-text-muted);
  }

  .hero-avatars {
    display: flex;
    align-items: center;
  }

  .hero-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 700;
    color: #fff;
    border: 2px solid var(--color-page-bg);
    margin-left: -8px;
  }

  .hero-avatar:first-child {
    margin-left: 0;
  }

  .hero-trust-count {
    color: var(--color-accent);
    font-weight: 700;
  }

  .hero-trust-count.glow {
    text-shadow: 0 0 12px var(--color-accent), 0 0 24px var(--color-accent);
  }

  .hero-cta {
    margin-top: 8px;
  }

  .hero-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: var(--btn-height);
    padding: 0 32px;
    background: var(--btn-primary-bg);
    color: var(--btn-primary-text);
    font-family: var(--font-heading-family);
    font-weight: 700;
    font-size: var(--btn-font-size);
    letter-spacing: var(--btn-letter-spacing);
    text-transform: {% if settings.btn_uppercase %}uppercase{% else %}none{% endif %};
    border-radius: var(--btn-radius);
    border: none;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .hero-button:hover {
    background: var(--btn-primary-hover);
    {% if settings.btn_hover_lift %}transform: translateY(-2px);{% endif %}
    box-shadow: 0 4px 20px rgba(57, 255, 20, 0.3);
  }

  @media (max-width: 749px) {
    .hero-title {
      font-size: var(--font-h1-mobile-size);
    }

    .hero-section {
      min-height: 50vh;
    }

    .hero-trust {
      flex-direction: column;
      gap: 8px;
    }
  }
</style>

{% schema %}
{
  "name": "Hero Section",
  "tag": "div",
  "class": "hero-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "title_before",
      "label": "Title line 1 (white)",
      "default": "START YOUR"
    },
    {
      "type": "text",
      "id": "title_accent",
      "label": "Title accent line (green)",
      "default": "RESELLING"
    },
    {
      "type": "text",
      "id": "title_after",
      "label": "Title line 3 (white)",
      "default": "JOURNEY TODAY"
    },
    {
      "type": "text",
      "id": "trust_prefix",
      "label": "Trust prefix text",
      "default": "Join"
    },
    {
      "type": "text",
      "id": "trust_count",
      "label": "Trust count number",
      "default": "2,500"
    },
    {
      "type": "text",
      "id": "trust_suffix",
      "label": "Trust suffix text",
      "default": "people"
    },
    {
      "type": "checkbox",
      "id": "show_avatars",
      "label": "Show avatar stack",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_glow",
      "label": "Glow effect on count",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 40,
      "max": 200,
      "step": 10,
      "default": 120,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 40,
      "max": 200,
      "step": 10,
      "default": 80,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Hero Section"
    }
  ]
}
{% endschema %}
