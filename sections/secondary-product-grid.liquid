{%- liquid
  assign collection = section.settings.collection | default: collections.all
  assign columns_desktop = section.settings.columns_desktop | default: 4
  assign columns_mobile = section.settings.columns_mobile | default: 2
  assign max_products = section.settings.max_products | default: 8
  assign show_glow = section.settings.show_glow
  assign glow_color = section.settings.glow_color | default: '#39ff14'
  assign glow_intensity = section.settings.glow_intensity | default: 25
  assign card_bg = section.settings.card_bg | default: '#111111'
  assign card_border = section.settings.card_border | default: '#2a2a2a'
  assign card_hover_border = section.settings.card_hover_border | default: '#39ff14'
  assign image_bg = section.settings.image_bg | default: '#0a0a0a'
  assign sale_badge_bg = section.settings.sale_badge_bg | default: 'rgba(0,0,0,0.5)'
  assign sale_badge_text = section.settings.sale_badge_text_color | default: '#ffffff'
  assign price_color = section.settings.price_color | default: '#39ff14'
  assign compare_color = section.settings.compare_price_color | default: '#6b7280'
  assign btn_bg = section.settings.buy_btn_bg | default: '#39ff14'
  assign btn_text = section.settings.buy_btn_text_color | default: '#1a1a1a'
  assign btn_label = section.settings.buy_btn_label | default: 'BUY NOW'
  assign btn_action = section.settings.buy_btn_action | default: 'product'
  assign cart_btn_bg = section.settings.cart_btn_bg | default: '#1a1a1a'
  assign cart_btn_border = section.settings.cart_btn_border | default: '#2a2a2a'
  assign cart_btn_hover_border = section.settings.cart_btn_hover_border | default: '#ffffff'
  assign cart_btn_hover_bg = section.settings.cart_btn_hover_bg | default: '#1a1a1a'
  assign cart_btn_hover_color = section.settings.cart_btn_hover_color | default: '#ffffff'
  assign cart_btn_incart_bg = section.settings.cart_btn_incart_bg | default: '#22c55e'
  assign cart_btn_incart_border = section.settings.cart_btn_incart_border | default: '#22c55e'
  assign overlay_title_green = section.settings.overlay_title_green_color | default: '#39ff14'
  assign overlay_title_white = section.settings.overlay_title_white_color | default: '#ffffff'
  assign title_color = section.settings.title_color | default: '#ffffff'
  assign show_details_btn = section.settings.show_details_btn
  assign details_btn_bg = section.settings.details_btn_bg | default: 'rgba(255,255,255,0.06)'
  assign details_btn_text = section.settings.details_btn_text_color | default: '#ffffff'
  assign glassmorphic = section.settings.glassmorphic_cards
  assign show_top_fade = section.settings.show_top_fade
  assign btn_height = section.settings.buy_btn_height | default: 52
  assign btn_radius = section.settings.buy_btn_border_radius | default: 10
  assign btn_font_size = section.settings.buy_btn_font_size | default: 14
  assign btn_font_weight = section.settings.buy_btn_font_weight | default: '800'
  assign btn_style = section.settings.buy_btn_style | default: 'solid_glow'
  assign icon_btn_type = section.settings.icon_btn_type | default: 'info'
  assign sid = section.id
-%}

<style>
  .spg-section-{{ sid }} {
    padding: {{ section.settings.padding_top | default: 40 }}px 20px {{ section.settings.padding_bottom | default: 60 }}px;
    position: relative;
    overflow: hidden;
  }

  {%- if show_glow -%}
  {%- assign glow_r = glow_color | color_extract: 'red' -%}
  {%- assign glow_g = glow_color | color_extract: 'green' -%}
  {%- assign glow_b = glow_color | color_extract: 'blue' -%}
  {%- assign glow_a = glow_intensity | times: 1.0 | divided_by: 100.0 -%}
  .spg-section-{{ sid }}::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 1000px 700px at 90% 50%, rgba({{ glow_r }},{{ glow_g }},{{ glow_b }},{{ glow_a }}) 0%, transparent 65%),
      radial-gradient(ellipse 800px 600px at 10% 50%, rgba({{ glow_r }},{{ glow_g }},{{ glow_b }},{{ glow_a }}) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }
  @media (max-width: 768px) {
    .spg-section-{{ sid }}::before {
      background:
        radial-gradient(ellipse 500px 350px at 90% 50%, rgba({{ glow_r }},{{ glow_g }},{{ glow_b }},0.12) 0%, transparent 65%) !important;
    }
  }
  {%- endif -%}

  {%- if show_top_fade -%}
  .spg-section-{{ sid }}::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 350px;
    background: linear-gradient(to bottom, var(--color-bg, #000) 10%, transparent 100%);
    pointer-events: none;
    z-index: 1;
  }
  {%- endif -%}

  .spg-inner-{{ sid }} { position: relative; z-index: 2; max-width: var(--max-width); margin: 0 auto; }
  .spg-grid-{{ sid }} {
    display: grid;
    grid-template-columns: repeat({{ columns_desktop }}, 1fr);
    gap: var(--grid-gap);
  }
  @media (max-width: 768px) {
    .spg-grid-{{ sid }} { grid-template-columns: repeat({{ columns_mobile }}, 1fr); }
  }
  @media (max-width: 480px) {
    .spg-card-{{ sid }} .btn-buy, .spg-card-{{ sid }} .btn-cart-icon { height: 44px !important; }
    .spg-card-{{ sid }} .btn-cart-icon { width: 44px !important; }
    .spg-card-{{ sid }} .product-card-info { padding: 10px; }
    .spg-card-{{ sid }} .product-card-title { font-size: 11px; }
  }

  .spg-card-{{ sid }} {
    background: {{ card_bg }};
    border: 1px solid {{ card_border }};
    border-radius: var(--radius-card);
    overflow: hidden;
    transition: transform 0.3s, border-color 0.3s, box-shadow 0.3s;
    {%- if glassmorphic %}
    box-shadow:
      inset 0 0 0 1px rgba(255,255,255,0.03),
      inset 1.8px 3px 0px -2px rgba(255,255,255,0.15),
      inset -2px -2px 0px -2px rgba(255,255,255,0.12),
      0 2px 8px rgba(0,0,0,0.4);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    {%- endif %}
  }
  .spg-card-{{ sid }}:hover {
    transform: translateY(-3px);
    border-color: {{ card_hover_border }};
    box-shadow:
      {%- if glassmorphic %}
      inset 0 0 0 1px rgba(255,255,255,0.06),
      inset 1.8px 3px 0px -2px rgba(255,255,255,0.2),
      inset -2px -2px 0px -2px rgba(255,255,255,0.15),
      {%- endif %}
      0 8px 32px {{ card_hover_border }}33,
      0 2px 12px rgba(0,0,0,0.3);
  }

  .spg-card-{{ sid }} .product-card-inner { border-radius: calc(var(--radius-card) - 1px); overflow: hidden; }
  .spg-card-{{ sid }} .product-card-image {
    position: relative; aspect-ratio: 1; background: {{ image_bg }};
    overflow: hidden; display: block; cursor: pointer;
  }
  .spg-card-{{ sid }} .product-card-image img {
    width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s;
  }
  .spg-card-{{ sid }}:hover .product-card-image img { transform: scale(1.03); }
  .spg-card-{{ sid }} .product-card-overlay {
    position: absolute; top: 12px; left: 12px;
    font-family: var(--font-heading);
    font-size: {{ section.settings.overlay_font_size | default: 14 }}px;
    line-height: 1.3; text-transform: uppercase; z-index: 2;
  }
  .spg-card-{{ sid }} .overlay-green { color: {{ overlay_title_green }}; font-style: italic; font-weight: 600; }
  .spg-card-{{ sid }} .overlay-white { color: {{ overlay_title_white }}; font-weight: 800; }
  .spg-card-{{ sid }} .product-card-badge {
    position: absolute;
    {{ section.settings.sale_badge_position_y | default: 'top' }}: 10px;
    {{ section.settings.sale_badge_position_x | default: 'right' }}: 10px;
    background: {{ sale_badge_bg }}; color: {{ sale_badge_text }};
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    padding: 4px 12px; border-radius: 999px;
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.15); z-index: 2;
  }
  .spg-card-{{ sid }} .product-card-info { padding: 14px; }
  .spg-card-{{ sid }} .product-card-title {
    font-size: 13px; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.02em; color: {{ title_color }};
    margin-bottom: 8px; line-height: 1.3;
  }
  .spg-card-{{ sid }} .product-card-title a { color: inherit; }
  .spg-card-{{ sid }} .product-card-prices {
    display: flex; align-items: center; gap: 8px; margin-bottom: 12px;
  }
  .spg-card-{{ sid }} .price-sale { color: {{ price_color }}; font-weight: 800; font-size: 16px; }
  .spg-card-{{ sid }} .price-compare { color: {{ compare_color }}; text-decoration: line-through; font-size: 14px; }
  .spg-card-{{ sid }} .product-card-actions { display: flex; gap: 8px; }
  .spg-card-{{ sid }} .btn-cart-icon {
    width: {{ btn_height }}px; height: {{ btn_height }}px;
    border-radius: {{ btn_radius }}px;
    background: {{ cart_btn_bg }}; border: 1px solid {{ cart_btn_border }};
    display: flex; align-items: center; justify-content: center;
    color: #fff; transition: background 0.2s, border-color 0.2s, color 0.2s;
    flex-shrink: 0; cursor: pointer;
  }
  .spg-card-{{ sid }} .btn-cart-icon:hover {
    background: {{ cart_btn_hover_bg }}; border-color: {{ cart_btn_hover_border }}; color: {{ cart_btn_hover_color }};
  }
  .spg-card-{{ sid }} .btn-cart-icon.in-cart {
    background: {{ cart_btn_incart_bg }}; border-color: {{ cart_btn_incart_border }}; color: #fff;
  }
  .spg-card-{{ sid }} .btn-cart-icon svg { width: 20px; height: 20px; }
  .spg-card-{{ sid }} .btn-buy {
    flex: 1; height: {{ btn_height }}px;
    border-radius: {{ btn_radius }}px;
    background: {{ btn_bg }}; color: {{ btn_text }};
    font-weight: {{ btn_font_weight }}; font-size: {{ btn_font_size }}px;
    font-family: var(--font-heading);
    text-transform: uppercase; letter-spacing: 0.04em;
    display: flex; align-items: center; justify-content: center; border: none; cursor: pointer;
    transition: box-shadow 0.25s, transform 0.2s, opacity 0.2s, background 0.2s;
    {%- if btn_style == 'glass' %}
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.28),
      inset 0 -1px 0 rgba(0,0,0,0.18),
      0 4px 20px rgba({{ btn_bg | color_extract: 'red' }}, {{ btn_bg | color_extract: 'green' }}, {{ btn_bg | color_extract: 'blue' }}, 0.55),
      0 1px 4px rgba(0,0,0,0.25);
    {%- elsif btn_style == 'solid_glow' %}
    background:
      linear-gradient(180deg, rgba(255,255,255,0.22) 0%, rgba(255,255,255,0) 52%, rgba(0,0,0,0.10) 100%),
      {{ btn_bg }};
    box-shadow:
      0 6px 28px rgba({{ btn_bg | color_extract: 'red' }}, {{ btn_bg | color_extract: 'green' }}, {{ btn_bg | color_extract: 'blue' }}, 0.65),
      0 2px 6px rgba(0,0,0,0.25);
    {%- endif %}
  }
  .spg-card-{{ sid }} .btn-buy:hover {
    {%- if btn_style == 'solid_glow' %}
    box-shadow:
      0 4px 12px rgba({{ btn_bg | color_extract: 'red' }}, {{ btn_bg | color_extract: 'green' }}, {{ btn_bg | color_extract: 'blue' }}, 0.45),
      0 8px 24px rgba({{ btn_bg | color_extract: 'red' }}, {{ btn_bg | color_extract: 'green' }}, {{ btn_bg | color_extract: 'blue' }}, 0.25),
      0 2px 6px rgba(0,0,0,0.35);
    {%- elsif btn_style == 'glass' %}
    transform: translateY(-1px);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.35),
      inset 0 -1px 0 rgba(0,0,0,0.18),
      0 8px 32px rgba({{ btn_bg | color_extract: 'red' }}, {{ btn_bg | color_extract: 'green' }}, {{ btn_bg | color_extract: 'blue' }}, 0.75),
      0 0 48px rgba({{ btn_bg | color_extract: 'red' }}, {{ btn_bg | color_extract: 'green' }}, {{ btn_bg | color_extract: 'blue' }}, 0.28);
    {%- else %}
    transform: translateY(-1px);
    opacity: 0.88;
    {%- endif %}
  }

  {%- if show_details_btn %}
  .spg-card-{{ sid }} .btn-details {
    width: 100%; height: 38px; border-radius: 28px;
    background: {{ details_btn_bg }}; color: {{ details_btn_text }};
    font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: 0.06em;
    display: flex; align-items: center; justify-content: center; gap: 6px;
    border: 1px solid rgba(255,255,255,0.08); margin-top: 8px;
    backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
    transition: background 0.2s, border-color 0.2s; cursor: pointer;
  }
  .spg-card-{{ sid }} .btn-details:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.15); }
  .spg-card-{{ sid }} .btn-details svg { width: 14px; height: 14px; }
  {%- endif %}

  .spg-section-{{ sid }} .section-title {
    text-align: center; font-family: var(--font-heading);
    font-size: clamp(24px, 4vw, 36px); text-transform: uppercase;
    letter-spacing: -0.5px; margin-bottom: 32px; color: #fff;
  }
</style>

<section class="spg-section-{{ sid }}">
  <div class="spg-inner-{{ sid }}">
    {%- if section.settings.title != blank -%}
      <h2 class="section-title">{{ section.settings.title }}</h2>
    {%- endif -%}

    <div class="spg-grid-{{ sid }}">
      {%- for product in collection.products limit: max_products -%}
        <div class="spg-card-{{ sid }}" data-product-id="{{ product.id }}">
          <div class="product-card-inner">
            <a href="{{ product.url }}" class="product-card-image" aria-label="{{ product.title }}">
              {%- if product.featured_image -%}
                <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title | escape }}" loading="lazy" width="600" height="600">
              {%- else -%}
                <div style="width:100%;height:100%;background:{{ image_bg }};"></div>
              {%- endif -%}

              {%- if section.settings.show_overlay_title and product.metafields.custom.overlay_green != blank -%}
                <div class="product-card-overlay">
                  <span class="overlay-green">{{ product.metafields.custom.overlay_green }}</span>
                  {%- if product.metafields.custom.overlay_white != blank -%}
                    <br><span class="overlay-white">{{ product.metafields.custom.overlay_white }}</span>
                  {%- endif -%}
                </div>
              {%- endif -%}

              {%- liquid
                assign has_compare = false
                assign compare_price = 0
                if product.first_available_variant.compare_at_price > product.price
                  assign has_compare = true
                  assign compare_price = product.first_available_variant.compare_at_price
                elsif product.compare_at_price > product.price
                  assign has_compare = true
                  assign compare_price = product.compare_at_price
                elsif product.compare_at_price_max > product.price
                  assign has_compare = true
                  assign compare_price = product.compare_at_price_max
                elsif product.compare_at_price_min > product.price
                  assign has_compare = true
                  assign compare_price = product.compare_at_price_min
                endif
              -%}
              {%- if section.settings.show_sale_badge -%}
                {%- if has_compare or section.settings.always_show_sale_badge -%}
                  <span class="product-card-badge">{{ section.settings.sale_badge_label | default: 'SALE' }}</span>
                {%- endif -%}
              {%- endif -%}
            </a>

            <div class="product-card-info">
              <h3 class="product-card-title"><a href="{{ product.url }}">{{ product.title }}</a></h3>
              <div class="product-card-prices">
                {%- if has_compare -%}
                  <span class="price-compare">{{ compare_price | money }}</span>
                  <span class="price-sale">{{ product.price | money }}</span>
                {%- else -%}
                  <span class="price-sale">{{ product.price | money }}</span>
                {%- endif -%}
              </div>
              <div class="product-card-actions">
                {%- if icon_btn_type == 'info' -%}
                  <button type="button" class="btn-cart-icon" aria-label="Product info"
                    onclick="window['openProductDetail_' + '{{ sid }}']({{ product.title | json | escape }}, {{ product.description | strip_html | truncate: 500 | json | escape }}, '{{ product.price | money | strip_html }}', '{{ product.compare_at_price_max | money | strip_html }}', {{ product.compare_at_price_max | default: 0 }}, {{ product.price }}, {{ product.url | json | escape }}, {{ product.first_available_variant.id }})">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"/>
                      <line x1="12" y1="16" x2="12" y2="12"/>
                      <line x1="12" y1="8" x2="12.01" y2="8" stroke-width="2.5"/>
                    </svg>
                  </button>
                {%- else -%}
                  <button class="btn-cart-icon" data-variant-id="{{ product.first_available_variant.id }}" aria-label="Add to cart" onclick="addToCartOnly(this, {{ product.first_available_variant.id }})">
                    <svg class="icon-cart" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                      <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/>
                    </svg>
                    <svg class="icon-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                  </button>
                {%- endif -%}
                {%- if btn_action == 'checkout' -%}
                  <button class="btn-buy" onclick="buyNowCheckout({{ product.first_available_variant.id }})">{{ btn_label }}</button>
                {%- elsif btn_action == 'add_to_cart' -%}
                  <button class="btn-buy" onclick="addToCartAndNotify({{ product.first_available_variant.id }})">{{ btn_label }}</button>
                {%- else -%}
                  <a href="{{ product.url }}" class="btn-buy">{{ btn_label }}</a>
                {%- endif -%}
              </div>

              {%- if show_details_btn -%}
                <button type="button" class="btn-details"
                  onclick="openProductDetail({{ product.title | json | escape }}, {{ product.description | strip_html | truncate: 500 | json | escape }}, '{{ product.price | money | strip_html }}', '{{ product.compare_at_price_max | money | strip_html }}', {{ product.compare_at_price_max | default: 0 }}, {{ product.price }}, {{ product.url | json | escape }}, {{ product.first_available_variant.id }})">
                  DETAILS
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                  </svg>
                </button>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{%- if show_details_btn or icon_btn_type == 'info' -%}
<div class="product-detail-modal" id="product-detail-modal-{{ sid }}">
  <div class="product-detail-modal__backdrop" onclick="closeProductDetail('{{ sid }}')"></div>
  <div class="product-detail-modal__content">
    <button class="product-detail-modal__close" onclick="closeProductDetail('{{ sid }}')">&times;</button>
    <h3 class="product-detail-modal__title" id="pdm-title-{{ sid }}"></h3>
    <div class="product-detail-modal__body" id="pdm-body-{{ sid }}"></div>
  </div>
</div>

<script>
  (function() {
    var sid = '{{ sid }}';
    window['openProductDetail_' + sid] = function(title, desc) {
      var modal = document.getElementById('product-detail-modal-' + sid);
      document.getElementById('pdm-title-' + sid).textContent = title;
      document.getElementById('pdm-body-' + sid).innerHTML = desc ? '<p>' + desc + '</p>' : '<p>No description available.</p>';
      modal.classList.add('open');
      document.body.style.overflow = 'hidden';
    };
    window['closeProductDetail'] = window['closeProductDetail'] || function(id) {
      var m = document.getElementById('product-detail-modal-' + id);
      if (m) m.classList.remove('open');
      document.body.style.overflow = '';
    };
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Product Grid (Secondary)",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Collection" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "text", "id": "title", "label": "Section title", "default": "More Products You'll Love" },
    { "type": "range", "id": "max_products", "label": "Max products", "min": 2, "max": 16, "step": 1, "default": 4 },
    { "type": "header", "content": "Grid Layout" },
    { "type": "range", "id": "columns_desktop", "label": "Columns desktop", "min": 1, "max": 8, "step": 1, "default": 4 },
    { "type": "range", "id": "columns_mobile", "label": "Columns mobile", "min": 1, "max": 4, "step": 1, "default": 2 },
    { "type": "header", "content": "Card Style" },
    { "type": "checkbox", "id": "glassmorphic_cards", "label": "Glassmorphic cards", "default": true },
    { "type": "color", "id": "card_bg", "label": "Card background", "default": "#111111" },
    { "type": "color", "id": "card_border", "label": "Card border", "default": "#2a2a2a" },
    { "type": "color", "id": "card_hover_border", "label": "Card hover border", "default": "#39ff14" },
    { "type": "color", "id": "image_bg", "label": "Image background", "default": "#0a0a0a" },
    { "type": "color", "id": "title_color", "label": "Title color", "default": "#ffffff" },
    { "type": "header", "content": "Overlay Title on Image" },
    { "type": "checkbox", "id": "show_overlay_title", "label": "Show overlay title on image", "default": false },
    { "type": "color", "id": "overlay_title_green_color", "label": "Overlay green color", "default": "#39ff14" },
    { "type": "color", "id": "overlay_title_white_color", "label": "Overlay white color", "default": "#ffffff" },
    { "type": "range", "id": "overlay_font_size", "label": "Overlay font size (px)", "min": 10, "max": 22, "step": 1, "default": 14 },
    { "type": "header", "content": "Sale Badge" },
    { "type": "checkbox", "id": "show_sale_badge", "label": "Show sale badge", "default": false },
    { "type": "checkbox", "id": "always_show_sale_badge", "label": "Always show badge", "default": false },
    { "type": "text", "id": "sale_badge_label", "label": "Badge text", "default": "SALE" },
    { "type": "color", "id": "sale_badge_bg", "label": "Badge background", "default": "#000000" },
    { "type": "color", "id": "sale_badge_text_color", "label": "Badge text color", "default": "#ffffff" },
    { "type": "select", "id": "sale_badge_position_y", "label": "Badge vertical position", "default": "top", "options": [
      { "value": "top", "label": "Top" }, { "value": "bottom", "label": "Bottom" }
    ]},
    { "type": "select", "id": "sale_badge_position_x", "label": "Badge horizontal position", "default": "right", "options": [
