{%- liquid
  assign accent = section.settings.accent_color | default: '#39ff14'
  assign card_bg = section.settings.card_bg | default: '#111111'
  assign card_border = section.settings.card_border | default: '#2a2a2a'
-%}

<style>
  .cart-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 40px 20px 80px;
  }
  .cart-title {
    font-family: var(--font-heading);
    font-size: clamp(24px, 4vw, 36px);
    text-transform: uppercase;
    text-align: center;
    margin-bottom: 32px;
  }
  .cart-empty {
    text-align: center;
    padding: 60px 20px;
  }
  .cart-empty p {
    color: var(--color-text-muted);
    font-size: 16px;
    margin-bottom: 24px;
  }
  .cart-empty-btn {
    display: inline-block;
    padding: 14px 36px;
    border-radius: 28px;
    background: {{ accent }};
    color: #000;
    font-weight: 800;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: box-shadow 0.3s, transform 0.2s;
  }
  .cart-empty-btn:hover {
    box-shadow: 0 4px 20px rgba(57,255,20,0.4);
    transform: translateY(-1px);
  }

  /* Cart items */
  .cart-items { display: flex; flex-direction: column; gap: 16px; }
  .cart-item {
    display: flex;
    gap: 16px;
    padding: 16px;
    background: {{ card_bg }};
    border: 1px solid {{ card_border }};
    border-radius: 16px;
    align-items: center;
  }
  .cart-item-img {
    width: 90px; height: 90px;
    border-radius: 12px;
    overflow: hidden;
    flex-shrink: 0;
    background: #0a0a0a;
  }
  .cart-item-img img { width: 100%; height: 100%; object-fit: cover; }
  .cart-item-info { flex: 1; min-width: 0; }
  .cart-item-title {
    font-weight: 700;
    font-size: 15px;
    margin-bottom: 4px;
    line-height: 1.3;
  }
  .cart-item-title a { color: #fff; }
  .cart-item-title a:hover { color: {{ accent }}; }
  .cart-item-price {
    color: {{ accent }};
    font-weight: 800;
    font-size: 16px;
    margin-bottom: 8px;
  }
  .cart-item-compare {
    color: var(--color-text-muted);
    text-decoration: line-through;
    font-size: 13px;
    margin-left: 8px;
  }

  /* Qty controls */
  .cart-item-qty {
    display: flex;
    align-items: center;
    border: 1px solid {{ card_border }};
    border-radius: 8px;
    overflow: hidden;
    width: fit-content;
  }
  .cart-qty-btn {
    width: 32px; height: 32px;
    background: {{ card_bg }};
    border: none;
    color: #fff;
    font-size: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s;
  }
  .cart-qty-btn:hover { background: #1a1a1a; }
  .cart-qty-val {
    width: 36px; height: 32px;
    background: #0a0a0a;
    border: none;
    border-left: 1px solid {{ card_border }};
    border-right: 1px solid {{ card_border }};
    color: #fff;
    text-align: center;
    font-size: 14px;
    font-weight: 600;
    font-family: inherit;
    -moz-appearance: textfield;
  }
  .cart-qty-val::-webkit-outer-spin-button,
  .cart-qty-val::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }

  /* Remove */
  .cart-item-remove {
    background: none;
    border: none;
    color: var(--color-text-muted);
    cursor: pointer;
    padding: 4px;
    transition: color 0.2s;
    flex-shrink: 0;
  }
  .cart-item-remove:hover { color: #ef4444; }
  .cart-item-remove svg { width: 20px; height: 20px; }

  /* Footer */
  .cart-footer {
    margin-top: 24px;
    padding: 20px;
    background: {{ card_bg }};
    border: 1px solid {{ card_border }};
    border-radius: 16px;
  }
  .cart-subtotal {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
    font-size: 16px;
  }
  .cart-subtotal-price {
    color: {{ accent }};
    font-weight: 900;
    font-size: 22px;
  }
  .cart-note {
    color: var(--color-text-muted);
    font-size: 12px;
    margin-bottom: 16px;
  }
  .cart-checkout-btn {
    width: 100%;
    padding: 16px;
    border-radius: 28px;
    background: {{ accent }};
    color: #000;
    font-weight: 900;
    font-size: 15px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: none;
    cursor: pointer;
    transition: box-shadow 0.3s, transform 0.2s;
    box-shadow: 0 2px 12px rgba(57,255,20,0.35);
  }
  .cart-checkout-btn:hover {
    box-shadow: 0 4px 24px rgba(57,255,20,0.55);
    transform: translateY(-1px);
  }
  .cart-continue {
    display: block;
    text-align: center;
    margin-top: 12px;
    font-size: 13px;
    color: var(--color-text-muted);
  }
  .cart-continue:hover { color: {{ accent }}; }

  /* Loading overlay */
  .cart-loading {
    position: relative;
    pointer-events: none;
    opacity: 0.5;
    transition: opacity 0.2s;
  }

  @media (max-width: 600px) {
    .cart-item { flex-wrap: wrap; }
    .cart-item-img { width: 72px; height: 72px; }
  }
</style>

<section class="cart-page">
  <h1 class="cart-title">{{ section.settings.title | default: 'Your Cart' }}</h1>

  {%- if cart.item_count == 0 -%}
    <div class="cart-empty">
      <p>{{ section.settings.empty_text | default: "Your cart is empty" }}</p>
      <a href="/collections/all" class="cart-empty-btn">{{ section.settings.continue_text | default: 'Continue Shopping' }}</a>
    </div>
  {%- else -%}
    <div class="cart-items" id="cart-items">
      {%- for item in cart.items -%}
        <div class="cart-item" data-line="{{ forloop.index }}" data-key="{{ item.key }}">
          <div class="cart-item-img">
            {%- if item.image -%}
              <a href="{{ item.url }}"><img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}"></a>
            {%- endif -%}
          </div>
          <div class="cart-item-info">
            <div class="cart-item-title"><a href="{{ item.url }}">{{ item.product.title }}</a></div>
            <div class="cart-item-price">
              {{ item.final_line_price | money }}
              {%- if item.original_line_price > item.final_line_price -%}
                <span class="cart-item-compare">{{ item.original_line_price | money }}</span>
              {%- endif -%}
            </div>
            <div class="cart-item-qty">
              <button class="cart-qty-btn" type="button" onclick="updateCartQty('{{ item.key }}', {{ item.quantity | minus: 1 }})">−</button>
              <input class="cart-qty-val" type="number" value="{{ item.quantity }}" min="0" onchange="updateCartQty('{{ item.key }}', parseInt(this.value))">
              <button class="cart-qty-btn" type="button" onclick="updateCartQty('{{ item.key }}', {{ item.quantity | plus: 1 }})">+</button>
            </div>
          </div>
          <button class="cart-item-remove" type="button" onclick="updateCartQty('{{ item.key }}', 0)" aria-label="Remove {{ item.product.title | escape }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="3 6 5 6 21 6"/><path d="M19 6l-2 14H7L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2"/>
            </svg>
          </button>
        </div>
      {%- endfor -%}
    </div>

    <div class="cart-footer">
      <div class="cart-subtotal">
        <span>Subtotal</span>
        <span class="cart-subtotal-price" id="cart-subtotal">{{ cart.total_price | money }}</span>
      </div>
      <p class="cart-note">{{ section.settings.tax_note | default: 'Taxes and shipping calculated at checkout.' }}</p>
      <form action="/checkout" method="post">
        <button type="submit" class="cart-checkout-btn">{{ section.settings.checkout_text | default: 'Checkout' }}</button>
      </form>
      <a href="/collections/all" class="cart-continue">{{ section.settings.continue_text | default: 'Continue Shopping' }} →</a>
    </div>
  {%- endif -%}
</section>

<script>
  function updateCartQty(key, qty) {
    var items = document.getElementById('cart-items');
    if (items) items.classList.add('cart-loading');

    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: key, quantity: Math.max(0, qty) })
    })
    .then(function(r) { return r.json(); })
    .then(function() { window.location.reload(); })
    .catch(function() { window.location.reload(); });
  }
</script>

{% schema %}
{
  "name": "Cart Page",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "title", "label": "Page title", "default": "Your Cart" },
    { "type": "text", "id": "empty_text", "label": "Empty cart text", "default": "Your cart is empty" },
    { "type": "text", "id": "continue_text", "label": "Continue shopping text", "default": "Continue Shopping" },
    { "type": "text", "id": "checkout_text", "label": "Checkout button text", "default": "Checkout" },
    { "type": "text", "id": "tax_note", "label": "Tax/shipping note", "default": "Taxes and shipping calculated at checkout." },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#39ff14" },
    { "type": "color", "id": "card_bg", "label": "Card background", "default": "#111111" },
    { "type": "color", "id": "card_border", "label": "Card border", "default": "#2a2a2a" }
  ]
}
{% endschema %}
