{%- liquid
  assign section_title = section.settings.section_title | default: "Build Your Bundle"
  assign section_subtitle = section.settings.section_subtitle | default: "Select 2 or more products to unlock bundle discounts"
  assign min_products = section.settings.min_products | default: 2
  assign tier_2_discount = section.settings.tier_2_discount | default: 10
  assign tier_3_discount = section.settings.tier_3_discount | default: 15
  assign tier_2_code = section.settings.tier_2_discount_code
  assign tier_3_code = section.settings.tier_3_discount_code
  assign show_savings = section.settings.show_savings
  assign show_original = section.settings.show_original_prices
  assign cta_text = section.settings.cta_button_text | default: "Checkout Bundle"
  assign empty_text = section.settings.empty_selection_text | default: "Select at least 2 products"
  assign accent = settings.color_accent | default: '#39ff14'
  assign card_bg = settings.color_card_bg | default: '#111111'
  assign card_border = settings.color_border | default: '#2a2a2a'
-%}

<style>
  /* ═══════════════════════════════════════════════════════════
     Bundle Builder Section — Vexel Theme
     ═══════════════════════════════════════════════════════════ */

  .bundle-section {
    padding: {{ section.settings.padding_top | default: 60 }}px 20px {{ section.settings.padding_bottom | default: 80 }}px;
    position: relative;
    overflow: hidden;
  }

  .bundle-inner {
    max-width: var(--max-width, 1200px);
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  /* ── Header ────────────────────────────────────────────── */
  .bundle-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .bundle-header__title {
    font-family: var(--font-heading, 'Anton', sans-serif);
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    line-height: 1.1;
    color: var(--color-text, #fff);
    margin: 0 0 12px;
  }

  .bundle-header__subtitle {
    color: var(--color-text-muted, #9ca3af);
    font-size: 16px;
    line-height: 1.5;
    margin: 0 0 28px;
    font-family: var(--font-body, 'Inter', sans-serif);
  }

  /* ── Discount Tier Badges ──────────────────────────────── */
  .bundle-tiers {
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
  }

  .bundle-tier {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 500;
    font-family: var(--font-body, 'Inter', sans-serif);
    color: var(--color-text, #fff);
    background: rgba(148, 74, 255, 0.08);
    border: 1px solid rgba(148, 74, 255, 0.25);
    transition: border-color 0.3s, background 0.3s;
  }

  .bundle-tier.active {
    background: rgba(148, 74, 255, 0.18);
    border-color: rgba(148, 74, 255, 0.5);
  }

  .bundle-tier__pct {
    font-weight: 700;
    color: #9f5afd;
  }

  /* ── Product Grid ──────────────────────────────────────── */
  .bundle-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--grid-gap, 16px);
    margin-top: 40px;
  }

  @media (max-width: 900px) {
    .bundle-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .bundle-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* ── Product Card ──────────────────────────────────────── */
  .bundle-card {
    position: relative;
    background: {{ card_bg }};
    border: 1px solid {{ card_border }};
    border-radius: var(--radius-card, 12px);
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    -webkit-user-select: none;
    user-select: none;
  }

  .bundle-card:hover {
    transform: translateY(-3px);
    border-color: rgba(148, 74, 255, 0.4);
    box-shadow: 0 8px 32px rgba(148, 74, 255, 0.12);
  }

  .bundle-card.selected {
    border-color: #9f5afd;
    box-shadow: 0 0 0 1px #9f5afd, 0 8px 32px rgba(148, 74, 255, 0.2);
  }

  /* Selection circle */
  .bundle-card__check {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.25);
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    transition: background 0.25s, border-color 0.25s, transform 0.25s;
  }

  .bundle-card__check svg {
    width: 14px;
    height: 14px;
    opacity: 0;
    transform: scale(0.5);
    transition: opacity 0.25s, transform 0.25s;
    color: #fff;
  }

  .bundle-card.selected .bundle-card__check {
    background: #9f5afd;
    border-color: #9f5afd;
    transform: scale(1.05);
  }

  .bundle-card.selected .bundle-card__check svg {
    opacity: 1;
    transform: scale(1);
  }

  /* Card image */
  .bundle-card__image {
    aspect-ratio: 1;
    background: #0a0a0a;
    overflow: hidden;
    position: relative;
  }

  .bundle-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .bundle-card:hover .bundle-card__image img {
    transform: scale(1.04);
  }

  /* Card info */
  .bundle-card__info {
    padding: 14px;
  }

  .bundle-card__title {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--color-text, #fff);
    margin: 0 0 6px;
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .bundle-card__prices {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .bundle-card__price {
    font-weight: 800;
    font-size: 16px;
    color: var(--color-text, #fff);
  }

  .bundle-card__compare {
    font-size: 14px;
    color: var(--color-text-muted, #6b7280);
    text-decoration: line-through;
  }

  /* ── Summary Bar ───────────────────────────────────────── */
  .bundle-summary {
    max-width: 520px;
    margin: 48px auto 0;
    background: rgba(17, 17, 17, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 28px 32px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .bundle-summary__row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 0;
    font-size: 14px;
    color: var(--color-text-muted, #9ca3af);
    font-family: var(--font-body, 'Inter', sans-serif);
  }

  .bundle-summary__row--savings {
    color: #22c55e;
  }

  .bundle-summary__row--total {
    padding-top: 14px;
    margin-top: 8px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    font-size: 16px;
    font-weight: 700;
    color: var(--color-text, #fff);
  }

  .bundle-summary__row--total .bundle-summary__value {
    font-size: 22px;
    font-weight: 800;
  }

  .bundle-summary__btn {
    width: 100%;
    height: 52px;
    border: none;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    cursor: pointer;
    margin-top: 20px;
    transition: background 0.3s, box-shadow 0.3s, transform 0.2s, opacity 0.3s;
    font-family: var(--font-body, 'Inter', sans-serif);
  }

  .bundle-summary__btn--disabled {
    background: rgba(255, 255, 255, 0.06);
    color: var(--color-text-muted, #6b7280);
    cursor: not-allowed;
  }

  .bundle-summary__btn--active {
    background: #9f5afd;
    color: #fff;
    box-shadow: 0 4px 24px rgba(148, 74, 255, 0.4);
  }

  .bundle-summary__btn--active:hover {
    box-shadow: 0 6px 32px rgba(148, 74, 255, 0.55);
    transform: translateY(-1px);
  }

  /* Loading spinner inside button */
  .bundle-summary__btn .spinner {
    display: none;
    width: 20px;
    height: 20px;
    border: 2px solid rgba(255,255,255,0.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: bundle-spin 0.6s linear infinite;
    margin: 0 auto;
  }

  .bundle-summary__btn.loading .spinner { display: block; }
  .bundle-summary__btn.loading .btn-text { display: none; }

  @keyframes bundle-spin {
    to { transform: rotate(360deg); }
  }

  /* ── Responsive ────────────────────────────────────────── */
  @media (max-width: 600px) {
    .bundle-summary {
      padding: 20px 20px;
      margin-top: 32px;
    }
    .bundle-header__title {
      font-size: clamp(1.5rem, 6vw, 2rem);
    }
  }
</style>

<section class="bundle-section" id="bundle-builder-{{ section.id }}">
  <div class="bundle-inner">
    <!-- Header -->
    <div class="bundle-header">
      <h2 class="bundle-header__title">{{ section_title }}</h2>
      <p class="bundle-header__subtitle">{{ section_subtitle }}</p>

      <div class="bundle-tiers">
        <div class="bundle-tier" id="bundle-tier-2-{{ section.id }}">
          <span>2 products</span>
          <span class="bundle-tier__pct">{{ tier_2_discount }}% off</span>
        </div>
        <div class="bundle-tier" id="bundle-tier-3-{{ section.id }}">
          <span>3+ products</span>
          <span class="bundle-tier__pct">{{ tier_3_discount }}% off</span>
        </div>
      </div>
    </div>

    <!-- Product Grid -->
    <div class="bundle-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'product' and block.settings.product != blank -%}
          {%- assign product = block.settings.product -%}
          {%- if product.available -%}
            {%- liquid
              assign variant = product.selected_or_first_available_variant
              assign has_compare = false
              assign compare_price = 0
              if variant.compare_at_price > product.price
                assign has_compare = true
                assign compare_price = variant.compare_at_price
              elsif product.compare_at_price > product.price
                assign has_compare = true
                assign compare_price = product.compare_at_price
              endif
            -%}

            <div class="bundle-card"
                 data-variant-id="{{ variant.id }}"
                 data-price="{{ product.price }}"
                 data-compare-price="{{ compare_price | default: product.price }}"
                 data-title="{{ product.title | escape }}"
                 onclick="toggleBundleProduct(this, '{{ section.id }}')">

              <!-- Selection circle -->
              <div class="bundle-card__check">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </div>

              <!-- Product image -->
              <div class="bundle-card__image">
                {%- if product.featured_image -%}
                  <img src="{{ product.featured_image | image_url: width: 500 }}"
                       alt="{{ product.title | escape }}"
                       loading="lazy"
                       width="500" height="500">
                {%- else -%}
                  <div style="width:100%;height:100%;background:#0a0a0a;display:flex;align-items:center;justify-content:center;color:#333;">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/>
                    </svg>
                  </div>
                {%- endif -%}
              </div>

              <!-- Product info -->
              <div class="bundle-card__info">
                <h3 class="bundle-card__title">{{ product.title }}</h3>
                <div class="bundle-card__prices">
                  <span class="bundle-card__price">{{ product.price | money }}</span>
                  {%- if has_compare and show_original -%}
                    <span class="bundle-card__compare">{{ compare_price | money }}</span>
                  {%- endif -%}
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Summary Bar -->
    <div class="bundle-summary" id="bundle-summary-{{ section.id }}">
      <div class="bundle-summary__row">
        <span>Selected items:</span>
        <span class="bundle-summary__value" id="bundle-count-{{ section.id }}">0</span>
      </div>
      <div class="bundle-summary__row">
        <span>Subtotal:</span>
        <span class="bundle-summary__value" id="bundle-subtotal-{{ section.id }}">{{ 0 | money }}</span>
      </div>
      {%- if show_savings -%}
      <div class="bundle-summary__row bundle-summary__row--savings" id="bundle-savings-row-{{ section.id }}" style="display:none;">
        <span>You save:</span>
        <span class="bundle-summary__value" id="bundle-savings-{{ section.id }}">{{ 0 | money }}</span>
      </div>
      {%- endif -%}
      <div class="bundle-summary__row bundle-summary__row--total">
        <span>Total:</span>
        <span class="bundle-summary__value" id="bundle-total-{{ section.id }}">{{ 0 | money }}</span>
      </div>

      <button class="bundle-summary__btn bundle-summary__btn--disabled"
              id="bundle-btn-{{ section.id }}"
              disabled
              onclick="checkoutBundle('{{ section.id }}')">
        <span class="btn-text">{{ empty_text }}</span>
        <div class="spinner"></div>
      </button>
    </div>
  </div>
</section>

<script>
(function() {
  var sectionId = {{ section.id | json }};
  var minProducts = {{ min_products }};
  var tier2Discount = {{ tier_2_discount }};
  var tier3Discount = {{ tier_3_discount }};
  var tier2Code = {{ tier_2_code | json }};
  var tier3Code = {{ tier_3_code | json }};
  var ctaText = {{ cta_text | json }};
  var emptyText = {{ empty_text | json }};
  var showSavings = {{ show_savings | json }};

  /* Format money using Shopify's format */
  function formatMoney(cents) {
    if (typeof Shopify !== 'undefined' && Shopify.formatMoney) {
      return Shopify.formatMoney(cents);
    }
    var amount = (cents / 100).toFixed(2);
    /* Use the store's money format if available */
    var format = '{{ shop.money_format }}';
    if (format && format.indexOf('amount') > -1) {
      return format.replace(/\{\{\s*amount\s*\}\}/, amount)
                   .replace(/\{\{\s*amount_no_decimals\s*\}\}/, Math.round(cents / 100))
                   .replace(/\{\{\s*amount_with_comma_separator\s*\}\}/, amount.replace('.', ','));
    }
    return '$' + amount;
  }

  window.toggleBundleProduct = function(card, secId) {
    if (secId !== sectionId) return;
    card.classList.toggle('selected');
    updateBundleSummary();
  };

  function updateBundleSummary() {
    var cards = document.querySelectorAll('#bundle-builder-' + sectionId + ' .bundle-card.selected');
    var count = cards.length;
    var subtotal = 0;

    cards.forEach(function(c) {
      subtotal += parseInt(c.getAttribute('data-price'), 10) || 0;
    });

    /* Determine discount tier */
    var discountPct = 0;
    if (count >= 3) {
      discountPct = tier3Discount;
    } else if (count >= 2) {
      discountPct = tier2Discount;
    }

    var savings = Math.round(subtotal * discountPct / 100);
    var total = subtotal - savings;

    /* Update UI */
    var countEl = document.getElementById('bundle-count-' + sectionId);
    var subtotalEl = document.getElementById('bundle-subtotal-' + sectionId);
    var totalEl = document.getElementById('bundle-total-' + sectionId);
    var btn = document.getElementById('bundle-btn-' + sectionId);
    var tier2El = document.getElementById('bundle-tier-2-' + sectionId);
    var tier3El = document.getElementById('bundle-tier-3-' + sectionId);

    if (countEl) countEl.textContent = count;
    if (subtotalEl) subtotalEl.textContent = formatMoney(subtotal);
    if (totalEl) totalEl.textContent = formatMoney(total);

    /* Savings row */
    if (showSavings) {
      var savingsRow = document.getElementById('bundle-savings-row-' + sectionId);
      var savingsEl = document.getElementById('bundle-savings-' + sectionId);
      if (savingsRow && savingsEl) {
        if (savings > 0) {
          savingsRow.style.display = 'flex';
          savingsEl.textContent = '-' + formatMoney(savings);
        } else {
          savingsRow.style.display = 'none';
        }
      }
    }

    /* Update tier badges */
    if (tier2El) tier2El.classList.toggle('active', count >= 2 && count < 3);
    if (tier3El) tier3El.classList.toggle('active', count >= 3);

    /* Button state */
    if (btn) {
      if (count >= minProducts) {
        btn.disabled = false;
        btn.className = 'bundle-summary__btn bundle-summary__btn--active';
        btn.querySelector('.btn-text').textContent = ctaText;
      } else {
        btn.disabled = true;
        btn.className = 'bundle-summary__btn bundle-summary__btn--disabled';
        btn.querySelector('.btn-text').textContent = emptyText;
      }
    }
  }

  window.checkoutBundle = function(secId) {
    if (secId !== sectionId) return;

    var cards = document.querySelectorAll('#bundle-builder-' + sectionId + ' .bundle-card.selected');
    if (cards.length < minProducts) return;

    var btn = document.getElementById('bundle-btn-' + sectionId);
    if (btn) btn.classList.add('loading');

    /* Build cart items */
    var items = [];
    cards.forEach(function(c) {
      items.push({
        id: parseInt(c.getAttribute('data-variant-id'), 10),
        quantity: 1
      });
    });

    /* Determine discount code */
    var discountCode = '';
    if (cards.length >= 3 && tier3Code) {
      discountCode = tier3Code;
    } else if (cards.length >= 2 && tier2Code) {
      discountCode = tier2Code;
    }

    /* Clear cart first, then add bundle items */
    fetch('/cart/clear.js', { method: 'POST' })
    .then(function() {
      return fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: items })
      });
    })
    .then(function(r) { return r.json(); })
    .then(function() {
      /* Redirect to checkout with discount code if available */
      if (discountCode) {
        window.location.href = '/checkout?discount=' + encodeURIComponent(discountCode);
      } else {
        window.location.href = '/checkout';
      }
    })
    .catch(function(err) {
      console.error('Bundle checkout error:', err);
      if (btn) btn.classList.remove('loading');
      alert('Something went wrong. Please try again.');
    });
  };
})();
</script>

{% schema %}
{
  "name": "Bundle Builder",
  "tag": "section",
  "class": "bundle-builder-wrapper",
  "settings": [
    { "type": "header", "content": "Section Content" },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Build Your Bundle"
    },
    {
      "type": "textarea",
      "id": "section_subtitle",
      "label": "Section Subtitle",
      "default": "Select 2 or more products to unlock bundle discounts"
    },
    { "type": "header", "content": "Discount Tiers" },
    {
      "type": "paragraph",
      "content": "Create discount codes in Shopify Admin → Discounts → Create discount. Use 'Percentage' type and set the same % as below."
    },
    {
      "type": "range",
      "id": "tier_2_discount",
      "label": "2 Products Discount (%)",
      "min": 0,
      "max": 50,
      "step": 5,
      "default": 10,
      "unit": "%"
    },
    {
      "type": "text",
      "id": "tier_2_discount_code",
      "label": "2 Products Discount Code",
      "info": "Enter the exact code you created in Shopify Discounts (e.g., BUNDLE10)",
      "placeholder": "BUNDLE10"
    },
    {
      "type": "range",
      "id": "tier_3_discount",
      "label": "3+ Products Discount (%)",
      "min": 0,
      "max": 50,
      "step": 5,
      "default": 15,
      "unit": "%"
    },
    {
      "type": "text",
      "id": "tier_3_discount_code",
      "label": "3+ Products Discount Code",
      "info": "Enter the exact code you created in Shopify Discounts (e.g., BUNDLE15)",
      "placeholder": "BUNDLE15"
    },
    { "type": "header", "content": "Display Options" },
    {
      "type": "checkbox",
      "id": "show_savings",
      "label": "Show Savings Amount",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_original_prices",
      "label": "Show Original Prices",
      "info": "Display strikethrough prices on products",
      "default": true
    },
    { "type": "header", "content": "Button Text" },
    {
      "type": "text",
      "id": "cta_button_text",
      "label": "Checkout Button Text",
      "default": "Checkout Bundle"
    },
    {
      "type": "text",
      "id": "empty_selection_text",
      "label": "Empty Selection Text",
      "default": "Select at least 2 products"
    },
    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding (px)",
      "min": 0,
      "max": 120,
      "step": 10,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding (px)",
      "min": 0,
      "max": 120,
      "step": 10,
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Bundle Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bundle Builder"
    }
  ]
}
{% endschema %}
