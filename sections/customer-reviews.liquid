{{ 'section-customer-reviews' | append: section.id }}

<style>
  .cr-section-{{ section.id }} {
    padding: 60px 0;
    background: {{ settings.color_page_bg }};
  }
  .cr-container-{{ section.id }} {
    max-width: {{ settings.page_max_width }}px;
    margin: 0 auto;
    padding: 0 {{ settings.page_side_padding }}px;
  }
  .cr-title-{{ section.id }} {
    text-align: center;
    font-size: {{ settings.font_h2_size }}px;
    color: {{ settings.color_text_primary }};
    text-transform: {{ settings.font_heading_transform }};
    font-weight: 700;
    margin: 0 0 40px;
    font-family: {{ settings.font_heading.family }}, {{ settings.font_heading.fallback_families }};
  }
  .cr-aggregate-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }
  .cr-big-rating-{{ section.id }} {
    font-size: 56px;
    font-weight: 800;
    color: {{ settings.color_text_primary }};
    line-height: 1;
  }
  .cr-stars-{{ section.id }} {
    display: flex;
    gap: 4px;
  }
  .cr-star-{{ section.id }} {
    width: 24px;
    height: 24px;
    color: {{ settings.color_stars }};
  }
  .cr-star-empty-{{ section.id }} {
    color: {{ settings.color_text_faint }};
  }
  .cr-total-{{ section.id }} {
    font-size: 16px;
    color: {{ settings.color_text_muted }};
  }
  .cr-btn-wrap-{{ section.id }} {
    text-align: center;
    margin-bottom: 40px;
  }
  .cr-btn-{{ section.id }} {
    display: inline-block;
    background: {{ settings.btn_primary_bg }};
    color: {{ settings.btn_primary_text }};
    padding: 12px 32px;
    border-radius: {{ settings.btn_radius }}px;
    font-size: {{ settings.btn_font_size }}px;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: {{ settings.btn_letter_spacing }}px;
    {% if settings.btn_uppercase %}text-transform: uppercase;{% endif %}
    transition: background 0.3s, transform 0.3s;
  }
  .cr-btn-{{ section.id }}:hover {
    background: {{ settings.btn_primary_hover }};
    {% if settings.btn_hover_lift %}transform: translateY(-{{ settings.card_hover_lift_amount }}px);{% endif %}
  }
  .cr-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: {{ settings.grid_gap }}px;
  }
  .cr-card-{{ section.id }} {
    background: {{ settings.color_card_bg }};
    border: 1px solid {{ settings.color_border }};
    border-radius: {{ settings.card_radius }}px;
    padding: 28px 24px;
    transition: border-color 0.3s, transform 0.3s;
  }
  .cr-card-{{ section.id }}:hover {
    border-color: {{ settings.card_hover_border }};
    {% if settings.card_hover_lift %}transform: translateY(-{{ settings.card_hover_lift_amount }}px);{% endif %}
  }
  .cr-card-header-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 14px;
  }
  .cr-avatar-{{ section.id }} {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: {{ settings.color_accent }};
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 16px;
    color: #000;
    flex-shrink: 0;
    text-transform: uppercase;
  }
  .cr-reviewer-{{ section.id }} {
    font-size: 16px;
    font-weight: 600;
    color: {{ settings.color_text_primary }};
  }
  .cr-card-stars-{{ section.id }} {
    display: flex;
    gap: 3px;
    margin-bottom: 12px;
  }
  .cr-card-star-{{ section.id }} {
    width: 16px;
    height: 16px;
    color: {{ settings.color_stars }};
  }
  .cr-card-star-empty-{{ section.id }} {
    color: {{ settings.color_text_faint }};
  }
  .cr-text-{{ section.id }} {
    font-size: {{ settings.font_body_size }}px;
    color: {{ settings.color_text_muted }};
    line-height: {{ settings.font_body_line_height }};
    margin-bottom: 12px;
  }
  .cr-date-{{ section.id }} {
    font-size: 13px;
    color: {{ settings.color_text_faint }};
  }
  @media (max-width: 768px) {
    .cr-grid-{{ section.id }} {
      grid-template-columns: 1fr;
    }
    .cr-big-rating-{{ section.id }} {
      font-size: 40px;
    }
    .cr-title-{{ section.id }} {
      font-size: {{ settings.font_h1_mobile_size }}px;
    }
  }
</style>

<section class="cr-section-{{ section.id }}">
  <div class="cr-container-{{ section.id }}">
    {% if section.settings.title != blank %}
      <h2 class="cr-title-{{ section.id }}">{{ section.settings.title }}</h2>
    {% endif %}

    <div class="cr-aggregate-{{ section.id }}">
      <span class="cr-big-rating-{{ section.id }}">{{ section.settings.aggregate_rating }}</span>
      <div class="cr-stars-{{ section.id }}">
        {% assign full_stars = section.settings.aggregate_rating | floor %}
        {% assign half_check = section.settings.aggregate_rating | modulo: 1 %}
        {% for i in (1..5) %}
          {% if i <= full_stars %}
            <svg class="cr-star-{{ section.id }}" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 6.91-1.01L12 2z"/></svg>
          {% elsif i == full_stars | plus: 1 and half_check > 0 %}
            <svg class="cr-star-{{ section.id }}" viewBox="0 0 24 24"><defs><linearGradient id="half-{{ section.id }}"><stop offset="50%" stop-color="currentColor"/><stop offset="50%" stop-color="{{ settings.color_text_faint }}"/></linearGradient></defs><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 6.91-1.01L12 2z" fill="url(#half-{{ section.id }})"/></svg>
          {% else %}
            <svg class="cr-star-{{ section.id }} cr-star-empty-{{ section.id }}" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 6.91-1.01L12 2z"/></svg>
          {% endif %}
        {% endfor %}
      </div>
      <span class="cr-total-{{ section.id }}">{{ section.settings.total_reviews }} reviews</span>
    </div>

    {% if section.settings.review_button_url != blank %}
      <div class="cr-btn-wrap-{{ section.id }}">
        <a href="{{ section.settings.review_button_url }}" class="cr-btn-{{ section.id }}">{{ section.settings.review_button_text }}</a>
      </div>
    {% endif %}

    <div class="cr-grid-{{ section.id }}">
      {% for block in section.blocks %}
        {% if block.type == 'review' %}
          <div class="cr-card-{{ section.id }}" {{ block.shopify_attributes }}>
            <div class="cr-card-header-{{ section.id }}">
              {% assign name_parts = block.settings.reviewer_name | split: ' ' %}
              {% assign initials = name_parts[0] | slice: 0 %}
              {% if name_parts.size > 1 %}
                {% assign last_initial = name_parts[1] | slice: 0 %}
                {% assign initials = initials | append: last_initial %}
              {% endif %}
              <div class="cr-avatar-{{ section.id }}">{{ initials }}</div>
              <span class="cr-reviewer-{{ section.id }}">{{ block.settings.reviewer_name }}</span>
            </div>
            <div class="cr-card-stars-{{ section.id }}">
              {% for i in (1..5) %}
                {% if i <= block.settings.rating %}
                  <svg class="cr-card-star-{{ section.id }}" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 6.91-1.01L12 2z"/></svg>
                {% else %}
                  <svg class="cr-card-star-{{ section.id }} cr-card-star-empty-{{ section.id }}" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 6.91-1.01L12 2z"/></svg>
                {% endif %}
              {% endfor %}
            </div>
            <p class="cr-text-{{ section.id }}">{{ block.settings.review_text }}</p>
            {% if block.settings.date != blank %}
              <span class="cr-date-{{ section.id }}">{{ block.settings.date }}</span>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Customer Reviews",
  "tag": "section",
  "class": "section-customer-reviews",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Customer Reviews"
    },
    {
      "type": "text",
      "id": "aggregate_rating",
      "label": "Aggregate rating",
      "default": "4.8"
    },
    {
      "type": "text",
      "id": "total_reviews",
      "label": "Total reviews count",
      "default": "2,847"
    },
    {
      "type": "text",
      "id": "review_button_text",
      "label": "Review button text",
      "default": "Write a Review"
    },
    {
      "type": "url",
      "id": "review_button_url",
      "label": "Review button URL"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "reviewer_name",
          "label": "Reviewer name",
          "default": "John D."
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review text",
          "default": "Amazing vendor list! Found exactly what I needed to start my reselling business."
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "default": "2 weeks ago"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "reviewer_name": "Marcus T.",
            "rating": 5,
            "review_text": "Best vendor list I've ever purchased. The suppliers are legit and I started making sales within the first week. Highly recommend to anyone serious about reselling.",
            "date": "1 week ago"
          }
        },
        {
          "type": "review",
          "settings": {
            "reviewer_name": "Sarah K.",
            "rating": 5,
            "review_text": "I was skeptical at first but this completely changed my business. The vendor contacts are real and responsive. Already placed multiple orders.",
            "date": "2 weeks ago"
          }
        },
        {
          "type": "review",
          "settings": {
            "reviewer_name": "Devon W.",
            "rating": 4,
            "review_text": "Great resource for finding reliable vendors. The list is well organized and the prices from these suppliers are unbeatable. Worth every penny.",
            "date": "3 weeks ago"
          }
        }
      ]
    }
  ]
}
{% endschema %}
