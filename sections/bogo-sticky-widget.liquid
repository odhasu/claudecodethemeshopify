{% comment %}
  Section: BOGO 50% Off Sticky Widget - Color Controls Only
  Version: 12.4 (adds badge_text_color)
  File: sections/bogo-sticky-widget.liquid
{% endcomment %}

{%- liquid
  assign accent_color = section.settings.accent_color | default: '#FF6B6B'
  assign text_color = section.settings.text_color | default: '#FFFFFF'
  assign panel_bg_color = section.settings.panel_bg_color | default: '#0F0F0F'
  assign card_bg_color = section.settings.card_bg_color | default: '#1A1A1A'
  assign border_color = section.settings.border_color | default: 'rgba(255, 255, 255, 0.1)'
  assign label_text_color = section.settings.label_text_color | default: '#FFFFFF'
  assign price_text_color = section.settings.price_text_color | default: '#FF6B6B'
  assign discount_text_color = section.settings.discount_text_color | default: '#22c55e'
  assign muted_text_color = section.settings.muted_text_color | default: 'rgba(255, 255, 255, 0.5)'

  assign tab_bg_color = section.settings.tab_bg_color | default: accent_color
  assign tab_text_color = section.settings.tab_text_color | default: '#FFFFFF'
  assign tab_border_color = section.settings.tab_border_color | default: 'rgba(255, 255, 255, 0.3)'

  assign button_hover_color = section.settings.button_hover_color | default: accent_color
  assign selected_border_color = section.settings.selected_border_color | default: accent_color
  assign overlay_bg_color = section.settings.overlay_bg_color | default: '#000000'
  assign button_text_color = section.settings.button_text_color | default: '#FFFFFF'
  assign badge_text_color = section.settings.badge_text_color | default: '#FFFFFF'

  assign accent_r = accent_color | color_extract: 'red'
  assign accent_g = accent_color | color_extract: 'green'
  assign accent_b = accent_color | color_extract: 'blue'

  assign button_hover_r = button_hover_color | color_extract: 'red'
  assign button_hover_g = button_hover_color | color_extract: 'green'
  assign button_hover_b = button_hover_color | color_extract: 'blue'
-%}

{%- if section.settings.enable_widget and section.blocks.size > 1 -%}
{%- style -%}
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

  .bogo-panel-{{ section.id }} *,
  .bogo-panel-{{ section.id }} *::before,
  .bogo-panel-{{ section.id }} *::after { box-sizing: border-box; }

  @media (max-width: 768px) {
    .bogo-panel-{{ section.id }}, .bogo-overlay-{{ section.id }} {
      -webkit-transform: translateZ(0);
      -webkit-backface-visibility: hidden;
    }
  }

  /* Sticky tab */
  .bogo-sticky-tab-{{ section.id }} {
    position: fixed;
    {{ section.settings.position }}: 0;
    top: 50%;
    transform: translateY(-50%);
    z-index: 100001;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    transition: all 0.4s cubic-bezier(0.4,0,0.2,1);
    writing-mode: vertical-rl;
    width: auto;
    {% if section.settings.position == 'right' %}
      text-orientation: mixed;
    {% else %}
      text-orientation: mixed;
      transform: translateY(-50%) rotate(180deg);
    {% endif %}
  }
  .bogo-sticky-tab-{{ section.id }}.hidden {
    {% if section.settings.position == 'right' %}
      transform: translateY(-50%) translateX(30px);
    {% else %}
      transform: translateY(-50%) rotate(180deg) translateX(30px);
    {% endif %}
    opacity: 0; pointer-events: none;
  }
  .bogo-tab-content-{{ section.id }} {
    background: {{ tab_bg_color }};
    color: {{ tab_text_color }};
    padding: 6px 12px;
    border: 1px solid {{ tab_border_color }};
    border-{{ section.settings.position }}: none;
    border-radius: {% if section.settings.position == 'right' %}20px 0 0 20px{% else %}0 20px 20px 0{% endif %};
    box-shadow: {% if section.settings.position == 'right' %}-2px{% else %}2px{% endif %} 0 10px rgba(0,0,0,.2);
    display: flex; align-items: center; justify-content: center; gap: 8px;
    {% if section.settings.tab_layout == 'vertical' %}
      flex-direction: column; min-height: 70px; padding: 10px 6px;
    {% else %}
      flex-direction: row-reverse; min-height: 28px;
    {% endif %}
  }
  .bogo-tab-icon-{{ section.id }} { width: 12px; height: 12px; {% if section.settings.position == 'left' %}transform: rotate(180deg);{% endif %} }
  .bogo-tab-text-{{ section.id }} {
    font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: .6px; line-height: 1;
    {% if section.settings.position == 'left' %}transform: rotate(180deg);{% endif %}
  }
  .bogo-sticky-tab-{{ section.id }}:hover:not(.hidden) {
    {% if section.settings.position == 'right' %}
      transform: translateY(-50%) translateX(-2px);
    {% else %}
      transform: translateY(-50%) rotate(180deg) translateX(-2px);
    {% endif %}
  }

  /* Panel (glass, darker) */
  .bogo-panel-{{ section.id }} {
    position: fixed; top: 0; {{ section.settings.position }}: 0;
    width: 100%; max-width: 420px; height: 100vh; height: 100dvh;
    background-color: {{ panel_bg_color | color_modify: 'alpha', 0.72 }} !important;
    backdrop-filter: blur(8px) saturate(150%);
    -webkit-backdrop-filter: blur(8px) saturate(150%);
    border: 1px solid rgba(255,255,255,0.03);
    border-radius: {% if section.settings.position == 'right' %}16px 0 0 16px{% else %}0 16px 16px 0{% endif %};
    box-shadow:
      inset 0 0 0 1px rgba(255,255,255,0.03),
      inset 1.8px 3px 0px -2px rgba(255,255,255,0.15),
      inset -2px -2px 0px -2px rgba(255,255,255,0.12),
      inset -3px -8px 1px -6px rgba(255,255,255,0.08),
      inset -0.3px -1px 4px 0px rgba(0,0,0,0.24),
      inset -1.5px 2.5px 0px -2px rgba(0,0,0,0.4),
      inset 0px 3px 4px -2px rgba(0,0,0,0.4),
      inset 2px -6.5px 1px -4px rgba(0,0,0,0.2),
      {% if section.settings.position == 'right' %}-5px{% else %}5px{% endif %} 0 30px rgba(0,0,0,0.4);
    z-index: 100000;
    transform: translateX({% if section.settings.position == 'right' %}100%{% else %}-100%{% endif %});
    transition: transform .4s cubic-bezier(0.4,0,0.2,1);
    font-family: 'Inter', sans-serif; color: {{ text_color }}; overflow: hidden; box-sizing: border-box;
  }
  .bogo-panel-{{ section.id }}.open { transform: translateX(0); }

  .bogo-panel-content-{{ section.id }} { height: 100vh; height: 100dvh; display: flex; flex-direction: column; overflow: hidden; }
  .bogo-panel-scroll-{{ section.id }} { flex: 1; min-height: 0; overflow-y: auto; overflow-x: hidden; padding: 0 20px 60px 20px; -webkit-overflow-scrolling: touch; }
  .bogo-panel-fixed-header-{{ section.id }} { padding: 24px 20px 0 20px; }
  .bogo-panel-header-{{ section.id }} { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:16px; padding-bottom:16px; border-bottom:1px solid {{ border_color }}; }
  .bogo-panel-title-{{ section.id }} { font-size:20px; font-weight:700; margin:0 0 4px 0; color: {{ text_color }}; }
  .bogo-panel-subtitle-{{ section.id }} { font-size:13px; color: {{ muted_text_color }}; margin:0; line-height:1.4; }

  .bogo-close-btn-{{ section.id }} {
    background: transparent; border: 1px solid {{ border_color }}; border-radius: 50%; color: {{ text_color }};
    width: 32px; height: 32px; display:flex; align-items:center; justify-content:center; cursor: pointer; transition: .2s;
  }
  .bogo-close-btn-{{ section.id }}:hover { background: rgba(255,255,255,0.1); transform: rotate(90deg); border-color: {{ accent_color }}; }

  /* Product selection */
  .bogo-selection-area-{{ section.id }} { display:flex; flex-direction:column; gap:16px; margin-bottom:20px; padding-bottom:20px; }
  .bogo-product-section-{{ section.id }} { background: {{ card_bg_color }}; border:1px solid {{ border_color }}; border-radius:12px; padding:14px; }
  .bogo-section-label-{{ section.id }} { font-size:14px; font-weight:600; margin-bottom:10px; display:flex; align-items:center; justify-content:space-between; color: {{ label_text_color }}; }
  .bogo-section-step-{{ section.id }} { background: rgba(255,255,255,0.1); width:20px; height:20px; border-radius:50%; display:inline-flex; align-items:center; justify-content:center; font-size:11px; font-weight:700; margin-right:8px; }
  .bogo-section-badge-{{ section.id }} { background: {{ accent_color }}; color: {{ badge_text_color }}; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700; }

  .bogo-product-grid-{{ section.id }} { display:grid; grid-template-columns: repeat(2, 1fr); gap:10px; }
  @media (min-width: 360px) { .bogo-product-grid-{{ section.id }} { grid-template-columns: repeat(3, 1fr); } }

  .bogo-product-card-{{ section.id }} {
    background: {{ panel_bg_color }};
    border: 2px solid transparent; border-radius: 8px; padding: 10px; cursor: pointer; transition: .2s; text-align:center; display:grid; gap:6px;
  }
  .bogo-product-card-{{ section.id }}:hover { background: rgba(255,255,255,0.05); border-color: rgba({{ accent_r }}, {{ accent_g }}, {{ accent_b }}, .3); }
  .bogo-product-card-{{ section.id }}.selected { border-color: {{ selected_border_color }}; background: rgba({{ accent_r }}, {{ accent_g }}, {{ accent_b }}, .1); box-shadow: 0 0 0 1px {{ selected_border_color }}; }

  .bogo-product-title-{{ section.id }} { font-size:12px; font-weight:600; line-height:1.3; color: {{ text_color }}; }
  .bogo-product-price-{{ section.id }} { font-size:13px; font-weight:700; color: {{ price_text_color }}; }

  .bogo-price-summary-{{ section.id }} { background: {{ card_bg_color }}; border:1px solid {{ accent_color }}; border-radius:10px; padding:16px; margin-top:16px; }
  .bogo-price-row-{{ section.id }} { display:flex; justify-content:space-between; align-items:center; margin-bottom:8px; font-size:13px; color: {{ text_color }}; }
  .bogo-price-row-{{ section.id }}:last-child { margin-bottom:0; padding-top:8px; border-top:1px solid {{ border_color }}; font-size:14px; font-weight:700; }
  .bogo-discount-amount-{{ section.id }} { color: {{ discount_text_color }}; font-weight:600; }
  .bogo-original-price-{{ section.id }} { text-decoration: line-through; color: {{ muted_text_color }}; font-size:12px; margin-right:6px; }

  .bogo-checkout-btn-{{ section.id }} {
    background: {{ accent_color }}; color: {{ button_text_color }}; border:none; border-radius:8px; padding:14px 20px;
    font-size:14px; font-weight:600; text-transform:uppercase; letter-spacing:.5px; cursor:pointer; transition:.2s;
    margin-top:16px; width:100%; display:flex; align-items:center; justify-content:center; gap:8px;
  }
  .bogo-checkout-btn-{{ section.id }}:hover:not(:disabled) { background: {{ button_hover_color }}; transform: translateY(-1px); box-shadow: 0 6px 20px rgba({{ button_hover_r }}, {{ button_hover_g }}, {{ button_hover_b }}, .4); }
  .bogo-checkout-btn-{{ section.id }}:active:not(:disabled) { transform: translateY(0); }
  .bogo-checkout-btn-{{ section.id }}:disabled { opacity:.5; cursor:not-allowed; }
  .loading-spinner-{{ section.id }} { display:none; width:16px; height:16px; border:2px solid transparent; border-top-color: currentColor; border-radius:50%; animation: spin-{{ section.id }} .8s linear infinite; }
  .bogo-checkout-btn-{{ section.id }}.loading .loading-spinner-{{ section.id }} { display:block; }
  @keyframes spin-{{ section.id }} { to { transform: rotate(360deg); } }

  .bogo-status-message-{{ section.id }} { padding:12px; border-radius:8px; margin-top:12px; font-size:13px; text-align:center; display:none; }
  .bogo-status-message-{{ section.id }}.success { background: rgba(34,197,94,.1); border:1px solid #22c55e; color:#22c55e; display:block; }
  .bogo-status-message-{{ section.id }}.error { background: rgba(239,68,68,.1); border:1px solid #ef4444; color:#ef4444; display:block; }
  .bogo-status-message-{{ section.id }}.warning { background: rgba(245,158,11,.1); border:1px solid #f59e0b; color:#f59e0b; display:block; }

  @media (max-width: 768px) {
    .bogo-sticky-tab-{{ section.id }} { {% if section.settings.position == 'left' %}transform: translateY(-50%) rotate(180deg);{% endif %} }
    .bogo-sticky-tab-{{ section.id }}.hidden { {% if section.settings.position == 'right' %}transform: translateY(-50%) translateX(30px);{% else %}transform: translateY(-50%) rotate(180deg) translateX(30px);{% endif %} }
    .bogo-tab-content-{{ section.id }} { padding:5px 10px; font-size:9px; gap:6px; {% if section.settings.tab_layout == 'horizontal' %}min-height:24px;{% endif %} }
    .bogo-tab-icon-{{ section.id }} { width:11px; height:11px; }
    .bogo-tab-text-{{ section.id }} { font-size:9px; font-weight:800; }
    .bogo-panel-{{ section.id }} { max-width:100%; width:100%; height:100vh; height:100dvh; transform: translateX({% if section.settings.position == 'right' %}100%{% else %}-100%{% endif %}); transition: transform .3s cubic-bezier(0.4,0,0.2,1); border-radius:0; }
    .bogo-panel-{{ section.id }}.open { transform: translateX(0) !important; }
    .bogo-panel-fixed-header-{{ section.id }} { padding:16px 16px 0 16px; }
    .bogo-panel-scroll-{{ section.id }} { padding: 0 16px 50px 16px; }
    .bogo-product-grid-{{ section.id }} { gap:8px; grid-template-columns: repeat(2, 1fr); }
  }

  /* Overlay (color adjustable; fixed 0.5 alpha) */
  .bogo-overlay-{{ section.id }} {
    position: fixed; inset: 0; background: {{ overlay_bg_color | color_modify: 'alpha', 0.5 }};
    z-index: 99999; opacity: 0; visibility: hidden; transition: opacity .3s ease, visibility .3s ease; -webkit-tap-highlight-color: transparent;
  }
  .bogo-overlay-{{ section.id }}.show { opacity: 1; visibility: visible; }

  .bogo-icon-svg { fill: currentColor; }
  .bogo-discount-info-{{ section.id }} { display:none; }
{%- endstyle -%}

<!-- Sticky Tab -->
<div class="bogo-sticky-tab-{{ section.id }}" id="bogoTab{{ section.id }}" data-bogo-open>
  <div class="bogo-tab-content-{{ section.id }}">
    <svg class="bogo-tab-icon-{{ section.id }} bogo-icon-svg" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M19 7h-3V6a4 4 0 0 0-8 0v1H5a1 1 0 0 0-1 1v11a3 3 0 0 0 3 3h10a3 3 0 0 0 3-3V8a1 1 0 0 0-1-1zM10 6a2 2 0 0 1 4 0v1h-4V6zm8 13a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V9h2v1a1 1 0 0 0 2 0V9h4v1a1 1 0 0 0 2 0V9h2v10z"/>
    </svg>
    <span class="bogo-tab-text-{{ section.id }}">{{ section.settings.tab_text }}</span>
  </div>
</div>

<!-- Overlay -->
<div class="bogo-overlay-{{ section.id }}" data-bogo-close></div>

<!-- Slide-out Panel -->
<div class="bogo-panel-{{ section.id }}" id="bogoPanel{{ section.id }}" role="dialog" aria-modal="true" aria-label="{{ section.settings.panel_title }}">
  <div class="bogo-panel-content-{{ section.id }}">
    <div class="bogo-panel-fixed-header-{{ section.id }}">
      <div class="bogo-panel-header-{{ section.id }}">
        <div>
          <h3 class="bogo-panel-title-{{ section.id }}">{{ section.settings.panel_title }}</h3>
          <p class="bogo-panel-subtitle-{{ section.id }}">{{ section.settings.panel_subtitle }}</p>
        </div>
        <button class="bogo-close-btn-{{ section.id }}" data-bogo-close aria-label="Close">×</button>
      </div>
    </div>

    <div class="bogo-panel-scroll-{{ section.id }}">
      <!-- Product Selection -->
      <div class="bogo-selection-area-{{ section.id }}">
        <div class="bogo-product-section-{{ section.id }}">
          <div class="bogo-section-label-{{ section.id }}">
            <span><span class="bogo-section-step-{{ section.id }}">1</span>Choose First Item</span>
          </div>
          <div class="bogo-product-grid-{{ section.id }}" id="firstProductGrid{{ section.id }}">
            {%- for block in section.blocks -%}
              {%- if block.settings.product != blank -%}
                {%- assign product = block.settings.product -%}
                {%- assign variant = product.selected_or_first_available_variant -%}
                {%- assign display_name = block.settings.custom_name | default: product.title -%}
                {%- if product.available -%}
                  <div class="bogo-product-card-{{ section.id }}"
                       data-variant-id="{{ variant.id }}"
                       data-title="{{ display_name | escape }}"
                       data-price="{{ variant.price }}"
                       data-product-select="first">
                    <div class="bogo-product-title-{{ section.id }}">{{ display_name }}</div>
                    <div class="bogo-product-price-{{ section.id }}">{{ variant.price | money }}</div>
                  </div>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>

        <div class="bogo-product-section-{{ section.id }}">
          <div class="bogo-section-label-{{ section.id }}">
            <span><span class="bogo-section-step-{{ section.id }}">2</span>Choose Second Item</span>
            <span class="bogo-section-badge-{{ section.id }}">{{ section.settings.second_badge_text }}</span>
          </div>
          <div class="bogo-product-grid-{{ section.id }}" id="secondProductGrid{{ section.id }}">
            {%- for block in section.blocks -%}
              {%- if block.settings.product != blank -%}
                {%- assign product = block.settings.product -%}
                {%- assign variant = product.selected_or_first_available_variant -%}
                {%- assign display_name = block.settings.custom_name | default: product.title -%}
                {%- if product.available -%}
                  <div class="bogo-product-card-{{ section.id }}"
                       data-variant-id="{{ variant.id }}"
                       data-title="{{ display_name | escape }}"
                       data-price="{{ variant.price }}"
                       data-product-select="second">
                    <div class="bogo-product-title-{{ section.id }}">{{ display_name }}</div>
                    <div class="bogo-product-price-{{ section.id }}">{{ variant.price | money }}</div>
                  </div>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>

      <!-- Price Summary -->
      <div class="bogo-price-summary-{{ section.id }}" id="priceSummary{{ section.id }}" style="display: none;">
        <div class="bogo-price-row-{{ section.id }}">
          <span id="firstProductName{{ section.id }}">-</span>
          <span id="firstProductPrice{{ section.id }}">$0.00</span>
        </div>
        <div class="bogo-price-row-{{ section.id }}">
          <span id="secondProductName{{ section.id }}">-</span>
          <span>
            <span class="bogo-original-price-{{ section.id }}" id="secondProductOriginalPrice{{ section.id }}">$0.00</span>
            <span id="secondProductDiscountPrice{{ section.id }}">$0.00</span>
          </span>
        </div>
        <div class="bogo-price-row-{{ section.id }}">
          <span>You Save:</span>
          <span class="bogo-discount-amount-{{ section.id }}" id="totalSavings{{ section.id }}">$0.00</span>
        </div>
        <div class="bogo-price-row-{{ section.id }}">
          <span>Total:</span>
          <span id="finalTotal{{ section.id }}">$0.00</span>
        </div>
      </div>

      <!-- Status Message -->
      <div class="bogo-status-message-{{ section.id }}" id="statusMessage{{ section.id }}"></div>

      <!-- Checkout Button -->
      <button class="bogo-checkout-btn-{{ section.id }}"
              id="bogoCheckoutBtn{{ section.id }}"
              data-bogo-checkout
              disabled>
        <span class="loading-spinner-{{ section.id }}"></span>
        <span id="checkoutBtnText{{ section.id }}">Select Both Products</span>
      </button>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const sectionId = '{{ section.id }}';
    const panel = document.getElementById('bogoPanel' + sectionId);
    const overlay = document.querySelector('.bogo-overlay-' + sectionId);
    const tab = document.getElementById('bogoTab' + sectionId);
    const statusMessage = document.getElementById('statusMessage' + sectionId);

    let selectedProducts = { first: null, second: null };

    function showStatus(message, type = 'success') {
      statusMessage.textContent = message;
      statusMessage.className = `bogo-status-message-${sectionId} ${type}`;
      if (type === 'success') setTimeout(() => { statusMessage.className = `bogo-status-message-${sectionId}`; }, 5000);
    }

    function openPanel() {
      panel.classList.add('open');
      overlay.classList.add('show');
      tab.classList.add('hidden');
      if ('ontouchstart' in window) {
        document.body.style.position = 'fixed';
        document.body.style.width = '100%';
        document.body.style.top = `-${window.scrollY}px`;
      } else {
        document.body.style.overflow = 'hidden';
      }
    }
    function closePanel() {
      panel.classList.remove('open');
      overlay.classList.remove('show');
      if ('ontouchstart' in window && document.body.style.position === 'fixed') {
        const scrollY = Math.abs(parseInt(document.body.style.top || '0'));
        document.body.style.position = '';
        document.body.style.width = '';
        document.body.style.top = '';
        window.scrollTo(0, scrollY);
      } else {
        document.body.style.overflow = '';
      }
      setTimeout(() => { tab.classList.remove('hidden'); }, window.innerWidth <= 768 ? 250 : 300);
    }

    document.querySelectorAll('[data-bogo-open]').forEach(el => el.addEventListener('click', openPanel));
    document.querySelectorAll('[data-bogo-close]').forEach(el => el.addEventListener('click', closePanel));

    document.querySelectorAll('[data-product-select]').forEach(el => {
      el.addEventListener('click', function() {
        const position = this.getAttribute('data-product-select');
        const variantId = parseInt(this.getAttribute('data-variant-id'));
        const title = this.getAttribute('data-title');
        const price = parseInt(this.getAttribute('data-price'));
        if (!variantId || isNaN(variantId)) { showStatus('Invalid product variant. Please try again.', 'error'); return; }
        document.querySelectorAll(`[data-product-select="${position}"]`).forEach(c => c.classList.remove('selected'));
        this.classList.add('selected');
        selectedProducts[position] = { variantId, title, price };
        updatePriceSummary();
      });
    });

    function updatePriceSummary() {
      const summary = document.getElementById('priceSummary' + sectionId);
      const checkoutBtn = document.getElementById('bogoCheckoutBtn' + sectionId);
      const btnText = document.getElementById('checkoutBtnText' + sectionId);

      if (selectedProducts.first && selectedProducts.second) {
        const a = selectedProducts.first, b = selectedProducts.second;
        const full = a.price >= b.price ? a : b;
        const disc = a.price >= b.price ? b : a;
        const discountAmount = Math.round(disc.price * 0.5);
        const discountedPrice = disc.price - discountAmount;
        const totalPrice = full.price + discountedPrice;

        document.getElementById('firstProductName' + sectionId).textContent = full.title;
        document.getElementById('firstProductPrice' + sectionId).textContent = formatMoney(full.price);
        document.getElementById('secondProductName' + sectionId).textContent = disc.title + ' ({{ section.settings.second_badge_text }})';
        document.getElementById('secondProductOriginalPrice' + sectionId).textContent = formatMoney(disc.price);
        document.getElementById('secondProductDiscountPrice' + sectionId).textContent = formatMoney(discountedPrice);
        document.getElementById('totalSavings' + sectionId).textContent = formatMoney(discountAmount);
        document.getElementById('finalTotal' + sectionId).textContent = formatMoney(totalPrice);

        summary.style.display = 'block';
        checkoutBtn.disabled = false;
        btnText.textContent = `Checkout - Save ${formatMoney(discountAmount)}`;
      } else {
        summary.style.display = 'none';
        checkoutBtn.disabled = true;
        btnText.textContent = (!selectedProducts.first && !selectedProducts.second) ? 'Select Both Products'
                         : (!selectedProducts.first ? 'Select First Product' : 'Select Second Product');
      }
    }

    document.querySelector('[data-bogo-checkout]').addEventListener('click', function() {
      if (!selectedProducts.first || !selectedProducts.second) return;

      const btn = this;
      const btnText = document.getElementById('checkoutBtnText' + sectionId);
      const discountCode = '{{ section.settings.discount_code }}';
      if (!discountCode || discountCode.trim() === '') { showStatus('Setup required: No discount code configured.', 'error'); return; }

      btn.classList.add('loading'); btn.disabled = true; btnText.textContent = 'Processing...';

      const clearCart = {{ section.settings.clear_cart_first }};

      let cartPromise = Promise.resolve();
      if (clearCart) { cartPromise = fetch('/cart/clear.js', { method: 'POST', headers: { 'Content-Type': 'application/json' } }); }

      cartPromise
        .then(() => {
          btnText.textContent = 'Adding to cart...';
          const body = { items: [
            { id: parseInt(selectedProducts.first.variantId), quantity: 1 },
            { id: parseInt(selectedProducts.second.variantId), quantity: 1 }
          ]};
          return fetch('/cart/add.js', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
        })
        .then(r => r.ok ? r.json() : r.json().then(e => { throw new Error(e.description || 'Failed to add to cart'); }))
        .then(() => fetch('/cart/update.js', {
          method:'POST', headers:{'Content-Type':'application/json'},
          body: JSON.stringify({ attributes: { 'discount_code': discountCode.trim(), 'bogo_deal': 'true', 'bogo_applied': 'pending' },
                                 note: `BOGO Deal - Apply code: ${discountCode.trim()}` })
        }))
        .then(() => {
          btnText.textContent = 'Applying discount...';
          try { localStorage.setItem('bogo_discount_code', discountCode.trim()); localStorage.setItem('bogo_discount_timestamp', Date.now().toString()); } catch(e) {}
          const discountUrl = `/discount/${encodeURIComponent(discountCode.trim())}?redirect=/checkout`;
          setTimeout(() => { btnText.textContent = 'Redirecting...'; window.location.href = discountUrl; }, 100);
        })
        .catch(err => {
          console.error('Checkout error:', err);
          btn.classList.remove('loading'); btn.disabled = false;
          if (err.message.includes('sold out') || err.message.includes('inventory')) { showStatus('❌ One or more items are out of stock.', 'error'); btnText.textContent = 'Out of Stock'; }
          else if (err.message.includes('variant')) { showStatus('❌ Product not available. Try refreshing.', 'error'); btnText.textContent = 'Product Error'; }
          else { showStatus(`❌ ${err.message}`, 'error'); btnText.textContent = 'Error - Try Again'; }
          setTimeout(updatePriceSummary, 3000);
        });
    });

    function formatMoney(cents) { return '$' + (cents / 100).toFixed(2); }

    document.addEventListener('keydown', e => { if (e.key === 'Escape') closePanel(); });

    if (window.location.pathname === '/cart') {
      try {
        const code = localStorage.getItem('bogo_discount_code');
        const ts = localStorage.getItem('bogo_discount_timestamp');
        if (code && ts) {
          const hours = (Date.now() - parseInt(ts)) / 36e5;
          if (hours < 24) {
            fetch('/cart.js').then(res => res.json()).then(cart => {
              if (cart.attributes && cart.attributes.bogo_deal === 'true') {
                const el = document.createElement('div');
                el.className = 'bogo-discount-reminder-' + sectionId;
                el.style.cssText = 'position:fixed;bottom:20px;right:20px;background:rgba(17,17,17,0.92);color:#fff;padding:12px 14px;border-radius:10px;border:1px solid rgba(255,255,255,0.1);box-shadow:0 10px 20px rgba(0,0,0,0.25);z-index:100010;font-family:Inter,sans-serif;font-size:13px;';
                el.innerHTML = `
                  <button onclick="this.parentElement.remove()" style="position:absolute;top:6px;right:8px;background:transparent;border:none;color:#fff;opacity:.7;cursor:pointer;font-size:16px" aria-label="Close">×</button>
                  <strong>BOGO Deal Active!</strong><br>
                  Use code: <strong>${code}</strong> at checkout<br>
                  <small style="opacity:.9;">50% off the cheaper item</small>
                `;
                document.body.appendChild(el);
                setTimeout(() => { if (el.parentElement) el.remove(); }, 10000);
              }
            });
          }
          if (hours > 24) { localStorage.removeItem('bogo_discount_code'); localStorage.removeItem('bogo_discount_timestamp'); }
        }
      } catch(e) {}
    }
  });
</script>
{%- endif -%}

