</div>

<script>
  (function() {
    const sectionId = '{{ section.id }}';
    
    {%- if section.settings.enable_conversion_header -%}
    // Conversion Header Script
    const members = [
      {%- assign has_header_members = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'header_member' -%}
          {%- assign has_header_members = true -%}
          { name: '{{ block.settings.member_name | escape }}', profit: '{{ block.settings.member_profit | escape }}' },
        {%- endif -%}
      {%- endfor -%}
      {%- unless has_header_members -%}
        { name: 'Tyler K.', profit: '$1,847' },
        { name: 'Marcus R.', profit: '$2,392' },
        { name: 'Jordan T.', profit: '$984' },
        { name: 'Blake M.', profit: '$3,126' },
        { name: 'Connor S.', profit: '$1,563' }
      {%- endunless -%}
    ];
    
    const timeFrames = ['2 mins ago', '3 mins ago', '7 mins ago', '11 mins ago', '14 mins ago', '18 mins ago'];
    
    let memberIndex = 0;
    let currentMessage = 1;
    const totalMessages = 4;
    
    function updateProfitDisplay() {
      memberIndex = (memberIndex + 1) % members.length;
      const member = members[memberIndex];
      
      const nameEl = document.getElementById('memberName-' + sectionId);
      const profitEl = document.getElementById('profitAmount-' + sectionId);
      const timeEl = document.getElementById('timeAgo-' + sectionId);
      
      if (nameEl) nameEl.textContent = member.name;
      if (profitEl) profitEl.textContent = member.profit;
      if (timeEl) timeEl.textContent = timeFrames[Math.floor(Math.random() * timeFrames.length)];
    }
    
    function updateActiveMembers() {
      const hour = new Date().getHours();
      const isEvening = hour >= 17 && hour <= 23;
      const base = isEvening ? 1200 : 800;
      const variance = Math.floor(Math.random() * 200);
      
      const el = document.getElementById('activeMembers-' + sectionId);
      if (el) el.textContent = (base + variance).toLocaleString();
    }
    
    function updateLostAmount() {
      const avgProfit = 487 + Math.floor(Math.random() * 200);
      const el = document.getElementById('lostAmount-' + sectionId);
      if (el) el.textContent = avgProfit;
    }
    
    function rotateMessages() {
      document.getElementById(`message${currentMessage}-${sectionId}`).classList.add('message-hidden-' + sectionId);
      currentMessage = currentMessage % totalMessages + 1;
      document.getElementById(`message${currentMessage}-${sectionId}`).classList.remove('message-hidden-' + sectionId);
      
      switch(currentMessage) {
        case 1:
          setTimeout(updateProfitDisplay, 100);
          break;
        case 2:
          updateActiveMembers();
          break;
        case 4:
          updateLostAmount();
          break;
      }
    }
    
    updateProfitDisplay();
    updateActiveMembers();
    updateLostAmount();
    
    setInterval(rotateMessages, 4500);
    setInterval(updateActiveMembers, 30000);
    setInterval(() => {
      if (currentMessage === 1 && Math.random() < 0.3) {
        updateProfitDisplay();
      }
    }, 15000);
    {%- endif -%}

    {%- if section.settings.enable_live_sales -%}
    // Live Sales Notification Script
    const notifications = [
      {%- assign has_live_sales = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'live_sale' -%}
          {%- assign has_live_sales = true -%}
          { name: '{{ block.settings.customer_name | escape }}', product: '{{ block.settings.product_name | escape }}' },
        {%- endif -%}
      {%- endfor -%}
      {%- unless has_live_sales -%}
        { name: 'Landon L.', product: 'Spyder Hoodie Vendor' },
        { name: 'Emiliano G.', product: 'Pod Vendor' },
        { name: 'Christian', product: 'ELITE VENDOR BUNDLE' },
        { name: 'Aurora', product: 'Colognes Vendor' }
      {%- endunless -%}
    ];

    const notificationElement = document.getElementById('sale-notification-' + sectionId);
    const nameElement = document.getElementById('customer-name-' + sectionId);
    const productElement = document.getElementById('product-name-' + sectionId);

    function showNotification() {
      const randomSale = notifications[Math.floor(Math.random() * notifications.length)];
      nameElement.textContent = randomSale.name;
      productElement.textContent = randomSale.product;

      notificationElement.classList.add('sales-visible');

      setTimeout(() => {
        notificationElement.classList.remove('sales-visible');
      }, 5000);

      const nextDelay = Math.floor(Math.random() * 15000) + 10000;
      setTimeout(showNotification, 5000 + nextDelay);
    }

    setTimeout(showNotification, 5000);
    {%- endif -%}

    // Add body padding for fixed header
    {%- if section.settings.enable_conversion_header -%}
    document.addEventListener('DOMContentLoaded', function() {
      document.body.style.paddingTop = '52px';
      if (window.innerWidth >= 768) {
        document.body.style.paddingTop = '56px';
      }
    });
    {%- endif -%}

    // FAQ Accordion - Fixed and Simplified
    function initializeFAQ() {
      var questions = document.querySelectorAll('.faq-question-{{ section.id }}');
      
      questions.forEach(function(question) {
        question.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          
          var item = this.parentElement;
          var answer = item.querySelector('.faq-answer-{{ section.id }}');
          var arrow = this.querySelector('.faq-arrow-{{ section.id }}');
          
          if (!answer) return;
          
          var isOpen = answer.getAttribute('data-open') === 'true';
          
          if (!isOpen) {
            // Calculate height
            answer.style.cssText = 'max-height: none; opacity: 1; visibility: visible;';
            var height = answer.scrollHeight;
            answer.style.cssText = 'max-height: 0px !important; padding: 0 14px !important; opacity: 0 !important;';
            
            // Force reflow
            answer.offsetHeight;
            
            // Open
            answer.style.cssText = 'max-height: ' + height + 'px !important; padding: 12px 14px !important; opacity: 1 !important; overflow: hidden !important;';
            answer.setAttribute('data-open', 'true');
            if (arrow) arrow.style.transform = 'rotate(180deg)';
            
            // Set overflow after transition
            setTimeout(function() {
              if (answer.getAttribute('data-open') === 'true') {
                answer.style.overflow = 'visible';
                answer.style.maxHeight = 'none';
              }
            }, 300);
          } else {
            // Close
            answer.style.overflow = 'hidden';
            answer.style.maxHeight = answer.scrollHeight + 'px';
            answer.offsetHeight; // Force reflow
            answer.style.cssText = 'max-height: 0px !important; padding: 0 14px !important; opacity: 0 !important; overflow: hidden !important;';
            answer.setAttribute('data-open', 'false');
            if (arrow) arrow.style.transform = 'rotate(0)';
          }
        });
      });
    }
    
    // Initialize FAQ when DOM is ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initializeFAQ);
    } else {
      initializeFAQ();
    }
  })();
</script>

{% schema %}
{
  "name": "Custom Landing Page",
