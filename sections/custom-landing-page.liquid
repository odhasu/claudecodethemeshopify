      "default": "Build A Profitable Reselling Business In 30 Days."
    },
    {
      "type": "textarea",
      "id": "hero_subheadline",
      "label": "Hero Subheadline",
      "default": "We provide the resources, suppliers, strategies, and support you NEED to build a $10k/month reselling business. Success Guaranteed."
    },
    {
      "type": "header",
      "content": "👥 Social Proof"
    },
    {
      "type": "text",
