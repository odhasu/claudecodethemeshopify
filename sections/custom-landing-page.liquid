{% comment %}
  Custom Landing Page Section
  Version: 1.2
  File: sections/custom-landing-page.liquid
{% endcomment %}

{%- liquid
  # Core Colors from settings
  assign accent_color = section.settings.accent_color
  assign gradient_color = section.settings.gradient_color
  assign text_color = section.settings.text_color
  assign background_color = section.settings.background_color
  
  # Pre-configured color variations
  assign heading_color = text_color
  assign price_color = text_color
  assign sale_price_color = accent_color
  assign compare_price_color = text_color | color_modify: 'alpha', 0.6
  
  # Button colors
  assign button_bg_color = accent_color
  assign button_text_color = '#FFFFFF'
  
  # Glassmorphism settings
  assign glass_intensity = 100
  assign glass_transparency = 50
  assign frost_color = '#FFFFFF'
  assign frost_r = frost_color | color_extract: 'red'
  assign frost_g = frost_color | color_extract: 'green'
  assign frost_b = frost_color | color_extract: 'blue'
  
  # Glass calculations
  assign glass_blur = glass_intensity | times: 0.25
  
  if glass_transparency >= 90
    assign border_opacity = 0.5
    assign glass_opacity_1 = 0.7
    assign glass_opacity_2 = 0.65
  elsif glass_transparency >= 70
    assign border_opacity = 0.4
    assign glass_opacity_1 = 0.4
    assign glass_opacity_2 = 0.35
  elsif glass_transparency >= 50
    assign border_opacity = 0.3
    assign glass_opacity_1 = 0.2
    assign glass_opacity_2 = 0.15
  elsif glass_transparency >= 30
    assign border_opacity = 0.2
    assign glass_opacity_1 = 0.08
    assign glass_opacity_2 = 0.04
  else
    assign border_opacity = 0.15
    assign glass_opacity_1 = 0.04
    assign glass_opacity_2 = 0.02
  endif
  
  assign card_border_color = 'rgba(255, 255, 255, 0.25)'
  assign sale_badge_text = text_color
-%}

{%- style -%}
  /* Import fonts */
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap');
  @import url('https://fonts.googleapis.com/css2?family=Anton&display=swap');
  
  /* Reset and base styles */
  .section-{{ section.id }} {
    margin: 0;
    padding: 0;
    background-color: {{ background_color }};
    color: {{ text_color }};
    font-family: 'Poppins', sans-serif;
  }
  
  /* Conversion Header Styles */
  {%- if section.settings.enable_conversion_header -%}
  .conversion-header-{{ section.id }} {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background: #ffffff;
    padding: 16px 16px 12px 16px;
    z-index: 9999;
    font-family: var(--font-body-family);
    border-bottom: 1px solid #e5e5e5;
  }
  
  .conversion-content-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-size: 14px;
    line-height: 1.4;
    color: #1a1a1a;
    position: relative;
  }
  
  .metric-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  
  .profit-amount-{{ section.id }} {
    font-weight: 700;
    color: {{ accent_color }};
    font-size: 15px;
  }
  
  .live-indicator-{{ section.id }} {
    width: 6px;
    height: 6px;
    background: {{ accent_color }};
    border-radius: 50%;
    display: inline-block;
    margin-right: 5px;
    animation: pulse-{{ section.id }} 2s ease-in-out infinite;
  }
  
  @keyframes pulse-{{ section.id }} {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }
  
  .divider-{{ section.id }} {
    color: #d4d4d4;
    font-size: 12px;
  }
  
  .time-badge-{{ section.id }} {
    background: #4EA0FF;
    padding: 3px 10px;
    border-radius: 12px;
    font-weight: 600;
    font-size: 13px;
    color: #ffffff;
  }
  
  .member-name-{{ section.id }} {
    font-weight: 600;
    color: #1a1a1a;
  }
  
  .price-increase-{{ section.id }} {
    background: #4EA0FF;
    color: #ffffff;
    padding: 3px 10px;
    border-radius: 12px;
    font-weight: 600;
    font-size: 13px;
  }
  
  .bonus-alert-{{ section.id }} {
    color: {{ accent_color }};
    font-weight: 600;
  }
  
  /* Rotating messages */
  .message-rotate-{{ section.id }} {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    transition: opacity 0.3s ease;
    white-space: nowrap;
  }
  
  .message-hidden-{{ section.id }} {
    opacity: 0;
    pointer-events: none;
  }
  {%- endif -%}
  
  /* Live Sales Notification Styles */
  {%- if section.settings.enable_live_sales -%}
  .sales-notification-{{ section.id }} {
    position: fixed;
    bottom: 20px;
    left: 20px;
    color: {{ text_color }};
    padding: 14px 22px;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 500;
    display: flex;
    align-items: center;
    z-index: 9999;
    max-width: 90vw;
    word-wrap: break-word;
    background: rgba(255, 255, 255, 0.2);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    transform: translateY(20px);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.5s ease, visibility 0.6s;
  }
  
  .sales-notification-{{ section.id }}.sales-visible {
    opacity: 1;
    transform: translateY(0);
    visibility: visible;
    pointer-events: auto;
  }
  
  .sales-notification-{{ section.id }} p {
    margin: 0;
  }
  
  .sales-notification-{{ section.id }} strong {
    font-weight: 700;
    color: {{ accent_color }};
  }
  {%- endif -%}
  
  /* Main content section with customizable padding */
  .main-content-{{ section.id }} {
    background-color: {{ background_color }};
    {%- if section.settings.enable_gradient -%}
    background-image:
      radial-gradient(circle 800px at 10% 15%, {{ gradient_color | color_modify: 'alpha', 0.35 }} 0%, transparent 60%),
      radial-gradient(circle 700px at 80% 25%, {{ gradient_color | color_modify: 'alpha', 0.32 }} 0%, transparent 65%),
      radial-gradient(circle 900px at 90% 85%, {{ gradient_color | color_modify: 'alpha', 0.38 }} 0%, transparent 70%);
    {%- endif -%}
    background-repeat: no-repeat;
    background-size: cover;
    {%- if section.settings.enable_conversion_header -%}
    padding-top: calc({{ section.settings.top_padding }}px + 52px);
    {%- else -%}
    padding-top: {{ section.settings.top_padding }}px;
    {%- endif -%}
    padding-bottom: 60px;
    color: {{ text_color }};
    overflow: hidden;
    position: relative;
  }
  
  /* Custom HTML content styles */
  .large-image-container-{{ section.id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-top: 20px;
    padding: 20px 0;
  }
  
  .large-rounded-image-{{ section.id }} {
    width: 80%;
    max-width: 600px;
    height: auto;
    border-radius: 40px;
    box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.3);
    display: block;
    margin: 0 auto;
  }
  
  .reselling-heading-container-{{ section.id }} {
    text-align: center;
    margin: 40px auto;
    max-width: 800px;
    padding: 0 20px;
  }
  
  .reselling-heading-{{ section.id }} {
    font-size: 28px;
    font-weight: 700;
    color: {{ text_color }};
    margin-bottom: 10px;
  }
  
  .reselling-subheading-{{ section.id }} {
    font-size: 15px;
    font-weight: 550;
    color: {{ text_color | color_modify: 'alpha', 0.9 }};
    line-height: 1.5;
    margin-bottom: 0;
  }
  
  .join-user-container-{{ section.id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
    margin: 40px auto 20px auto;
    width: 100%;
  }
  
  .join-user-tile-{{ section.id }} {
    background: #1A1A1A;
    padding: 4px 20px;
    border-radius: 12px;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 90% !important;
    max-width: 900px;
  }
  
  .join-user-text-{{ section.id }} {
    font-size: 14px;
    font-weight: 600;
    color: {{ text_color }};
    margin-bottom: 12px;
  }
  
  .join-user-image-{{ section.id }} {
    width: 100px;
    height: auto;
    border-radius: 8px;
    margin-bottom: 4px;
  }
  
  .join-user-rating-{{ section.id }} {
    font-size: 18px;
    font-weight: 600;
    color: {{ text_color }};
  }
  
  .stars-{{ section.id }} {
    color: {{ accent_color }};
  }
  
  /* Image slider styles */
  .image-slider-{{ section.id }} {
    width: 100%;
    overflow: hidden;
    position: relative;
    background: transparent;
    padding: 10px 0;
  }
  
  .slider-track-{{ section.id }} {
    display: flex;
    gap: 20px;
    animation: slide-animation-{{ section.id }} 20s linear infinite;
    width: calc(220px * 22);
  }
  
  .slide-{{ section.id }} {
    flex: 0 0 auto;
    width: 220px;
  }
  
  .slide-{{ section.id }} img {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: 10px;
  }
  
  @keyframes slide-animation-{{ section.id }} {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  
  /* Features section */
  .features-section-{{ section.id }} {
    width: 90%;
    max-width: 700px;
    margin: 40px auto;
    padding: 20px;
    background: #1A1A1A;
    border-radius: 12px;
    text-align: left;
  }
  
  .section-title-{{ section.id }} {
    text-align: center;
    font-size: 20px;
    font-weight: 700;
    color: {{ text_color }};
    margin-bottom: 15px;
  }
  
  .features-container-{{ section.id }} {
    padding: 15px 20px;
  }
  
  .features-list-{{ section.id }} {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .features-list-{{ section.id }} li {
    font-size: 14px;
    color: {{ text_color }};
    margin-bottom: 4px;
    padding: 8px 0;
  }
  
  .features-list-{{ section.id }} strong {
    color: {{ accent_color }};
  }
  
  .features-list-{{ section.id }} hr {
    border: none;
    height: 1px;
    background: rgba(255, 255, 255, 0.2);
    margin: 5px 0;
  }
  
  /* Testimonial slider - Updated for continuous sliding */
  .slider-title-{{ section.id }} {
    text-align: center;
    font-size: 18px;
    font-weight: 700;
    color: {{ text_color }};
    margin-bottom: 15px;
  }
  
  .exact-center-slider-container-{{ section.id }} {
    width: 100%;
    max-width: 900px;
    margin: 40px auto;
    position: relative;
    overflow: hidden;
    background: transparent; /* Removed background color */
    padding: 20px 0;
    /* Prevent touch interruption */
    -webkit-touch-callout: none;
    -webkit-user-select: none;
    -khtml-user-select: none;
    -moz-user-select: none;
    -ms-user-select: none;
    user-select: none;
    pointer-events: none;
  }
  
  .exact-center-slider-track-{{ section.id }} {
    display: flex;
    animation: testimonial-slide-{{ section.id }} 15s linear infinite;
    width: fit-content;
    pointer-events: auto;
  }
  
  @keyframes testimonial-slide-{{ section.id }} {
    0% {
      transform: translateX(-50%);
    }
    100% {
      transform: translateX(0);
    }
  }
  
  .exact-center-slider-card-{{ section.id }} {
    flex: 0 0 auto;
    width: 300px;
    margin: 0 10px;
    background: #191919;
    border-radius: 12px;
    padding: 20px;
    text-align: center;
    box-shadow: 0 4px 10px rgba(0,0,0,0.4);
    box-sizing: border-box;
    color: {{ text_color }};
    font-size: 14px;
    line-height: 1.6;
    pointer-events: none;
  }
  
  .testimonial-stars-{{ section.id }} {
    font-size: 18px;
    color: {{ accent_color }};
    margin-bottom: 15px;
  }
  
  /* FAQ Styles */
  .faq-container-{{ section.id }} {
    width: 90%;
    max-width: 700px;
    margin: 40px auto;
    text-align: center;
    position: relative;
    z-index: 10;
  }
  
  .faq-title-{{ section.id }} {
    font-size: 18px;
    font-weight: 700;
    color: {{ text_color }};
    margin-bottom: 20px;
  }
  
  .faq-item-{{ section.id }} {
    margin-bottom: 10px;
    overflow: hidden;
    border-radius: 15px;
    background: #1A1A1A;
    pointer-events: all;
    position: relative;
  }
  
  .faq-question-{{ section.id }} {
    width: 100%;
    padding: 14px;
    font-size: 16px;
    font-weight: 600;
    text-align: left;
    background: transparent;
    color: {{ text_color }};
    border: none;
    cursor: pointer;
    outline: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: background 0.3s;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
    user-select: none;
  }
  
  .faq-question-{{ section.id }}:hover {
    background: #2A2A2A;
  }
  
  .faq-answer-{{ section.id }} {
    max-height: 0;
    overflow: hidden;
    background: transparent;
    color: {{ text_color | color_modify: 'alpha', 0.8 }};
    font-size: 14px;
    text-align: left;
    padding: 0 14px;
    transition: max-height 0.3s ease, padding 0.3s ease, opacity 0.3s ease;
    opacity: 0;
  }
  
  .faq-answer-{{ section.id }} > div {
    padding: 0;
  }
  
  .faq-arrow-{{ section.id }} {
    transition: transform 0.3s ease-in-out;
    font-size: 14px;
    color: {{ text_color | color_modify: 'alpha', 0.8 }};
    line-height: 1;
    display: flex;
    align-items: center;
    flex-shrink: 0;
    margin-left: 10px;
    pointer-events: none;
  }
  
  /* Subscribe buttons */
  .subscribe-container-{{ section.id }} {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    margin-top: 30px;
    margin-bottom: 0;
  }
  
  /* Subscribe buttons below FAQ */
  .subscribe-container-bottom-{{ section.id }} {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    margin-top: 40px;
    margin-bottom: 40px;
  }
  
  .subscribe-button-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 25px;
    font-size: 16px;
    font-weight: 700;
    color: #ffffff;
    background: {{ button_bg_color }} !important;
    border-radius: 12px;
    text-decoration: none;
    border: none;
    transition: all 0.3s ease-in-out;
    text-align: center;
    min-width: 200px;
    box-sizing: border-box;
  }
  
  .subscribe-button-{{ section.id }}:hover {
    cursor: pointer;
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
  }
  
  .subscribe-button-{{ section.id }}:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
  
  .subscribe-button-{{ section.id }}:disabled:hover {
    transform: none;
    box-shadow: none;
  }
  
  .subscribe-image-{{ section.id }} {
    height: 30px;
    width: auto;
    margin-right: 10px;
    border-radius: 6px;
  }
  
  .discord-button-{{ section.id }} {
    margin-top: 15px;
    background: #212121 !important;
  }
  
  /* Reviews section */
  .reviews-container-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 15px;
    background: #101010;
    padding: 25px;
    border-radius: 12px;
    max-width: 750px;
    margin: 40px auto;
  }
  
  .review-item-{{ section.id }} {
    background: #191919;
    padding: 15px;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    display: flex;
    flex-direction: column;
  }
  
  .review-header-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  
  .review-avatar-{{ section.id }} {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    object-fit: cover;
  }
  
  .review-meta-{{ section.id }} {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  
  .review-name-stars-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  
  .review-name-{{ section.id }} {
    font-size: 15px;
    font-weight: 700;
    color: {{ text_color }};
  }
  
  .review-stars-{{ section.id }} {
    font-size: 14px;
    color: {{ accent_color }};
    margin: 0;
  }
  
  .review-text-{{ section.id }} {
    font-size: 14px;
    color: {{ text_color | color_modify: 'alpha', 0.8 }};
    line-height: 1.4;
    margin-top: 8px;
  }
  
  /* Mobile Responsive */
  @media (max-width: 767px) {
    {%- if section.settings.enable_conversion_header -%}
    .conversion-header-{{ section.id }} {
      padding: 10px 10px 8px 10px;
    }
    
    .conversion-content-{{ section.id }} {
      font-size: 13px;
    }
    
    .profit-amount-{{ section.id }} {
      font-size: 14px;
    }
    {%- endif -%}
    
    .main-content-{{ section.id }} {
      {%- if section.settings.enable_conversion_header -%}
      padding-top: calc({{ section.settings.mobile_top_padding }}px + 44px);
      {%- else -%}
      padding-top: {{ section.settings.mobile_top_padding }}px;
      {%- endif -%}
    }
    
    .large-rounded-image-{{ section.id }} {
      width: 90%;
      border-radius: 25px;
    }
    
    .reselling-heading-{{ section.id }} {
      font-size: 24px;
    }
    
    .reselling-subheading-{{ section.id }} {
      font-size: 14px;
    }
    
    .join-user-tile-{{ section.id }} {
      width: 90% !important;
      padding: 8px 15px;
    }
    
    .subscribe-container-{{ section.id }}, .subscribe-container-bottom-{{ section.id }} {
      margin-top: 20px;
    }
    
    .join-user-text-{{ section.id }} {
      font-size: 16px;
    }
    
    .join-user-image-{{ section.id }} {
      width: 290px;
    }
    
    .join-user-rating-{{ section.id }} {
      font-size: 14px;
    }
    
    .features-section-{{ section.id }} {
      width: 90%;
      padding: 12px 16px;
    }
    
    .features-list-{{ section.id }} li {
      font-size: 13px;
    }
    
    {%- if section.settings.enable_live_sales -%}
    .sales-notification-{{ section.id }} {
      left: 10px;
      right: 10px;
      width: auto;
      font-size: 13px;
    }
    {%- endif -%}
    
    .reviews-container-{{ section.id }} {
      padding: 15px;
      max-width: 95%;
    }
    
    .review-item-{{ section.id }} {
      padding: 12px;
    }
    
    .review-avatar-{{ section.id }} {
      width: 45px;
      height: 45px;
    }
    
    .review-text-{{ section.id }} {
      font-size: 13px;
    }
    
    .exact-center-slider-card-{{ section.id }} {
      width: 280px;
      margin: 0 8px;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}">
  {%- if section.settings.enable_conversion_header -%}
  {% comment %} Conversion Header {% endcomment %}
  <div class="conversion-header-{{ section.id }}">
    <div class="conversion-content-{{ section.id }}">
      <!-- Message 1: Recent profit -->
      <div id="message1-{{ section.id }}" class="message-rotate-{{ section.id }}">
        <div class="metric-{{ section.id }}">
          <span class="live-indicator-{{ section.id }}"></span>
          <span><span class="member-name-{{ section.id }}" id="memberName-{{ section.id }}">Tyler K.</span> made <span class="profit-amount-{{ section.id }}" id="profitAmount-{{ section.id }}">$1,847</span> today</span>
          <span class="divider-{{ section.id }}">•</span>
          <span class="time-badge-{{ section.id }}" id="timeAgo-{{ section.id }}">3 mins ago</span>
        </div>
      </div>
      
      <!-- Message 2: Active members -->
      <div id="message2-{{ section.id }}" class="message-rotate-{{ section.id }} message-hidden-{{ section.id }}">
        <div class="metric-{{ section.id }}">
          <span><span style="font-weight: 700;" id="activeMembers-{{ section.id }}">1,247</span> members active now</span>
          <span class="divider-{{ section.id }}">•</span>
          <span>Supplier from IG video</span>
        </div>
      </div>
      
      <!-- Message 3: Price urgency -->
      <div id="message3-{{ section.id }}" class="message-rotate-{{ section.id }} message-hidden-{{ section.id }}">
        <div class="metric-{{ section.id }}">
          <span>Next price increase:</span>
          <span class="price-increase-{{ section.id }}">Tonight at midnight</span>
        </div>
      </div>
      
      <!-- Message 4: Lost opportunity -->
      <div id="message4-{{ section.id }}" class="message-rotate-{{ section.id }} message-hidden-{{ section.id }}">
        <div class="metric-{{ section.id }}">
          <span class="bonus-alert-{{ section.id }}">$<span id="lostAmount-{{ section.id }}">487</span></span>
          <span>lost every day without access</span>
        </div>
      </div>
    </div>
  </div>
  {%- endif -%}

  {%- if section.settings.enable_live_sales -%}
  {% comment %} Live Sales Notification {% endcomment %}
  <div id="sale-notification-{{ section.id }}" class="sales-notification-{{ section.id }}">
    <p>
      <strong id="customer-name-{{ section.id }}"></strong> just purchased the <span id="product-name-{{ section.id }}"></span>!
    </p>
  </div>
  {%- endif -%}

  {% comment %} Main Content Section {% endcomment %}
  <div class="main-content-{{ section.id }}">
    {% comment %} Custom HTML Content {% endcomment %}
    <div class="large-image-container-{{ section.id }}">
      {%- if section.settings.hero_image != blank -%}
        <img src="{{ section.settings.hero_image | image_url: width: 1200 }}"
             alt="{{ section.settings.hero_headline | escape }}"
             class="large-rounded-image-{{ section.id }}">
      {%- else -%}
