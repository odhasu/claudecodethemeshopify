    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#C6A701",
      "info": "Used for text highlights, stars, buttons, and important elements"
    },
    {
      "type": "color",
      "id": "gradient_color",
      "label": "Background Gradient Color",
      "default": "#39ff14",
      "info": "Used for background gradient effects"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Main Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#050208"
