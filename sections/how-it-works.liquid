<style>
  .hiw-section-{{ section.id }} {
    padding: 80px 0;
    background: {{ settings.color_page_bg }};
  }
  .hiw-container-{{ section.id }} {
    max-width: {{ settings.page_max_width }}px;
    margin: 0 auto;
    padding: 0 {{ settings.page_side_padding }}px;
  }
  .hiw-title-{{ section.id }} {
    text-align: center;
    font-size: {{ settings.font_h2_size }}px;
    color: {{ settings.color_text_primary }};
    text-transform: {{ settings.font_heading_transform }};
    font-weight: 700;
    margin: 0 0 60px;
    font-family: {{ settings.font_heading.family }}, {{ settings.font_heading.fallback_families }};
  }
  .hiw-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: {{ settings.grid_gap }}px;
    position: relative;
  }
  .hiw-card-{{ section.id }} {
    background: {{ section.settings.card_bg }};
    border: 1px solid {{ settings.color_border }};
    border-radius: {{ settings.card_radius }}px;
    padding: 36px 24px;
    text-align: center;
    position: relative;
    transition: border-color 0.3s, transform 0.3s;
  }
  .hiw-card-{{ section.id }}:hover {
    border-color: {{ settings.card_hover_border }};
    {% if settings.card_hover_lift %}transform: translateY(-{{ settings.card_hover_lift_amount }}px);{% endif %}
  }
  .hiw-number-{{ section.id }} {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: {{ settings.color_accent }};
    color: #000;
    font-size: 20px;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
  }
  .hiw-icon-{{ section.id }} {
    font-size: 36px;
    margin-bottom: 16px;
    line-height: 1;
  }
  .hiw-step-title-{{ section.id }} {
    font-size: {{ settings.font_h3_size }}px;
    color: {{ settings.color_text_primary }};
    font-weight: 700;
    margin: 0 0 12px;
    text-transform: {{ settings.font_heading_transform }};
    font-family: {{ settings.font_heading.family }}, {{ settings.font_heading.fallback_families }};
  }
  .hiw-desc-{{ section.id }} {
    font-size: {{ settings.font_body_size }}px;
    color: {{ settings.color_text_muted }};
    line-height: {{ settings.font_body_line_height }};
    margin: 0;
  }
  .hiw-connector-{{ section.id }} {
    position: absolute;
    top: 50%;
    right: -{{ settings.grid_gap | divided_by: 2 | plus: 8 }}px;
    transform: translateY(-50%);
    display: flex;
    gap: 4px;
  }
  .hiw-connector-{{ section.id }} span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: {{ settings.color_accent }};
    opacity: 0.5;
  }
  .hiw-card-{{ section.id }}:last-child .hiw-connector-{{ section.id }} {
    display: none;
  }
  @media (max-width: 1024px) {
    .hiw-grid-{{ section.id }} {
      grid-template-columns: repeat(2, 1fr);
    }
    .hiw-connector-{{ section.id }} {
      display: none;
    }
  }
  @media (max-width: 600px) {
    .hiw-grid-{{ section.id }} {
      grid-template-columns: 1fr;
    }
    .hiw-title-{{ section.id }} {
      font-size: {{ settings.font_h1_mobile_size }}px;
    }
    .hiw-section-{{ section.id }} {
      padding: 48px 0;
    }
  }
</style>

<section class="hiw-section-{{ section.id }}">
  <div class="hiw-container-{{ section.id }}">
    {% if section.settings.title != blank %}
      <h2 class="hiw-title-{{ section.id }}">{{ section.settings.title }}</h2>
    {% endif %}

    <div class="hiw-grid-{{ section.id }}">
      {% for block in section.blocks %}
        {% if block.type == 'step' %}
          <div class="hiw-card-{{ section.id }}" {{ block.shopify_attributes }}>
            {% if section.settings.show_numbers %}
              <div class="hiw-number-{{ section.id }}">{{ block.settings.number }}</div>
            {% endif %}
            {% if block.settings.icon_text != blank %}
              <div class="hiw-icon-{{ section.id }}">{{ block.settings.icon_text }}</div>
            {% endif %}
            <h3 class="hiw-step-title-{{ section.id }}">{{ block.settings.title }}</h3>
            <p class="hiw-desc-{{ section.id }}">{{ block.settings.description }}</p>

            <div class="hiw-connector-{{ section.id }}">
              <span></span><span></span><span></span>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "How It Works",
  "tag": "section",
  "class": "section-how-it-works",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "How It Works"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_numbers",
      "label": "Show step numbers",
      "default": true
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#1a1a1a"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Step number",
          "default": "1"
        },
        {
          "type": "text",
          "id": "icon_text",
          "label": "Icon emoji or text",
          "default": "📋"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Step title",
          "default": "Choose Plan"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Browse our vendor list packages and choose the plan that fits your needs."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How It Works",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "number": "1",
            "icon_text": "📋",
            "title": "Choose Plan",
            "description": "Browse our vendor list packages and choose the plan that fits your needs and budget."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "2",
            "icon_text": "🔓",
            "title": "Get Access",
            "description": "Receive instant access to your vendor list with direct contact information and pricing."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "3",
            "icon_text": "🔍",
            "title": "Find Vendors",
            "description": "Connect with verified wholesale vendors and suppliers offering the best prices."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "4",
            "icon_text": "💰",
            "title": "Start Selling",
            "description": "Source products at wholesale prices and start your reselling business today."
          }
        }
      ]
    }
  ]
}
{% endschema %}
