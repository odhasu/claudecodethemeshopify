{%- liquid
  assign title_before = section.settings.title_before | default: 'START YOUR'
  assign title_highlight = section.settings.title_highlight | default: 'RESELLING'
  assign title_after = section.settings.title_after | default: 'JOURNEY TODAY'
  assign title_color = section.settings.title_color | default: '#ffffff'
  assign highlight_color = section.settings.highlight_color | default: '#19d400'
  assign title_size_desktop = section.settings.title_size_desktop | default: 110
  assign title_size_mobile = section.settings.title_size_mobile | default: 42
  assign hero_font = section.settings.hero_font | default: 'Clash Grotesk'
  assign bg_gradient_strength = section.settings.bg_gradient_strength | default: 40
  assign bg_image_position = section.settings.bg_image_position | default: 'center center'
  assign btn_1_text = section.settings.btn_1_text | default: 'BUY NOW'
  assign btn_1_bg = section.settings.btn_1_bg | default: '#19d400'
  assign btn_1_text_color = section.settings.btn_1_text_color | default: '#000000'
  assign btn_1_action = section.settings.btn_1_action | default: 'scroll'
  assign btn_2_text = section.settings.btn_2_text | default: 'ADD TO CART'
  assign btn_2_bg = section.settings.btn_2_bg | default: '#000000'
  assign btn_2_text_color = section.settings.btn_2_text_color | default: '#ffffff'
  assign btn_2_action = section.settings.btn_2_action | default: 'scroll'
  assign btn_layout = section.settings.btn_layout | default: 'side-by-side'
  assign trust_prefix = section.settings.trust_prefix | default: 'Trusted By'
  assign trust_count = section.settings.trust_count | default: '10,000+'
  assign trust_suffix = section.settings.trust_suffix | default: 'Resellers'
  assign trust_count_color = section.settings.trust_count_color | default: '#fbbf24'
  assign trust_text_color = section.settings.trust_text_color | default: '#9ca3af'
  assign trust_font_size = section.settings.trust_font_size | default: 15
  assign avatar_size = section.settings.avatar_size | default: 36
  assign glow_color = section.settings.glow_color | default: '#19d400'
  assign padding_top = section.settings.padding_top | default: 80
  assign padding_bottom = section.settings.padding_bottom | default: 60
-%}

<style>
  #shopify-section-{{ section.id }} .hero-section {
    position: relative;
    width: 100%;
    padding: {{ padding_top }}px 20px {{ padding_bottom }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: var(--color-bg, #000);
  }

  #shopify-section-{{ section.id }} .hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: {{ bg_image_position }};
    background-repeat: no-repeat;
    z-index: 0;
  }

  #shopify-section-{{ section.id }} .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      rgba(0, 0, 0, {{ bg_gradient_strength | divided_by: 100.0 }}),
      rgba(0, 0, 0, {{ bg_gradient_strength | divided_by: 100.0 }})
    );
    z-index: 1;
  }

  {% if section.settings.show_glow %}
  #shopify-section-{{ section.id }} .hero-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, {{ glow_color }}1a 0%, transparent 70%);
    pointer-events: none;
    z-index: 1;
  }
  {% endif %}

  #shopify-section-{{ section.id }} .hero-content {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    width: 100%;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .hero-title {
    font-family: '{{ hero_font }}', var(--font-heading), sans-serif;
    font-weight: 700;
    font-size: {{ title_size_desktop }}px;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 0 40px;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .hero-title-line {
    display: block;
    color: {{ title_color }};
  }

  #shopify-section-{{ section.id }} .hero-title-highlight {
    display: block;
    color: {{ highlight_color }};
    text-shadow: 0 0 40px {{ highlight_color }}66, 0 0 80px {{ highlight_color }}33;
  }

  #shopify-section-{{ section.id }} .hero-buttons {
    display: flex;
    flex-direction: {% if btn_layout == 'stacked' %}column{% else %}row{% endif %};
    gap: 12px;
    justify-content: center;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .hero-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 15px;
    padding: 16px 40px;
    border-radius: 8px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-decoration: none;
    cursor: pointer;
    transition: opacity 0.2s, border-color 0.2s, transform 0.2s;
    border: 1px solid transparent;
    font-family: var(--font-body, 'Satoshi'), sans-serif;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .hero-btn:hover {
    transform: translateY(-1px);
  }

  #shopify-section-{{ section.id }} .hero-btn--primary {
    background: {{ btn_1_bg }};
    color: {{ btn_1_text_color }};
    border-color: {{ btn_1_bg }};
  }

  #shopify-section-{{ section.id }} .hero-btn--primary:hover {
    opacity: 0.9;
  }

  #shopify-section-{{ section.id }} .hero-btn--secondary {
    background: {{ btn_2_bg }};
    color: {{ btn_2_text_color }};
    border-color: #333;
  }

  #shopify-section-{{ section.id }} .hero-btn--secondary:hover {
    border-color: #fff;
  }

  #shopify-section-{{ section.id }} .hero-trust {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-top: 32px;
  }

  #shopify-section-{{ section.id }} .hero-avatars {
    display: flex;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .hero-avatar {
    width: {{ avatar_size }}px;
    height: {{ avatar_size }}px;
    border-radius: 50%;
    border: 2px solid #000;
    object-fit: cover;
    background: #333;
  }

  #shopify-section-{{ section.id }} .hero-avatar + .hero-avatar {
    margin-left: -8px;
  }

  #shopify-section-{{ section.id }} .hero-avatar-placeholder {
    width: {{ avatar_size }}px;
    height: {{ avatar_size }}px;
    border-radius: 50%;
    border: 2px solid #000;
    background: linear-gradient(135deg, #333, #555);
  }

  #shopify-section-{{ section.id }} .hero-avatar-placeholder + .hero-avatar-placeholder,
  #shopify-section-{{ section.id }} .hero-avatar + .hero-avatar-placeholder,
  #shopify-section-{{ section.id }} .hero-avatar-placeholder + .hero-avatar {
    margin-left: -8px;
  }

  #shopify-section-{{ section.id }} .hero-trust-text {
    font-size: {{ trust_font_size }}px;
    color: {{ trust_text_color }};
    font-family: var(--font-body, 'Satoshi'), sans-serif;
  }

  #shopify-section-{{ section.id }} .hero-trust-count {
    color: {{ trust_count_color }};
    font-weight: 600;
  }

  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .hero-title {
      font-size: {{ title_size_mobile }}px;
    }

    #shopify-section-{{ section.id }} .hero-buttons {
      flex-direction: column;
      width: 100%;
    }

    #shopify-section-{{ section.id }} .hero-btn {
      width: 100%;
    }

    #shopify-section-{{ section.id }} .hero-trust {
      flex-direction: column;
      gap: 8px;
    }
  }
</style>

<div class="hero-section">
  {%- if section.settings.bg_image != blank -%}
    <div class="hero-bg" style="background-image: url('{{ section.settings.bg_image | image_url: width: 1920 }}');"></div>
  {%- endif -%}

  {%- if section.settings.show_glow -%}
    <div class="hero-glow"></div>
  {%- endif -%}

  <div class="hero-content">
    <h1 class="hero-title">
      {%- if title_before != blank -%}
        <span class="hero-title-line">{{ title_before }}</span>
      {%- endif -%}
      {%- if title_highlight != blank -%}
        <span class="hero-title-highlight">{{ title_highlight }}</span>
      {%- endif -%}
      {%- if title_after != blank -%}
        <span class="hero-title-line">{{ title_after }}</span>
      {%- endif -%}
    </h1>

    {%- if section.settings.show_btn_1 or section.settings.show_btn_2 -%}
      <div class="hero-buttons">
        {%- if section.settings.show_btn_1 -%}
          <a
            class="hero-btn hero-btn--primary"
            href="{{ section.settings.btn_1_url | default: '#' }}"
            data-hero-btn-action="{{ btn_1_action }}"
          >
            {{ btn_1_text }}
          </a>
        {%- endif -%}

        {%- if section.settings.show_btn_2 -%}
          <a
            class="hero-btn hero-btn--secondary"
            href="{{ section.settings.btn_2_url | default: '#' }}"
            data-hero-btn-action="{{ btn_2_action }}"
          >
            {{ btn_2_text }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="hero-trust">
      {%- if section.settings.show_avatars -%}
        <div class="hero-avatars">
          {%- for i in (1..10) -%}
            {%- assign avatar_key = 'avatar_' | append: i -%}
            {%- assign avatar_img = section.settings[avatar_key] -%}
            {%- if avatar_img != blank -%}
              <img
                class="hero-avatar"
                src="{{ avatar_img | image_url: width: 72 }}"
                alt="User avatar"
                width="{{ avatar_size }}"
                height="{{ avatar_size }}"
                loading="lazy"
              >
            {%- else -%}
              {%- if i <= 4 -%}
                <div class="hero-avatar-placeholder"></div>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      <span class="hero-trust-text">
        {{ trust_prefix }} <span class="hero-trust-count">{{ trust_count }}</span> {{ trust_suffix }}
      </span>
    </div>
  </div>
</div>

<script>
  (function() {
    var section = document.getElementById('shopify-section-{{ section.id }}');
    if (!section) return;

    section.querySelectorAll('[data-hero-btn-action]').forEach(function(btn) {
      var action = btn.getAttribute('data-hero-btn-action');

      if (action === 'scroll') {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          var productGrid = document.querySelector('[data-section-type="product-grid"], .product-grid-section');
          if (productGrid) {
            productGrid.scrollIntoView({ behavior: 'smooth', block: 'start' });
          } else {
            var nextSection = section.nextElementSibling;
            if (nextSection) {
              nextSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
          }
        });
      } else if (action === 'checkout') {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          fetch('/cart.js')
            .then(function(r) { return r.json(); })
            .then(function(cart) {
              if (cart.items && cart.items.length > 0) {
                window.location.href = '/checkout';
              } else {
                var firstProduct = document.querySelector('[data-product-variant-id]');
                if (firstProduct) {
                  var variantId = firstProduct.getAttribute('data-product-variant-id');
                  window.location.href = '/cart/' + variantId + ':1';
                }
              }
            });
        });
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Font" },
    { "type": "select", "id": "hero_font", "label": "Hero font", "default": "Clash Grotesk", "options": [
      { "value": "Clash Grotesk", "label": "Clash Grotesk (heading font)" },
      { "value": "Satoshi", "label": "Satoshi (body font)" }
    ]},
    { "type": "header", "content": "Background Image" },
    { "type": "image_picker", "id": "bg_image", "label": "Hero background image" },
    { "type": "range", "id": "bg_gradient_strength", "label": "Gradient overlay strength (%)", "min": 0, "max": 100, "step": 5, "default": 40 },
    { "type": "select", "id": "bg_image_position", "label": "Image position", "default": "center center", "options": [
      { "value": "center center", "label": "Center" },
      { "value": "center top", "label": "Top" },
      { "value": "center bottom", "label": "Bottom" },
      { "value": "left center", "label": "Left" },
      { "value": "right center", "label": "Right" }
    ]},
    { "type": "header", "content": "Headline" },
    { "type": "text", "id": "title_before", "label": "Text before highlight", "default": "START YOUR" },
    { "type": "text", "id": "title_highlight", "label": "Highlighted word(s)", "default": "RESELLING" },
    { "type": "text", "id": "title_after", "label": "Text after highlight", "default": "JOURNEY TODAY" },
    { "type": "color", "id": "title_color", "label": "Title color", "default": "#ffffff" },
    { "type": "color", "id": "highlight_color", "label": "Highlight color", "default": "#19d400" },
    { "type": "range", "id": "title_size_desktop", "label": "Title size desktop (px)", "min": 24, "max": 140, "step": 2, "default": 110 },
    { "type": "range", "id": "title_size_mobile", "label": "Title size mobile (px)", "min": 18, "max": 72, "step": 2, "default": 42 },
    { "type": "header", "content": "CTA Buttons" },
    { "type": "checkbox", "id": "show_btn_1", "label": "Show button 1", "default": true },
    { "type": "text", "id": "btn_1_text", "label": "Button 1 text", "default": "BUY NOW" },
    { "type": "url", "id": "btn_1_url", "label": "Button 1 link" },
    { "type": "select", "id": "btn_1_action", "label": "Button 1 action", "default": "scroll", "options": [
      { "value": "scroll", "label": "Scroll to products" },
      { "value": "link", "label": "Go to URL" },
      { "value": "checkout", "label": "First product checkout" }
    ]},
    { "type": "color", "id": "btn_1_bg", "label": "Button 1 background", "default": "#19d400" },
    { "type": "color", "id": "btn_1_text_color", "label": "Button 1 text color", "default": "#000000" },
    { "type": "checkbox", "id": "show_btn_2", "label": "Show button 2", "default": true },
    { "type": "text", "id": "btn_2_text", "label": "Button 2 text", "default": "ADD TO CART" },
    { "type": "url", "id": "btn_2_url", "label": "Button 2 link" },
    { "type": "select", "id": "btn_2_action", "label": "Button 2 action", "default": "scroll", "options": [
      { "value": "scroll", "label": "Scroll to products" },
      { "value": "link", "label": "Go to URL" },
      { "value": "checkout", "label": "First product checkout" }
    ]},
    { "type": "color", "id": "btn_2_bg", "label": "Button 2 background", "default": "#000000" },
    { "type": "color", "id": "btn_2_text_color", "label": "Button 2 text color", "default": "#ffffff" },
    { "type": "select", "id": "btn_layout", "label": "Button layout", "default": "side-by-side", "options": [
      { "value": "side-by-side", "label": "Side by side" },
      { "value": "stacked", "label": "Stacked" }
    ]},
    { "type": "header", "content": "Trust Line" },
    { "type": "text", "id": "trust_prefix", "label": "Trust prefix", "default": "Trusted By" },
    { "type": "text", "id": "trust_count", "label": "Trust count", "default": "10,000+" },
    { "type": "text", "id": "trust_suffix", "label": "Trust suffix", "default": "Resellers" },
    { "type": "color", "id": "trust_count_color", "label": "Count color", "default": "#fbbf24" },
    { "type": "color", "id": "trust_text_color", "label": "Trust text color", "default": "#9ca3af" },
    { "type": "range", "id": "trust_font_size", "label": "Trust font size (px)", "min": 12, "max": 22, "step": 1, "default": 15 },
    { "type": "header", "content": "Avatars" },
    { "type": "checkbox", "id": "show_avatars", "label": "Show avatar stack", "default": true },
    { "type": "range", "id": "avatar_size", "label": "Avatar size (px)", "min": 24, "max": 56, "step": 2, "default": 36 },
    { "type": "image_picker", "id": "avatar_1", "label": "Avatar 1" },
    { "type": "image_picker", "id": "avatar_2", "label": "Avatar 2" },
    { "type": "image_picker", "id": "avatar_3", "label": "Avatar 3" },
    { "type": "image_picker", "id": "avatar_4", "label": "Avatar 4" },
    { "type": "image_picker", "id": "avatar_5", "label": "Avatar 5" },
    { "type": "image_picker", "id": "avatar_6", "label": "Avatar 6" },
    { "type": "image_picker", "id": "avatar_7", "label": "Avatar 7" },
    { "type": "image_picker", "id": "avatar_8", "label": "Avatar 8" },
    { "type": "image_picker", "id": "avatar_9", "label": "Avatar 9" },
    { "type": "image_picker", "id": "avatar_10", "label": "Avatar 10" },
    { "type": "header", "content": "Glow Effect" },
    { "type": "checkbox", "id": "show_glow", "label": "Show green glow", "default": true },
    { "type": "color", "id": "glow_color", "label": "Glow color", "default": "#19d400" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Top padding (px)", "min": 20, "max": 160, "step": 10, "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding (px)", "min": 20, "max": 160, "step": 10, "default": 60 }
  ],
  "presets": [
    { "name": "Hero" }
  ]
}
{% endschema %}
