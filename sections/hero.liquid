<section class="vx-shell vx-shell--loading" data-vx-section="hero">
  <div class="vx-editor-preview"><div class="vx-section-loader"><div class="vx-loader__spinner"></div></div></div>
</section>

<script type="application/json" data-vx-settings="hero">
{
  "hero_font": {{ section.settings.hero_font | default: 'Clash Grotesk' | json }},
  "title_before": {{ section.settings.title_before | default: 'START YOUR' | json }},
  "title_highlight": {{ section.settings.title_highlight | default: 'RESELLING' | json }},
  "title_after": {{ section.settings.title_after | default: 'JOURNEY TODAY' | json }},
  "title_color": {{ section.settings.title_color | default: '#ffffff' | json }},
  "highlight_color": {{ section.settings.highlight_color | default: '#19d400' | json }},
  "title_size_desktop": {{ section.settings.title_size_desktop | default: 110 }},
  "title_size_mobile": {{ section.settings.title_size_mobile | default: 42 }},
  "bg_image": {% if section.settings.bg_image != blank %}{{ section.settings.bg_image | image_url: width: 1920 | json }}{% else %}null{% endif %},
  "bg_gradient_strength": {{ section.settings.bg_gradient_strength | default: 40 }},
  "bg_image_position": {{ section.settings.bg_image_position | default: 'center center' | json }},
  "show_btn_1": {{ section.settings.show_btn_1 | json }},
  "btn_1_text": {{ section.settings.btn_1_text | default: 'BUY NOW' | json }},
  "btn_1_url": {{ section.settings.btn_1_url | default: '' | json }},
  "btn_1_action": {{ section.settings.btn_1_action | default: 'scroll' | json }},
  "btn_1_bg": {{ section.settings.btn_1_bg | default: '#19d400' | json }},
  "btn_1_text_color": {{ section.settings.btn_1_text_color | default: '#000000' | json }},
  "show_btn_2": {{ section.settings.show_btn_2 | json }},
  "btn_2_text": {{ section.settings.btn_2_text | default: 'ADD TO CART' | json }},
  "btn_2_url": {{ section.settings.btn_2_url | default: '' | json }},
  "btn_2_action": {{ section.settings.btn_2_action | default: 'scroll' | json }},
  "btn_2_bg": {{ section.settings.btn_2_bg | default: 'transparent' | json }},
  "btn_2_text_color": {{ section.settings.btn_2_text_color | default: '#ffffff' | json }},
  "btn_layout": {{ section.settings.btn_layout | default: 'side-by-side' | json }},
  "trust_prefix": {{ section.settings.trust_prefix | default: 'Trusted By' | json }},
  "trust_count": {{ section.settings.trust_count | default: '10,000+' | json }},
  "trust_suffix": {{ section.settings.trust_suffix | default: 'Resellers' | json }},
  "trust_count_color": {{ section.settings.trust_count_color | default: '#fbbf24' | json }},
  "trust_text_color": {{ section.settings.trust_text_color | default: '#9ca3af' | json }},
  "trust_font_size": {{ section.settings.trust_font_size | default: 15 }},
  "show_avatars": {{ section.settings.show_avatars | json }},
  "avatar_size": {{ section.settings.avatar_size | default: 36 }},
  "avatar_1": {% if section.settings.avatar_1 != blank %}{{ section.settings.avatar_1 | image_url: width: 72 | json }}{% else %}null{% endif %},
  "avatar_2": {% if section.settings.avatar_2 != blank %}{{ section.settings.avatar_2 | image_url: width: 72 | json }}{% else %}null{% endif %},
  "avatar_3": {% if section.settings.avatar_3 != blank %}{{ section.settings.avatar_3 | image_url: width: 72 | json }}{% else %}null{% endif %},
  "avatar_4": {% if section.settings.avatar_4 != blank %}{{ section.settings.avatar_4 | image_url: width: 72 | json }}{% else %}null{% endif %},
  "avatar_5": {% if section.settings.avatar_5 != blank %}{{ section.settings.avatar_5 | image_url: width: 72 | json }}{% else %}null{% endif %},
  "avatar_6": {% if section.settings.avatar_6 != blank %}{{ section.settings.avatar_6 | image_url: width: 72 | json }}{% else %}null{% endif %},
  "avatar_7": {% if section.settings.avatar_7 != blank %}{{ section.settings.avatar_7 | image_url: width: 72 | json }}{% else %}null{% endif %},
  "avatar_8": {% if section.settings.avatar_8 != blank %}{{ section.settings.avatar_8 | image_url: width: 72 | json }}{% else %}null{% endif %},
  "avatar_9": {% if section.settings.avatar_9 != blank %}{{ section.settings.avatar_9 | image_url: width: 72 | json }}{% else %}null{% endif %},
  "avatar_10": {% if section.settings.avatar_10 != blank %}{{ section.settings.avatar_10 | image_url: width: 72 | json }}{% else %}null{% endif %},
  "show_glow": {{ section.settings.show_glow | json }},
  "glow_color": {{ section.settings.glow_color | default: '#19d400' | json }},
  "padding_top": {{ section.settings.padding_top | default: 80 }},
  "padding_bottom": {{ section.settings.padding_bottom | default: 60 }}
}
</script>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Font" },
    { "type": "select", "id": "hero_font", "label": "Hero font", "default": "Clash Grotesk", "options": [
      { "value": "Clash Grotesk", "label": "Clash Grotesk (heading font)" },
      { "value": "Satoshi", "label": "Satoshi (body font)" }
    ]},
    { "type": "header", "content": "Background Image" },
    { "type": "image_picker", "id": "bg_image", "label": "Hero background image" },
    { "type": "range", "id": "bg_gradient_strength", "label": "Gradient overlay strength (%)", "min": 0, "max": 100, "step": 5, "default": 40 },
    { "type": "select", "id": "bg_image_position", "label": "Image position", "default": "center center", "options": [
      { "value": "center center", "label": "Center" },
      { "value": "center top", "label": "Top" },
      { "value": "center bottom", "label": "Bottom" },
      { "value": "left center", "label": "Left" },
      { "value": "right center", "label": "Right" }
    ]},
    { "type": "header", "content": "Headline" },
    { "type": "text", "id": "title_before", "label": "Text before highlight", "default": "START YOUR" },
    { "type": "text", "id": "title_highlight", "label": "Highlighted word(s)", "default": "RESELLING" },
    { "type": "text", "id": "title_after", "label": "Text after highlight", "default": "JOURNEY TODAY" },
    { "type": "color", "id": "title_color", "label": "Title color", "default": "#ffffff" },
    { "type": "color", "id": "highlight_color", "label": "Highlight color", "default": "#19d400" },
    { "type": "range", "id": "title_size_desktop", "label": "Title size desktop (px)", "min": 24, "max": 140, "step": 2, "default": 110 },
    { "type": "range", "id": "title_size_mobile", "label": "Title size mobile (px)", "min": 18, "max": 72, "step": 2, "default": 42 },
    { "type": "header", "content": "CTA Buttons" },
    { "type": "checkbox", "id": "show_btn_1", "label": "Show button 1", "default": true },
    { "type": "text", "id": "btn_1_text", "label": "Button 1 text", "default": "BUY NOW" },
    { "type": "url", "id": "btn_1_url", "label": "Button 1 link" },
    { "type": "select", "id": "btn_1_action", "label": "Button 1 action", "default": "scroll", "options": [
      { "value": "scroll", "label": "Scroll to products" },
      { "value": "link", "label": "Go to URL" },
      { "value": "checkout", "label": "First product checkout" }
    ]},
    { "type": "color", "id": "btn_1_bg", "label": "Button 1 background", "default": "#19d400" },
    { "type": "color", "id": "btn_1_text_color", "label": "Button 1 text color", "default": "#000000" },
    { "type": "checkbox", "id": "show_btn_2", "label": "Show button 2", "default": true },
    { "type": "text", "id": "btn_2_text", "label": "Button 2 text", "default": "ADD TO CART" },
    { "type": "url", "id": "btn_2_url", "label": "Button 2 link" },
    { "type": "select", "id": "btn_2_action", "label": "Button 2 action", "default": "scroll", "options": [
      { "value": "scroll", "label": "Scroll to products" },
      { "value": "link", "label": "Go to URL" },
      { "value": "checkout", "label": "First product checkout" }
    ]},
    { "type": "color", "id": "btn_2_bg", "label": "Button 2 background", "default": "#000000" },
    { "type": "color", "id": "btn_2_text_color", "label": "Button 2 text color", "default": "#ffffff" },
    { "type": "select", "id": "btn_layout", "label": "Button layout", "default": "side-by-side", "options": [
      { "value": "side-by-side", "label": "Side by side" },
      { "value": "stacked", "label": "Stacked" }
    ]},
    { "type": "header", "content": "Trust Line" },
    { "type": "text", "id": "trust_prefix", "label": "Trust prefix", "default": "Trusted By" },
    { "type": "text", "id": "trust_count", "label": "Trust count", "default": "10,000+" },
    { "type": "text", "id": "trust_suffix", "label": "Trust suffix", "default": "Resellers" },
    { "type": "color", "id": "trust_count_color", "label": "Count color", "default": "#fbbf24" },
    { "type": "color", "id": "trust_text_color", "label": "Trust text color", "default": "#9ca3af" },
    { "type": "range", "id": "trust_font_size", "label": "Trust font size (px)", "min": 12, "max": 22, "step": 1, "default": 15 },
    { "type": "header", "content": "Avatars" },
    { "type": "checkbox", "id": "show_avatars", "label": "Show avatar stack", "default": true },
    { "type": "range", "id": "avatar_size", "label": "Avatar size (px)", "min": 24, "max": 56, "step": 2, "default": 36 },
    { "type": "image_picker", "id": "avatar_1", "label": "Avatar 1" },
    { "type": "image_picker", "id": "avatar_2", "label": "Avatar 2" },
    { "type": "image_picker", "id": "avatar_3", "label": "Avatar 3" },
    { "type": "image_picker", "id": "avatar_4", "label": "Avatar 4" },
    { "type": "image_picker", "id": "avatar_5", "label": "Avatar 5" },
    { "type": "image_picker", "id": "avatar_6", "label": "Avatar 6" },
    { "type": "image_picker", "id": "avatar_7", "label": "Avatar 7" },
    { "type": "image_picker", "id": "avatar_8", "label": "Avatar 8" },
    { "type": "image_picker", "id": "avatar_9", "label": "Avatar 9" },
    { "type": "image_picker", "id": "avatar_10", "label": "Avatar 10" },
    { "type": "header", "content": "Glow Effect" },
    { "type": "checkbox", "id": "show_glow", "label": "Show green glow", "default": true },
    { "type": "color", "id": "glow_color", "label": "Glow color", "default": "#19d400" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Top padding (px)", "min": 20, "max": 160, "step": 10, "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding (px)", "min": 20, "max": 160, "step": 10, "default": 60 }
  ],
  "presets": [
    { "name": "Hero" }
  ]
}
{% endschema %}
