{%- liquid
  assign show_badge        = section.settings.show_badge
  assign badge_text        = section.settings.badge_text        | default: '#1 Reselling Education Platform'
  assign title_before      = section.settings.title_before      | default: 'START YOUR'
  assign title_highlight   = section.settings.title_highlight   | default: 'RESELLING'
  assign title_after       = section.settings.title_after       | default: 'JOURNEY TODAY'
  assign highlight_color   = section.settings.highlight_color   | default: settings.color_accent | default: '#19d400'
  assign title_color       = section.settings.title_color       | default: '#ffffff'
  assign title_size_desktop = section.settings.title_size_desktop | default: 90
  assign title_size_mobile  = section.settings.title_size_mobile  | default: 48
  assign show_subtitle     = section.settings.show_subtitle
  assign subtitle          = section.settings.subtitle          | default: 'Access 100+ verified vendors, exclusive guides, and a community of resellers making real money — starting today.'
  assign subtitle_color    = section.settings.subtitle_color    | default: '#9ca3af'
  assign subtitle_size     = section.settings.subtitle_size     | default: 18
  assign show_cta          = section.settings.show_cta
  assign cta_primary_text  = section.settings.cta_primary_text  | default: 'Browse Products'
  assign cta_primary_url   = section.settings.cta_primary_url   | default: '/collections/all'
  assign cta_primary_bg    = section.settings.cta_primary_bg    | default: '#19d400'
  assign cta_primary_color = section.settings.cta_primary_color | default: '#000000'
  assign cta_secondary_text = section.settings.cta_secondary_text | default: 'See Results'
  assign cta_secondary_url  = section.settings.cta_secondary_url  | default: '#results'
  assign show_trust        = section.settings.show_trust
  assign show_avatars      = section.settings.show_avatars
  assign trust_count       = section.settings.trust_count       | default: '10,000+'
  assign trust_label       = section.settings.trust_label       | default: 'resellers trust us'
  assign trust_count_color = section.settings.trust_count_color | default: '#fbbf24'
  assign trust_text_color  = section.settings.trust_text_color  | default: '#9ca3af'
  assign show_stars        = section.settings.show_stars
  assign star_rating       = section.settings.star_rating       | default: '4.9'
  assign star_review_label = section.settings.star_review_label | default: '2,400+ reviews'
  assign show_stats        = section.settings.show_stats
  assign stat_1_value      = section.settings.stat_1_value      | default: '$300K+'
  assign stat_1_label      = section.settings.stat_1_label      | default: 'Customer Sales'
  assign stat_2_value      = section.settings.stat_2_value      | default: '10,000+'
  assign stat_2_label      = section.settings.stat_2_label      | default: 'Orders Fulfilled'
  assign stat_3_value      = section.settings.stat_3_value      | default: '100+'
  assign stat_3_label      = section.settings.stat_3_label      | default: 'Verified Vendors'
  assign stat_value_color  = section.settings.stat_value_color  | default: '#ffffff'
  assign show_glow         = section.settings.show_glow
  assign glow_color        = section.settings.glow_color        | default: '#19d400'
  assign glow_size         = section.settings.glow_size         | default: 700
  assign padding_top       = section.settings.padding_top       | default: 100
  assign padding_bottom    = section.settings.padding_bottom    | default: 80
-%}

<style>
  .hero {
    position: relative;
    overflow: hidden;
    text-align: center;
    padding: {{ padding_top }}px 20px {{ padding_bottom }}px;
    background: var(--color-bg, #000);
  }

  {%- if show_glow -%}
  .hero::before {
    content: '';
    position: absolute;
    top: 0; left: 50%;
    width: {{ glow_size }}px;
    height: {{ glow_size }}px;
    transform: translate(-50%, -40%);
    background: radial-gradient(ellipse at center, {{ glow_color }}18 0%, {{ glow_color }}05 45%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  @media (max-width: 768px) {
    .hero::before {
      width: 340px; height: 340px;
    }
  }
  {%- endif -%}

  .hero__inner {
    position: relative;
    z-index: 1;
    max-width: var(--max-width, 1200px);
    margin: 0 auto;
  }

  /* Badge */
  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border: 1px solid {{ highlight_color }}40;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: {{ highlight_color }};
    background: {{ highlight_color }}0d;
    margin-bottom: 28px;
  }
  .hero__badge-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: {{ highlight_color }};
    animation: heroBadgePulse 2s ease-in-out infinite;
  }
  @keyframes heroBadgePulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* Headline */
  .hero__title {
    font-family: var(--font-heading, 'Anton', sans-serif);
    font-size: clamp({{ title_size_mobile }}px, 8vw, {{ title_size_desktop }}px);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -1.5px;
    line-height: 1.05;
    color: {{ title_color }};
    margin: 0 0 28px;
  }
  .hero__title-line { display: block; }
  .hero__title-highlight {
    background: linear-gradient(135deg, {{ highlight_color }}, {{ highlight_color }}bb);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Subtitle */
  .hero__subtitle {
    font-size: clamp(15px, 2vw, {{ subtitle_size }}px);
    color: {{ subtitle_color }};
    line-height: 1.65;
    max-width: 580px;
    margin: 0 auto 36px;
  }

  /* CTA buttons */
  .hero__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 44px;
  }
  .hero__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: var(--radius-button, 8px);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.02em;
    transition: transform 0.15s ease, opacity 0.15s ease, box-shadow 0.15s ease;
    text-decoration: none;
    white-space: nowrap;
  }
  .hero__btn:hover { transform: translateY(-2px); }
  .hero__btn--primary {
    background: {{ cta_primary_bg }};
    color: {{ cta_primary_color }};
  }
  .hero__btn--primary:hover {
    opacity: 0.9;
  }
  .hero__btn--secondary {
    background: transparent;
    color: #fff;
    border: 1px solid #ffffff30;
  }
  .hero__btn--secondary:hover {
    border-color: #ffffff70;
    background: #ffffff08;
  }
  .hero__btn-arrow {
    font-size: 16px;
    transition: transform 0.15s ease;
  }
  .hero__btn--primary:hover .hero__btn-arrow { transform: translateX(3px); }

  /* Trust row */
  .hero__trust {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    margin-bottom: 52px;
    width: 100%;
  }
  .hero__trust-label {
    font-size: 13px;
    color: {{ trust_text_color }};
    text-align: center;
    width: 100%;
  }
  .hero__trust-label strong {
    color: {{ trust_count_color }};
    font-weight: 700;
  }
  .hero__trust-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  /* Avatars */
  .hero__avatars {
    display: flex;
    align-items: center;
  }
  .hero__avatar {
    width: 32px; height: 32px;
    border-radius: 50%;
    border: 2px solid var(--color-bg, #000);
    margin-left: -8px;
    overflow: hidden;
    flex-shrink: 0;
    background: #1a1a1a;
  }
  .hero__avatar:first-child { margin-left: 0; }
  .hero__avatar img {
    width: 100%; height: 100%;
    object-fit: cover;
  }
  .hero__avatar-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 700;
    background: linear-gradient(135deg, {{ highlight_color }}, #22c55e);
    color: #000;
  }

  /* Stars */
  .hero__stars {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .hero__star-icons {
    display: flex;
    gap: 1px;
    color: var(--color-stars, #fbbf24);
    font-size: 13px;
  }
  .hero__star-text {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-stars, #fbbf24);
  }
  .hero__star-reviews {
    font-size: 12px;
    color: {{ trust_text_color }};
  }

  /* Stats */
  .hero__stats {
    display: flex;
    align-items: stretch;
    justify-content: center;
    gap: 0;
    border: 1px solid #ffffff12;
    border-radius: var(--radius-card, 12px);
    background: #ffffff05;
    backdrop-filter: blur(8px);
    overflow: hidden;
    max-width: 540px;
    margin: 0 auto;
  }
  .hero__stat {
    flex: 1;
    padding: 20px 16px;
    text-align: center;
    position: relative;
  }
  .hero__stat + .hero__stat::before {
    content: '';
    position: absolute;
    left: 0; top: 20%; height: 60%;
    width: 1px;
    background: #ffffff15;
  }
  .hero__stat-value {
    display: block;
    font-family: var(--font-heading, 'Anton', sans-serif);
    font-size: clamp(22px, 4vw, 28px);
    font-weight: 900;
    color: {{ stat_value_color }};
    line-height: 1.1;
    letter-spacing: -0.5px;
  }
  .hero__stat-label {
    display: block;
    font-size: 11px;
    font-weight: 500;
    color: {{ trust_text_color }};
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 4px;
  }

  /* Hero image */
  .hero__image-wrap {
    margin-top: {{ section.settings.image_margin_top | default: 40 }}px;
    text-align: center;
  }
  .hero__image {
    max-width: {{ section.settings.image_max_width | default: 1200 }}px;
    width: 100%;
    height: auto;
    border-radius: {{ section.settings.image_radius | default: 0 }}px;
    display: inline-block;
  }
</style>

<section class="hero" id="hero-{{ section.id }}">
  <div class="hero__inner">

    {%- if show_badge and badge_text != blank -%}
      <div class="hero__badge">
        <span class="hero__badge-dot"></span>
        {{ badge_text }}
      </div>
    {%- endif -%}

    <h1 class="hero__title">
      {%- if title_before != blank -%}
        <span class="hero__title-line">{{ title_before }}</span>
      {%- endif -%}
      {%- if title_highlight != blank -%}
        <span class="hero__title-line hero__title-highlight">{{ title_highlight }}</span>
      {%- endif -%}
      {%- if title_after != blank -%}
        <span class="hero__title-line">{{ title_after }}</span>
      {%- endif -%}
    </h1>

    {%- if show_subtitle and subtitle != blank -%}
      <p class="hero__subtitle">{{ subtitle }}</p>
    {%- endif -%}

    {%- if show_cta -%}
      <div class="hero__cta">
        {%- if cta_primary_text != blank -%}
          <a href="{{ cta_primary_url }}" class="hero__btn hero__btn--primary">
            {{ cta_primary_text }}
            <span class="hero__btn-arrow">→</span>
          </a>
        {%- endif -%}
        {%- if cta_secondary_text != blank -%}
          <a href="{{ cta_secondary_url }}" class="hero__btn hero__btn--secondary">
            {{ cta_secondary_text }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if show_trust -%}
      {%- comment -%} Count how many avatar images are actually uploaded {%- endcomment -%}
      {%- assign avatar_count = 0 -%}
      {%- for i in (1..6) -%}
        {%- assign avatar_key = 'avatar_' | append: i -%}
        {%- if section.settings[avatar_key] != blank -%}
          {%- assign avatar_count = avatar_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
      <div class="hero__trust">
        <p class="hero__trust-label">Trusted by <strong>{{ trust_count }}</strong> {{ trust_label }}</p>
        {%- if show_avatars and avatar_count > 0 -%}
          <div class="hero__avatars">
            {%- for i in (1..6) -%}
              {%- assign avatar_key = 'avatar_' | append: i -%}
              {%- if section.settings[avatar_key] != blank -%}
                <div class="hero__avatar">
                  <img src="{{ section.settings[avatar_key] | image_url: width: 64 }}" alt="Customer" loading="lazy" width="32" height="32">
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
        {%- if show_stars -%}
          <div class="hero__stars">
            <div class="hero__star-icons">★★★★★</div>
            <span class="hero__star-text">{{ star_rating }}</span>
            <span class="hero__star-reviews">· {{ star_review_label }}</span>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if show_stats -%}
      <div class="hero__stats">
        <div class="hero__stat">
          <span class="hero__stat-value">{{ stat_1_value }}</span>
          <span class="hero__stat-label">{{ stat_1_label }}</span>
        </div>
        <div class="hero__stat">
          <span class="hero__stat-value">{{ stat_2_value }}</span>
          <span class="hero__stat-label">{{ stat_2_label }}</span>
        </div>
        <div class="hero__stat">
          <span class="hero__stat-value">{{ stat_3_value }}</span>
          <span class="hero__stat-label">{{ stat_3_label }}</span>
        </div>
      </div>
    {%- endif -%}

    {%- assign show_hero_image = section.settings.show_hero_image -%}
    {%- if show_hero_image and section.settings.hero_image != blank -%}
      <div class="hero__image-wrap">
        <img
          src="{{ section.settings.hero_image | image_url: width: 1200 }}"
          srcset="{{ section.settings.hero_image | image_url: width: 600 }} 600w, {{ section.settings.hero_image | image_url: width: 900 }} 900w, {{ section.settings.hero_image | image_url: width: 1200 }} 1200w"
          sizes="(max-width: 768px) 100vw, 1200px"
          alt="{{ section.settings.hero_image_alt | default: shop.name }}"
          loading="eager"
          width="1200"
          height="600"
          class="hero__image"
        >
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Badge" },
    { "type": "checkbox", "id": "show_badge", "label": "Show badge", "default": true },
    { "type": "text", "id": "badge_text", "label": "Badge text", "default": "#1 Reselling Education Platform" },

    { "type": "header", "content": "Headline" },
    { "type": "text", "id": "title_before", "label": "Line 1 (before highlight)", "default": "START YOUR" },
    { "type": "text", "id": "title_highlight", "label": "Line 2 (highlighted)", "default": "RESELLING" },
    { "type": "text", "id": "title_after", "label": "Line 3 (after highlight)", "default": "JOURNEY TODAY" },
    { "type": "color", "id": "title_color", "label": "Title color", "default": "#ffffff" },
    { "type": "color", "id": "highlight_color", "label": "Highlight color", "default": "#19d400" },
    { "type": "range", "id": "title_size_desktop", "label": "Title size desktop (px)", "min": 32, "max": 120, "step": 2, "default": 90 },
    { "type": "range", "id": "title_size_mobile", "label": "Title size mobile (px)", "min": 24, "max": 72, "step": 2, "default": 48 },

    { "type": "header", "content": "Subtitle" },
    { "type": "checkbox", "id": "show_subtitle", "label": "Show subtitle", "default": false },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle text", "default": "Access 100+ verified vendors, exclusive guides, and a community of resellers making real money — starting today." },
    { "type": "color", "id": "subtitle_color", "label": "Subtitle color", "default": "#9ca3af" },
    { "type": "range", "id": "subtitle_size", "label": "Subtitle size (px)", "min": 14, "max": 24, "step": 1, "default": 18 },

    { "type": "header", "content": "CTA Buttons" },
    { "type": "checkbox", "id": "show_cta", "label": "Show buttons", "default": true },
    { "type": "text", "id": "cta_primary_text", "label": "Primary button text", "default": "Browse Products" },
    { "type": "url", "id": "cta_primary_url", "label": "Primary button link" },
    { "type": "color", "id": "cta_primary_bg", "label": "Primary button color", "default": "#19d400" },
    { "type": "color", "id": "cta_primary_color", "label": "Primary button text color", "default": "#000000" },
    { "type": "text", "id": "cta_secondary_text", "label": "Secondary button text", "default": "" },
    { "type": "url", "id": "cta_secondary_url", "label": "Secondary button link" },

    { "type": "header", "content": "Trust Row" },
    { "type": "checkbox", "id": "show_trust", "label": "Show trust row", "default": true },
    { "type": "checkbox", "id": "show_avatars", "label": "Show avatar stack", "default": true },
    { "type": "image_picker", "id": "avatar_1", "label": "Avatar 1" },
    { "type": "image_picker", "id": "avatar_2", "label": "Avatar 2" },
    { "type": "image_picker", "id": "avatar_3", "label": "Avatar 3" },
    { "type": "image_picker", "id": "avatar_4", "label": "Avatar 4" },
    { "type": "image_picker", "id": "avatar_5", "label": "Avatar 5" },
    { "type": "image_picker", "id": "avatar_6", "label": "Avatar 6" },
    { "type": "checkbox", "id": "show_stars", "label": "Show star rating", "default": false },
    { "type": "text", "id": "star_rating", "label": "Star rating value", "default": "4.9" },
    { "type": "text", "id": "star_review_label", "label": "Review count label", "default": "2,400+ reviews" },
    { "type": "text", "id": "trust_count", "label": "Trust count", "default": "10,000+" },
    { "type": "text", "id": "trust_label", "label": "Trust label", "default": "resellers trust us" },
    { "type": "color", "id": "trust_count_color", "label": "Count color", "default": "#fbbf24" },
    { "type": "color", "id": "trust_text_color", "label": "Trust text color", "default": "#9ca3af" },

    { "type": "header", "content": "Stats Row" },
    { "type": "checkbox", "id": "show_stats", "label": "Show stats", "default": false },
    { "type": "text", "id": "stat_1_value", "label": "Stat 1 value", "default": "$300K+" },
    { "type": "text", "id": "stat_1_label", "label": "Stat 1 label", "default": "Customer Sales" },
    { "type": "text", "id": "stat_2_value", "label": "Stat 2 value", "default": "10,000+" },
    { "type": "text", "id": "stat_2_label", "label": "Stat 2 label", "default": "Orders Fulfilled" },
    { "type": "text", "id": "stat_3_value", "label": "Stat 3 value", "default": "100+" },
    { "type": "text", "id": "stat_3_label", "label": "Stat 3 label", "default": "Verified Vendors" },
    { "type": "color", "id": "stat_value_color", "label": "Stat value color", "default": "#ffffff" },

    { "type": "header", "content": "Glow Effect" },
    { "type": "checkbox", "id": "show_glow", "label": "Show glow", "default": true },
    { "type": "color", "id": "glow_color", "label": "Glow color", "default": "#19d400" },
    { "type": "range", "id": "glow_size", "label": "Glow size (px)", "min": 300, "max": 1000, "step": 50, "default": 700 },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Top padding (px)", "min": 20, "max": 200, "step": 10, "default": 100 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding (px)", "min": 20, "max": 200, "step": 10, "default": 80 },

    { "type": "header", "content": "Hero Image" },
    { "type": "checkbox", "id": "show_hero_image", "label": "Show hero image", "default": false },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" },
    { "type": "text", "id": "hero_image_alt", "label": "Image alt text" },
    { "type": "range", "id": "image_max_width", "label": "Image max width (px)", "min": 400, "max": 1400, "step": 50, "default": 1200 },
    { "type": "range", "id": "image_margin_top", "label": "Image margin top (px)", "min": 0, "max": 100, "step": 4, "default": 40 },
    { "type": "range", "id": "image_radius", "label": "Image border radius (px)", "min": 0, "max": 24, "step": 2, "default": 0 }
  ],
  "presets": [
    { "name": "Hero" }
  ]
}
{% endschema %}
