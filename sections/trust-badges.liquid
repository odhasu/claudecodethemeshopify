<section class="vx-shell vx-shell--loading" data-vx-section="trust-badges">
  <div class="vx-editor-preview"><div class="vx-section-loader"><div class="vx-loader__spinner"></div></div></div>
</section>

<script type="application/json" data-vx-settings="trust-badges">
{
  "bg_color": {{ section.settings.bg_color | default: '#000000' | json }},
  "border_top": {{ section.settings.border_top | default: '#1a1a1a' | json }},
  "border_bot": {{ section.settings.border_bot | default: '#1a1a1a' | json }},
  "icon_color": {{ section.settings.icon_color | default: '#19d400' | json }},
  "text_color": {{ section.settings.text_color | default: '#ffffff' | json }},
  "scroll_speed": {{ section.settings.scroll_speed | default: 30 }},
  "show_separator": {{ section.settings.show_separator | json }},
  "badge_1_text": {{ section.settings.badge_1_text | default: '5,000+ Happy Customers' | json }},
  "badge_1_icon": {{ section.settings.badge_1_icon | default: 'users' | json }},
  "badge_2_text": {{ section.settings.badge_2_text | default: 'Verified Seller' | json }},
  "badge_2_icon": {{ section.settings.badge_2_icon | default: 'shield' | json }},
  "badge_3_text": {{ section.settings.badge_3_text | default: '24/7 Support' | json }},
  "badge_3_icon": {{ section.settings.badge_3_icon | default: 'headset' | json }},
  "badge_4_text": {{ section.settings.badge_4_text | default: 'Instant Access' | json }},
  "badge_4_icon": {{ section.settings.badge_4_icon | default: 'bolt' | json }}
}
</script>

{% schema %}
{
  "name": "Trust Badges Bar",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Style" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#000000" },
    { "type": "color", "id": "border_top", "label": "Border top", "default": "#1a1a1a" },
    { "type": "color", "id": "border_bot", "label": "Border bottom", "default": "#1a1a1a" },
    { "type": "color", "id": "icon_color", "label": "Icon color", "default": "#19d400" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" },
    { "type": "range", "id": "scroll_speed", "label": "Scroll speed (lower = faster)", "min": 10, "max": 80, "step": 5, "default": 30 },
    { "type": "checkbox", "id": "show_separator", "label": "Show separator between badges", "default": true },
    { "type": "header", "content": "Badge 1" },
    { "type": "text", "id": "badge_1_text", "label": "Text", "default": "5,000+ Happy Customers" },
    { "type": "select", "id": "badge_1_icon", "label": "Icon", "default": "users", "options": [
      { "value": "users", "label": "Users" },{ "value": "star", "label": "Star" },{ "value": "shield", "label": "Shield" },{ "value": "bolt", "label": "Bolt" },{ "value": "headset", "label": "Headset" }
    ]},
    { "type": "header", "content": "Badge 2" },
    { "type": "text", "id": "badge_2_text", "label": "Text", "default": "Verified Seller" },
    { "type": "select", "id": "badge_2_icon", "label": "Icon", "default": "shield", "options": [
      { "value": "users", "label": "Users" },{ "value": "star", "label": "Star" },{ "value": "shield", "label": "Shield" },{ "value": "bolt", "label": "Bolt" },{ "value": "headset", "label": "Headset" }
    ]},
    { "type": "header", "content": "Badge 3" },
    { "type": "text", "id": "badge_3_text", "label": "Text", "default": "24/7 Support" },
    { "type": "select", "id": "badge_3_icon", "label": "Icon", "default": "headset", "options": [
      { "value": "users", "label": "Users" },{ "value": "star", "label": "Star" },{ "value": "shield", "label": "Shield" },{ "value": "bolt", "label": "Bolt" },{ "value": "headset", "label": "Headset" }
    ]},
    { "type": "header", "content": "Badge 4" },
    { "type": "text", "id": "badge_4_text", "label": "Text", "default": "Instant Access" },
    { "type": "select", "id": "badge_4_icon", "label": "Icon", "default": "bolt", "options": [
      { "value": "users", "label": "Users" },{ "value": "star", "label": "Star" },{ "value": "shield", "label": "Shield" },{ "value": "bolt", "label": "Bolt" },{ "value": "headset", "label": "Headset" }
    ]}
  ],
  "presets": [
    { "name": "Trust Badges Bar" }
  ]
}
{% endschema %}
