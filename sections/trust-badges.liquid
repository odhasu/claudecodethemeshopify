<style>
  #trust-badges-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    border-top: 1px solid {{ section.settings.border_top }};
    border-bottom: 1px solid {{ section.settings.border_bot }};
    padding: 10px 0;
    overflow: hidden;
  }

  #trust-badges-{{ section.id }} .tb-track {
    display: flex;
    align-items: center;
    width: max-content;
    animation: tb-scroll-{{ section.id }} {{ section.settings.scroll_speed }}s linear infinite;
  }

  #trust-badges-{{ section.id }}:hover .tb-track {
    animation-play-state: paused;
  }

  #trust-badges-{{ section.id }} .tb-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
    padding: 0 16px;
  }

  #trust-badges-{{ section.id }} .tb-badge svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    fill: {{ section.settings.icon_color }};
  }

  #trust-badges-{{ section.id }} .tb-badge span {
    font-family: 'Satoshi', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: {{ section.settings.text_color }};
  }

  #trust-badges-{{ section.id }} .tb-sep {
    color: {{ section.settings.icon_color }};
    font-size: 8px;
    opacity: 0.5;
    flex-shrink: 0;
  }

  @keyframes tb-scroll-{{ section.id }} {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>

{%- capture badge_1_svg -%}
  {%- case section.settings.badge_1_icon -%}
    {%- when 'users' -%}<svg viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
    {%- when 'shield' -%}<svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
    {%- when 'headset' -%}<svg viewBox="0 0 24 24"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>
    {%- when 'bolt' -%}<svg viewBox="0 0 24 24"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
    {%- when 'star' -%}<svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
  {%- endcase -%}
{%- endcapture -%}

