<section class="vx-shell vx-shell--loading" data-vx-section="footer" data-vx-footer>
  <div class="vx-editor-preview"></div>
</section>

<script type="application/json" data-vx-settings="footer">
{
  "logo_url": {% if section.settings.logo != blank %}{{ section.settings.logo | image_url: height: 80 | json }}{% else %}null{% endif %},
  "logo_height": 40,
  "brand_text": {{ section.settings.brand_text | default: shop.name | json }},
  "brand_font_size": 24,
  "brand_color": "#ffffff",
  "show_policies": true,
  "showRefundPolicy": true,
  "label_refund": "Refund Policy",
  "label_shipping": "Shipping",
  "label_privacy": "Privacy",
  "label_terms": "Terms",
  "instagram_url": {{ section.settings.instagram_url | default: '' | json }},
  "tiktok_url": {{ section.settings.tiktok_url | default: '' | json }},
  "youtube_url": {{ section.settings.youtube_url | default: '' | json }},
  "discord_url": {{ section.settings.discord_url | default: '' | json }},
  "social_icon_color": "#19d400",
  "social_icon_size": 22,
  "show_cta": {{ section.settings.show_cta | json }},
  "cta_text": {{ section.settings.cta_text | default: 'Get this store design' | json }},
  "cta_url": {{ section.settings.cta_url | default: 'https://vexelthemes.com' | json }},
  "cta_color": "#19d400",
  "cta_text_color": "#000000",
  "show_copyright": true,
  "copyright_name": {{ section.settings.copyright_name | default: shop.name | json }},
  "bg_color": "#0a0a0a",
  "border_color": "#1a1a1a",
  "link_color": "#6b7280",
  "link_hover_color": "#ffffff",
  "copyright_color": "#6b7280",
  "padding_top": 40,
  "padding_bottom": 40
}
</script>

<style>.vx-shell[data-vx-section="footer"]{min-height:120px}</style>

{% schema %}
{
  "name": "Footer",
  "tag": "footer",
  "settings": [
    { "type": "header", "content": "Brand" },
    { "type": "image_picker", "id": "logo", "label": "Logo image" },
    { "type": "text", "id": "brand_text", "label": "Brand text (if no logo)", "default": "Vexel" },
    { "type": "header", "content": "Social Links" },
    { "type": "text", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "text", "id": "tiktok_url", "label": "TikTok URL" },
    { "type": "text", "id": "youtube_url", "label": "YouTube URL" },
    { "type": "text", "id": "discord_url", "label": "Discord URL" },
    { "type": "header", "content": "CTA Button" },
    { "type": "checkbox", "id": "show_cta", "label": "Show CTA button", "default": true },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "Get this store design" },
    { "type": "url", "id": "cta_url", "label": "Button link" },
    { "type": "header", "content": "Copyright" },
    { "type": "text", "id": "copyright_name", "label": "Copyright name (default: store name)" }
  ],
  "presets": [
    { "name": "Footer" }
  ]
}
{% endschema %}
