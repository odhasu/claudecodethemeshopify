{%- liquid
  assign bg = section.settings.bg_color | default: '#000000'
  assign border_top = section.settings.border_color | default: '#1a1a1a'
  assign brand_color = section.settings.brand_color | default: '#ffffff'
  assign link_color = section.settings.link_color | default: '#6b7280'
  assign link_hover = section.settings.link_hover_color | default: '#ffffff'
  assign copyright_color = section.settings.copyright_color | default: '#6b7280'
  assign icon_color = section.settings.social_icon_color | default: '#ffffff'
  assign icon_box_border = section.settings.social_icon_border | default: '#333333'
  assign icon_box_bg = section.settings.social_icon_bg | default: 'transparent'
  assign cta_bg = section.settings.cta_bg_color | default: '#19d400'
  assign cta_text = section.settings.cta_text_color | default: '#000000'
  assign cta_r = cta_bg | color_extract: 'red'
  assign cta_g = cta_bg | color_extract: 'green'
  assign cta_b = cta_bg | color_extract: 'blue'
-%}

<style>
  .site-footer {
    background: {{ bg }};
    border-top: 1px solid {{ border_top }};
    padding: {{ section.settings.padding_top | default: 48 }}px 20px {{ section.settings.padding_bottom | default: 40 }}px;
    text-align: center;
  }
  .footer-brand {
    font-family: var(--font-heading);
    font-size: {{ section.settings.brand_font_size | default: 22 }}px;
    font-weight: 700;
    color: {{ brand_color }};
    margin-bottom: 20px;
  }
  .footer-social {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    margin-bottom: 24px;
  }
  .footer-social a {
    width: 40px; height: 40px;
    border-radius: 8px;
    background: {{ icon_box_bg }};
    border: 1px solid {{ icon_box_border }};
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ icon_color }};
    transition: border-color 0.2s, color 0.2s;
  }
  .footer-social a:hover {
    border-color: #ffffff;
    color: #ffffff;
  }
  .footer-social svg { width: 18px; height: 18px; }
  .footer-links {
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }
  .footer-links a {
    color: {{ link_color }};
    font-size: 13px;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: {{ link_hover }}; }
  .footer-copyright {
    color: {{ copyright_color }};
    font-size: 13px;
    margin-bottom: 20px;
  }
  .footer-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 11px 26px;
    border-radius: 999px;
    border: none;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.32) 0%, rgba(255,255,255,0) 55%, rgba(0,0,0,0.14) 100%),
      {{ cta_bg }};
    color: {{ cta_text }};
    font-weight: 600;
    font-size: 14px;
    box-shadow:
      0 6px 28px rgba({{ cta_r }}, {{ cta_g }}, {{ cta_b }}, 0.6),
      0 2px 6px rgba(0,0,0,0.25);
    transition: box-shadow 0.2s;
  }
  .footer-cta:hover {
    box-shadow:
      0 4px 12px rgba({{ cta_r }}, {{ cta_g }}, {{ cta_b }}, 0.45),
      0 8px 24px rgba({{ cta_r }}, {{ cta_g }}, {{ cta_b }}, 0.28),
      0 2px 6px rgba(0,0,0,0.3);
  }
</style>

<footer class="site-footer">
  {%- if section.settings.logo != blank -%}
    <div style="margin-bottom:20px;">
      <img src="{{ section.settings.logo | image_url: height: 50 }}" alt="{{ shop.name }}" style="height:{{ section.settings.logo_height | default: 40 }}px;margin:0 auto;">
    </div>
  {%- else -%}
    <div class="footer-brand">{{ section.settings.brand_text | default: 'OGVENDORS' }}</div>
  {%- endif -%}

  {%- assign has_social = false -%}
  {%- if section.settings.instagram_url != blank or section.settings.youtube_url != blank or section.settings.discord_url != blank or section.settings.tiktok_url != blank -%}
    {%- assign has_social = true -%}
  {%- endif -%}

  {%- if has_social -%}
  <div class="footer-social">
    {%- if section.settings.instagram_url != blank -%}
      <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
      </a>
    {%- endif -%}
    {%- if section.settings.youtube_url != blank -%}
      <a href="{{ section.settings.youtube_url }}" target="_blank" rel="noopener" aria-label="YouTube">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
      </a>
    {%- endif -%}
    {%- if section.settings.discord_url != blank -%}
      <a href="{{ section.settings.discord_url }}" target="_blank" rel="noopener" aria-label="Discord">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057.1 18.082.114 18.105.134 18.12a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
      </a>
    {%- endif -%}
    {%- if section.settings.tiktok_url != blank -%}
      <a href="{{ section.settings.tiktok_url }}" target="_blank" rel="noopener" aria-label="TikTok">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
      </a>
    {%- endif -%}
  </div>
  {%- endif -%}

  <div class="footer-links">
    <a href="/policies/refund-policy">Refund Policy</a>
    <a href="/policies/shipping-policy">Shipping</a>
    <a href="/policies/privacy-policy">Privacy</a>
    <a href="/policies/terms-of-service">Terms</a>
  </div>

  {%- if section.settings.show_copyright -%}
    <div class="footer-copyright">&copy; {{ 'now' | date: '%Y' }} {{ section.settings.brand_text | default: shop.name }}. All rights reserved.</div>
  {%- endif -%}

  {%- if section.settings.show_cta -%}
    <a href="{{ section.settings.cta_url | default: '#' }}" class="footer-cta" target="_blank" rel="noopener">
      {{ section.settings.cta_label | default: 'Get this store design' }} ↗
    </a>
  {%- endif -%}
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "footer",
  "settings": [
    { "type": "header", "content": "Brand" },
    { "type": "image_picker", "id": "logo", "label": "Logo image" },
    { "type": "range", "id": "logo_height", "label": "Logo height (px)", "min": 20, "max": 80, "step": 5, "default": 40 },
    { "type": "text", "id": "brand_text", "label": "Brand name", "default": "OGVENDORS" },
    { "type": "range", "id": "brand_font_size", "label": "Brand font size (px)", "min": 14, "max": 40, "step": 2, "default": 22 },
    { "type": "header", "content": "Social Links" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url", "id": "youtube_url", "label": "YouTube URL" },
    { "type": "url", "id": "discord_url", "label": "Discord URL" },
    { "type": "url", "id": "tiktok_url", "label": "TikTok URL" },
    { "type": "header", "content": "CTA Button" },
    { "type": "checkbox", "id": "show_cta", "label": "Show CTA button", "default": true },
    { "type": "text", "id": "cta_label", "label": "Button text", "default": "Get this store design" },
    { "type": "url", "id": "cta_url", "label": "Button link" },
    { "type": "color", "id": "cta_bg_color", "label": "Button background", "default": "#19d400" },
    { "type": "color", "id": "cta_text_color", "label": "Button text color", "default": "#000000" },
    { "type": "header", "content": "Copyright" },
    { "type": "checkbox", "id": "show_copyright", "label": "Show copyright", "default": true },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#000000" },
    { "type": "color", "id": "border_color", "label": "Top border", "default": "#1a1a1a" },
    { "type": "color", "id": "brand_color", "label": "Brand name color", "default": "#ffffff" },
    { "type": "color", "id": "social_icon_color", "label": "Social icon color", "default": "#ffffff" },
    { "type": "color", "id": "social_icon_border", "label": "Social icon box border", "default": "#333333" },
    { "type": "color", "id": "social_icon_bg", "label": "Social icon box background", "default": "#000000" },
    { "type": "color", "id": "link_color", "label": "Link color", "default": "#6b7280" },
    { "type": "color", "id": "link_hover_color", "label": "Link hover color", "default": "#ffffff" },
    { "type": "color", "id": "copyright_color", "label": "Copyright color", "default": "#6b7280" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Top padding (px)", "min": 20, "max": 80, "step": 8, "default": 48 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding (px)", "min": 20, "max": 80, "step": 8, "default": 40 }
  ],
  "presets": [
    { "name": "Footer" }
  ]
}
{% endschema %}
