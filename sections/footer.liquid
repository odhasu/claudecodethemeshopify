<section class="vx-shell vx-shell--loading" data-vx-section="footer" data-vx-footer>
  <div class="vx-editor-preview"><div class="vx-section-loader"><div class="vx-loader__spinner"></div></div></div>
</section>

<script type="application/json" data-vx-settings="footer">
{
  "logo_url": {% if section.settings.logo != blank %}{{ section.settings.logo | image_url: height: 80 | json }}{% else %}null{% endif %},
  "logo_height": {{ section.settings.logo_height | default: 40 }},
  "brand_text": {{ section.settings.brand_text | default: shop.name | json }},
  "brand_font_size": {{ section.settings.brand_font_size | default: 26 }},
  "brand_color": {{ section.settings.brand_color | default: '#ffffff' | json }},
  "show_policies": {{ section.settings.show_policies | json }},
  "label_refund": {{ section.settings.label_refund | default: 'Refund' | json }},
  "label_shipping": {{ section.settings.label_shipping | default: 'Shipping' | json }},
  "label_privacy": {{ section.settings.label_privacy | default: 'Privacy' | json }},
  "label_terms": {{ section.settings.label_terms | default: 'Terms' | json }},
  "instagram_url": {{ section.settings.instagram_url | default: '' | json }},
  "tiktok_url": {{ section.settings.tiktok_url | default: '' | json }},
  "youtube_url": {{ section.settings.youtube_url | default: '' | json }},
  "discord_url": {{ section.settings.discord_url | default: '' | json }},
  "social_icon_color": {{ section.settings.social_icon_color | default: '#19d400' | json }},
  "social_icon_size": {{ section.settings.social_icon_size | default: 20 }},
  "show_cta": {{ section.settings.show_cta | json }},
  "cta_text": {{ section.settings.cta_text | default: 'Get this store design' | json }},
  "cta_url": {{ section.settings.cta_url | default: 'https://ogresells.com' | json }},
  "cta_color": {{ section.settings.cta_color | default: '#19d400' | json }},
  "cta_text_color": {{ section.settings.cta_text_color | default: '#000000' | json }},
  "show_copyright": {{ section.settings.show_copyright | json }},
  "copyright_name": {{ section.settings.copyright_name | default: shop.name | json }},
  "bg_color": {{ section.settings.bg_color | default: '#0a0a0a' | json }},
  "border_color": {{ section.settings.border_color | default: '#1a1a1a' | json }},
  "link_color": {{ section.settings.link_color | default: '#6b7280' | json }},
  "link_hover_color": {{ section.settings.link_hover_color | default: '#ffffff' | json }},
  "copyright_color": {{ section.settings.copyright_color | default: '#6b7280' | json }},
  "padding_top": {{ section.settings.padding_top | default: 48 }},
  "padding_bottom": {{ section.settings.padding_bottom | default: 48 }}
}
</script>

<style>.vx-shell[data-vx-section="footer"]{min-height:120px}</style>

{% schema %}
{
  "name": "Footer",
  "tag": "footer",
  "settings": [
    { "type": "header", "content": "Brand" },
    { "type": "image_picker", "id": "logo", "label": "Logo image" },
    { "type": "range", "id": "logo_height", "label": "Logo height (px)", "min": 20, "max": 80, "step": 5, "default": 40 },
    { "type": "text", "id": "brand_text", "label": "Brand text (if no logo)", "default": "OGVENDORS" },
    { "type": "range", "id": "brand_font_size", "label": "Brand font size (px)", "min": 16, "max": 48, "step": 2, "default": 26 },
    { "type": "header", "content": "Policy Links" },
    { "type": "checkbox", "id": "show_policies", "label": "Show policy links", "default": true },
    { "type": "text", "id": "label_refund", "label": "Refund label", "default": "Refund" },
    { "type": "text", "id": "label_shipping", "label": "Shipping label", "default": "Shipping" },
    { "type": "text", "id": "label_privacy", "label": "Privacy label", "default": "Privacy" },
    { "type": "text", "id": "label_terms", "label": "Terms label", "default": "Terms" },
    { "type": "range", "id": "link_gap", "label": "Link spacing (px)", "min": 4, "max": 32, "step": 2, "default": 6 },
    { "type": "header", "content": "Social Links" },
    { "type": "text", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "text", "id": "tiktok_url", "label": "TikTok URL" },
    { "type": "text", "id": "youtube_url", "label": "YouTube URL" },
    { "type": "text", "id": "discord_url", "label": "Discord URL" },
    { "type": "color", "id": "social_icon_color", "label": "Icon color", "default": "#19d400" },
    { "type": "range", "id": "social_icon_size", "label": "Icon size (px)", "min": 16, "max": 32, "step": 2, "default": 20 },
    { "type": "header", "content": "CTA Button" },
    { "type": "checkbox", "id": "show_cta", "label": "Show CTA button", "default": true },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "Get this store design" },
    { "type": "url", "id": "cta_url", "label": "Button link" },
    { "type": "color", "id": "cta_color", "label": "Button color", "default": "#19d400" },
    { "type": "color", "id": "cta_text_color", "label": "Button text color", "default": "#000000" },
    { "type": "header", "content": "Copyright" },
    { "type": "checkbox", "id": "show_copyright", "label": "Show copyright", "default": true },
    { "type": "text", "id": "copyright_name", "label": "Copyright name (default: store name)" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#0a0a0a" },
    { "type": "color", "id": "border_color", "label": "Top border", "default": "#1a1a1a" },
    { "type": "color", "id": "brand_color", "label": "Brand color", "default": "#ffffff" },
    { "type": "color", "id": "link_color", "label": "Link color", "default": "#6b7280" },
    { "type": "color", "id": "link_hover_color", "label": "Link hover color", "default": "#ffffff" },
    { "type": "color", "id": "copyright_color", "label": "Copyright color", "default": "#6b7280" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Top padding (px)", "min": 20, "max": 100, "step": 4, "default": 48 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding (px)", "min": 20, "max": 100, "step": 4, "default": 48 }
  ],
  "presets": [
    { "name": "Footer" }
  ]
}
{% endschema %}
