{%- assign has_product_blocks = false -%}{%- for block in section.blocks -%}{%- if block.type == 'product' and block.settings.product != blank -%}{%- assign has_product_blocks = true -%}{%- break -%}{%- endif -%}{%- endfor -%}

<section class="vx-shell vx-shell--loading" data-vx-section="product-grid">
  <div class="vx-editor-preview"><div class="vx-section-loader"><div class="vx-loader__spinner"></div></div></div>
</section>

<script type="application/json" data-vx-settings="product-grid">
{
  "hero_headline": {{ section.settings.hero_headline | default: '' | json }},
  "highlight_word": {{ section.settings.highlight_word | default: '' | json }},
  "hero_image": {% if section.settings.hero_image %}{{ section.settings.hero_image | image_url: width: 1200 | json }}{% else %}null{% endif %},
  "hero_text_size": {{ section.settings.hero_text_size | default: 100 }},
  "card_style": {{ section.settings.card_style | default: 'flat' | json }},
  "card_click_action": {{ section.settings.card_click_action | default: 'product' | json }},
  "card_click_custom_url": {{ section.settings.card_click_custom_url | json }},
  "button_layout": {{ section.settings.button_layout | default: 'side-by-side' | json }},
  "button_1_text": {{ section.settings.button_1_text | default: 'VIEW PRODUCT' | json }},
  "button_1_action": {{ section.settings.button_1_action | default: 'product' | json }},
  "button_1_custom_url": {{ section.settings.button_1_custom_url | json }},
  "button_2_text": {{ section.settings.button_2_text | default: 'ADD TO CART' | json }},
  "button_2_action": {{ section.settings.button_2_action | default: 'add_to_cart' | json }},
  "button_2_custom_url": {{ section.settings.button_2_custom_url | json }},
  "sale_badge_text": {{ section.settings.sale_badge_text | default: 'SALE' | json }},
  "sale_badge_position": {{ section.settings.sale_badge_position | default: 'top-right' | json }},
  "show_background_gradient": {{ section.settings.show_background_gradient | json }},
  "gradient_strength": {{ section.settings.gradient_strength | default: 50 }}
}
</script>

<script type="application/json" data-vx-products="product-grid">
[{%- assign product_count = 0 -%}{%- if has_product_blocks -%}{%- for block in section.blocks -%}{%- if block.type == 'product' and block.settings.product != blank -%}{%- assign p = block.settings.product -%}{%- if p.available -%}{%- if product_count > 0 -%},{%- endif -%}{"id":{{ p.id | json }},"variantId":{{ p.selected_or_first_available_variant.id | json }},"title":{{ p.title | json }},"handle":{{ p.handle | json }},"url":{{ p.url | json }},"price":{{ p.price }},"comparePrice":{{ p.compare_at_price | default: 'null' }},"available":{{ p.available | json }},"image":{% if p.featured_image %}{{ p.featured_image | image_url: width: 500 | json }}{% else %}null{% endif %},"imageAlt":{{ p.featured_image.alt | default: p.title | json }},"description":{{ p.description | strip_html | truncate: 500 | json }},"button1Text":{{ block.settings.button_1_text | json }},"button1Action":{{ block.settings.button_1_action | default: "default" | json }},"button1CustomUrl":{{ block.settings.button_1_custom_url | json }},"button2Text":{{ block.settings.button_2_text | json }},"button2Action":{{ block.settings.button_2_action | default: "default" | json }},"button2CustomUrl":{{ block.settings.button_2_custom_url | json }}}{%- assign product_count = product_count | plus: 1 -%}{%- endif -%}{%- endif -%}{%- endfor -%}{%- else -%}{%- for p in collections.all.products limit: 50 -%}{%- if p.available -%}{%- if product_count > 0 -%},{%- endif -%}{"id":{{ p.id | json }},"variantId":{{ p.selected_or_first_available_variant.id | json }},"title":{{ p.title | json }},"handle":{{ p.handle | json }},"url":{{ p.url | json }},"price":{{ p.price }},"comparePrice":{{ p.compare_at_price | default: 'null' }},"available":{{ p.available | json }},"image":{% if p.featured_image %}{{ p.featured_image | image_url: width: 500 | json }}{% else %}null{% endif %},"imageAlt":{{ p.featured_image.alt | default: p.title | json }},"description":{{ p.description | strip_html | truncate: 500 | json }}}{%- assign product_count = product_count | plus: 1 -%}{%- endif -%}{%- endfor -%}{%- endif -%}]
</script>

{% schema %}{"name":"Product Grid","tag":"section","class":"vx-product-grid-wrapper","settings":[{"type":"header","content":"Hero Settings"},{"type":"text","id":"hero_headline","label":"Hero Headline","default":"Start Your Reselling Journey Today"},{"type":"text","id":"highlight_word","label":"Highlight Word","info":"Single word to highlight with accent color","default":"Reselling"},{"type":"range","id":"hero_text_size","label":"Hero Text Size","min":50,"max":200,"step":5,"unit":"%","default":100},{"type":"image_picker","id":"hero_image","label":"Hero Image (Optional)"},{"type":"checkbox","id":"show_background_gradient","label":"Show Background Gradient","info":"Adds a subtle gradient glow using Accent Color 1","default":true},{"type":"range","id":"gradient_strength","label":"Gradient Strength","min":10,"max":100,"step":10,"unit":"%","default":50},{"type":"header","content":"Product Grid Settings"},{"type":"select","id":"card_style","label":"Card Style","options":[{"value":"flat","label":"Flat"},{"value":"3d","label":"3D Glass"}],"default":"flat"},{"type":"select","id":"card_click_action","label":"Card Click Action","info":"What happens when clicking the product image or title","options":[{"value":"product","label":"Go to Product Page"},{"value":"add_to_cart","label":"Add to Cart"},{"value":"checkout","label":"Direct to Checkout"},{"value":"description","label":"Show Description Popup"},{"value":"custom","label":"Custom Link"}],"default":"product"},{"type":"url","id":"card_click_custom_url","label":"Card Click Custom URL","info":"Only used when 'Custom Link' is selected"},{"type":"header","content":"Button Layout"},{"type":"select","id":"button_layout","label":"Button Layout","options":[{"value":"side-by-side","label":"Two Buttons Side by Side"},{"value":"stacked","label":"Two Buttons Stacked"},{"value":"single","label":"Single Button"},{"value":"button-link","label":"Button + Link Text"}],"default":"side-by-side"},{"type":"header","content":"Button 1 (Primary)"},{"type":"text","id":"button_1_text","label":"Button Text","default":"VIEW PRODUCT"},{"type":"select","id":"button_1_action","label":"Button Action","options":[{"value":"product","label":"Go to Product Page"},{"value":"add_to_cart","label":"Add to Cart"},{"value":"checkout","label":"Direct to Checkout"},{"value":"description","label":"Show Description Popup"},{"value":"custom","label":"Custom Link"}],"default":"product"},{"type":"url","id":"button_1_custom_url","label":"Button 1 Custom URL","info":"Only used when 'Custom Link' is selected"},{"type":"header","content":"Button 2 (Secondary)"},{"type":"paragraph","content":"Used as second button in 'Two Buttons' layouts, or as the small underlined link in 'Button + Link' layout."},{"type":"text","id":"button_2_text","label":"Button / Link Text","default":"ADD TO CART"},{"type":"select","id":"button_2_action","label":"Button Action","options":[{"value":"add_to_cart","label":"Add to Cart"},{"value":"product","label":"Go to Product Page"},{"value":"checkout","label":"Direct to Checkout"},{"value":"description","label":"Show Description Popup"},{"value":"custom","label":"Custom Link"}],"default":"add_to_cart"},{"type":"url","id":"button_2_custom_url","label":"Button 2 Custom URL","info":"Only used when 'Custom Link' is selected"},{"type":"header","content":"Sale Badge"},{"type":"text","id":"sale_badge_text","label":"Sale Badge Text","default":"SALE"},{"type":"select","id":"sale_badge_position","label":"Sale Badge Position","options":[{"value":"top-left","label":"Top Left"},{"value":"top-right","label":"Top Right"},{"value":"bottom-left","label":"Bottom Left"},{"value":"bottom-right","label":"Bottom Right"}],"default":"top-right"}],"blocks":[{"type":"product","name":"Product","settings":[{"type":"product","id":"product","label":"Product"},{"type":"header","content":"Button 1 Override (Optional)"},{"type":"text","id":"button_1_text","label":"Button 1 Text Override","info":"Leave blank to use section default"},{"type":"select","id":"button_1_action","label":"Button 1 Action Override","options":[{"value":"default","label":"Use Section Default"},{"value":"product","label":"Go to Product Page"},{"value":"add_to_cart","label":"Add to Cart"},{"value":"checkout","label":"Direct to Checkout"},{"value":"description","label":"Show Description Popup"},{"value":"custom","label":"Custom Link"}],"default":"default"},{"type":"url","id":"button_1_custom_url","label":"Button 1 Custom URL"},{"type":"header","content":"Button 2 Override (Optional)"},{"type":"text","id":"button_2_text","label":"Button 2 Text Override","info":"Leave blank to use section default"},{"type":"select","id":"button_2_action","label":"Button 2 Action Override","options":[{"value":"default","label":"Use Section Default"},{"value":"add_to_cart","label":"Add to Cart"},{"value":"product","label":"Go to Product Page"},{"value":"checkout","label":"Direct to Checkout"},{"value":"description","label":"Show Description Popup"},{"value":"custom","label":"Custom Link"}],"default":"default"},{"type":"url","id":"button_2_custom_url","label":"Button 2 Custom URL"}]}],"presets":[{"name":"Product Grid"}]}{% endschema %}
