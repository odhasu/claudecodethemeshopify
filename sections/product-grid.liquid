{%- liquid
  assign collection = section.settings.collection | default: collections.all
  assign max_products = section.settings.max_products | default: 8
-%}

<section class="vx-shell vx-shell--loading" data-vx-section="product-grid">
  <div class="vx-editor-preview"><div class="vx-section-loader"><div class="vx-loader__spinner"></div></div></div>
</section>

<script type="application/json" data-vx-settings="product-grid">
{
  "title": {{ section.settings.title | json }},
  "columns_desktop": {{ section.settings.columns_desktop | default: 4 }},
  "columns_mobile": {{ section.settings.columns_mobile | default: 2 }},
  "glassmorphic": {{ section.settings.glassmorphic_cards | json }},
  "show_glow": {{ section.settings.show_glow | json }},
  "glow_color": {{ section.settings.glow_color | default: '#19d400' | json }},
  "glow_intensity": {{ section.settings.glow_intensity | default: 35 }},
  "show_top_fade": {{ section.settings.show_top_fade | json }},
  "card_bg": {{ section.settings.card_bg | default: '#111111' | json }},
  "card_border": {{ section.settings.card_border | default: '#2a2a2a' | json }},
  "card_hover_border": {{ section.settings.card_hover_border | default: '#19d400' | json }},
  "image_bg": {{ section.settings.image_bg | default: '#0a0a0a' | json }},
  "title_color": {{ section.settings.title_color | default: '#ffffff' | json }},
  "show_overlay_title": {{ section.settings.show_overlay_title | json }},
  "overlay_green_color": {{ section.settings.overlay_title_green_color | default: '#19d400' | json }},
  "overlay_white_color": {{ section.settings.overlay_title_white_color | default: '#ffffff' | json }},
  "overlay_font_size": {{ section.settings.overlay_font_size | default: 14 }},
  "show_sale_badge": {{ section.settings.show_sale_badge | json }},
  "always_show_sale_badge": {{ section.settings.always_show_sale_badge | json }},
  "sale_badge_label": {{ section.settings.sale_badge_label | default: 'SALE' | json }},
  "sale_badge_bg": {{ section.settings.sale_badge_bg | default: '#000000' | json }},
  "sale_badge_text_color": {{ section.settings.sale_badge_text_color | default: '#ffffff' | json }},
  "sale_badge_position_y": {{ section.settings.sale_badge_position_y | default: 'top' | json }},
  "sale_badge_position_x": {{ section.settings.sale_badge_position_x | default: 'right' | json }},
  "price_color": {{ section.settings.price_color | default: '#19d400' | json }},
  "compare_price_color": {{ section.settings.compare_price_color | default: '#6b7280' | json }},
  "buy_btn_label": {{ section.settings.buy_btn_label | default: 'BUY NOW' | json }},
  "buy_btn_radius": {{ section.settings.buy_btn_radius | default: 50 }},
  "buy_btn_action": {{ section.settings.buy_btn_action | default: 'product' | json }},
  "buy_btn_bg": {{ section.settings.buy_btn_bg | default: '#19d400' | json }},
  "buy_btn_text_color": {{ section.settings.buy_btn_text_color | default: '#1a1a1a' | json }},
  "show_info_btn": {{ section.settings.show_info_btn | json }},
  "show_description": {{ section.settings.show_description | json }},
  "padding_top": {{ section.settings.padding_top | default: 40 }},
  "padding_bottom": {{ section.settings.padding_bottom | default: 60 }}
}
</script>

<script type="application/json" data-vx-products="product-grid">
[{%- assign product_count = 0 -%}{%- for product in collection.products limit: max_products -%}{%- if product_count > 0 -%},{%- endif -%}{
  "id": {{ product.id | json }},
  "variantId": {{ product.first_available_variant.id | json }},
  "title": {{ product.title | json }},
  "handle": {{ product.handle | json }},
  "url": {{ product.url | json }},
  "price": {{ product.price }},
  "comparePrice": {{ product.compare_at_price_max | default: 'null' }},
  "available": {{ product.available | json }},
  "image": {% if product.featured_image %}{{ product.featured_image | image_url: width: 600 | json }}{% else %}null{% endif %},
  "imageAlt": {{ product.featured_image.alt | default: product.title | json }},
  "description": {{ product.description | strip_html | truncate: 500 | json }},
  "overlayGreen": {{ product.metafields.custom.overlay_green | json }},
  "overlayWhite": {{ product.metafields.custom.overlay_white | json }}
}{%- assign product_count = product_count | plus: 1 -%}{%- endfor -%}]
</script>

{% schema %}
{
  "name": "Product Grid",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Collection" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "text", "id": "title", "label": "Section title" },
    { "type": "range", "id": "max_products", "label": "Max products", "min": 2, "max": 16, "step": 1, "default": 8 },
    { "type": "header", "content": "Grid Layout" },
    { "type": "range", "id": "columns_desktop", "label": "Columns desktop", "min": 1, "max": 8, "step": 1, "default": 4 },
    { "type": "range", "id": "columns_mobile", "label": "Columns mobile", "min": 1, "max": 4, "step": 1, "default": 2 },
    { "type": "header", "content": "Card Style" },
    { "type": "checkbox", "id": "glassmorphic_cards", "label": "Glassmorphic cards (inset glow + blur)", "default": true },
    { "type": "color", "id": "card_bg", "label": "Card background", "default": "#111111" },
    { "type": "color", "id": "card_border", "label": "Card border", "default": "#2a2a2a" },
    { "type": "color", "id": "card_hover_border", "label": "Card hover border", "default": "#19d400" },
    { "type": "color", "id": "image_bg", "label": "Image background", "default": "#0a0a0a" },
    { "type": "color", "id": "title_color", "label": "Title color", "default": "#ffffff" },
    { "type": "header", "content": "Overlay Title on Image" },
    { "type": "checkbox", "id": "show_overlay_title", "label": "Show overlay title on image", "default": true },
    { "type": "color", "id": "overlay_title_green_color", "label": "Overlay green text color", "default": "#19d400" },
    { "type": "color", "id": "overlay_title_white_color", "label": "Overlay white text color", "default": "#ffffff" },
    { "type": "range", "id": "overlay_font_size", "label": "Overlay font size (px)", "min": 10, "max": 22, "step": 1, "default": 14 },
    { "type": "header", "content": "Sale Badge" },
    { "type": "checkbox", "id": "show_sale_badge", "label": "Show sale badge", "default": true },
    { "type": "checkbox", "id": "always_show_sale_badge", "label": "Always show badge (even without compare price)", "default": false },
    { "type": "text", "id": "sale_badge_label", "label": "Badge text", "default": "SALE" },
    { "type": "color", "id": "sale_badge_bg", "label": "Badge background", "default": "#000000" },
    { "type": "color", "id": "sale_badge_text_color", "label": "Badge text color", "default": "#ffffff" },
    { "type": "select", "id": "sale_badge_position_y", "label": "Badge vertical position", "default": "top", "options": [
      { "value": "top", "label": "Top" },
      { "value": "bottom", "label": "Bottom" }
    ]},
    { "type": "select", "id": "sale_badge_position_x", "label": "Badge horizontal position", "default": "right", "options": [
      { "value": "right", "label": "Right" },
      { "value": "left", "label": "Left" }
    ]},
    { "type": "header", "content": "Pricing" },
    { "type": "color", "id": "price_color", "label": "Sale price color", "default": "#19d400" },
    { "type": "color", "id": "compare_price_color", "label": "Compare price color", "default": "#6b7280" },
    { "type": "header", "content": "Buy Button" },
    { "type": "text", "id": "buy_btn_label", "label": "Button label", "default": "BUY NOW" },
    { "type": "range", "id": "buy_btn_radius", "label": "Button radius (px)", "min": 4, "max": 50, "step": 2, "default": 50 },
    { "type": "select", "id": "buy_btn_action", "label": "Button action", "default": "product", "options": [
      { "value": "product", "label": "Go to product page" },
      { "value": "add_to_cart", "label": "Add to cart" },
      { "value": "checkout", "label": "Direct checkout" }
    ]},
    { "type": "color", "id": "buy_btn_bg", "label": "Button background", "default": "#19d400" },
    { "type": "color", "id": "buy_btn_text_color", "label": "Button text color", "default": "#1a1a1a" },
    { "type": "header", "content": "Description" },
    { "type": "checkbox", "id": "show_description", "label": "Show product description on card", "default": true },
    { "type": "header", "content": "Info Button" },
    { "type": "checkbox", "id": "show_info_btn", "label": "Show info button", "default": true },
    { "type": "header", "content": "Glow Effect" },
    { "type": "checkbox", "id": "show_glow", "label": "Show radial glow on sides", "default": true },
    { "type": "color", "id": "glow_color", "label": "Glow color", "default": "#19d400" },
    { "type": "range", "id": "glow_intensity", "label": "Glow intensity (%)", "min": 10, "max": 60, "step": 5, "default": 35 },
    { "type": "checkbox", "id": "show_top_fade", "label": "Show top fade-to-background gradient", "default": false },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Top padding (px)", "min": 0, "max": 120, "step": 10, "default": 40 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding (px)", "min": 0, "max": 120, "step": 10, "default": 60 }
  ],
  "presets": [
    { "name": "Product Grid" }
  ]
}
{% endschema %}
