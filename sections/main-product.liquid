{%- liquid
  assign product = product
-%}

<style>
  .product-page {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 60px 20px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
  }
  @media (max-width: 768px) { .product-page { grid-template-columns: 1fr; padding: 30px 20px; gap: 24px; } }
  .product-gallery { position: relative; }
  .product-main-image {
    width: 100%;
    aspect-ratio: 1;
    background: #0a0a0a;
    border-radius: var(--radius-card);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }
  .product-main-image img { width: 100%; height: 100%; object-fit: cover; }
  .product-thumbnails { display: flex; gap: 8px; margin-top: 12px; overflow-x: auto; }
  .product-thumb {
    width: 72px; height: 72px;
    border-radius: 8px;
    overflow: hidden;
    border: 2px solid transparent;
    cursor: pointer;
    flex-shrink: 0;
    background: #0a0a0a;
  }
  .product-thumb.active { border-color: var(--color-accent); }
  .product-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .product-info h1 {
    font-family: var(--font-heading);
    font-size: clamp(24px, 4vw, 36px);
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .product-price-row { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
  .product-price { color: var(--color-accent); font-size: 28px; font-weight: 900; }
  .product-compare-price { color: var(--color-text-muted); text-decoration: line-through; font-size: 18px; }
  .product-description { color: var(--color-text-muted); font-size: 15px; line-height: 1.7; margin-bottom: 24px; }
  .product-buy-btn {
    width: 100%;
    padding: 16px;
    border-radius: var(--radius-button);
    background: var(--color-accent);
    color: #000;
    font-weight: 900;
    font-size: 16px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: none;
    cursor: pointer;
    transition: box-shadow 0.3s, transform 0.2s;
  }
  .product-buy-btn:hover { box-shadow: 0 4px 15px rgba(57,255,20,0.4); transform: translateY(-1px); }
</style>

<section class="product-page">
  <div class="product-gallery">
    <div class="product-main-image" id="main-image">
      {%- if product.featured_image -%}
        <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title | escape }}" id="main-img">
      {%- endif -%}
    </div>
    {%- if product.images.size > 1 -%}
      <div class="product-thumbnails">
        {%- for image in product.images -%}
          <div class="product-thumb{% if forloop.first %} active{% endif %}" onclick="switchImage(this, '{{ image | image_url: width: 800 }}')">
            <img src="{{ image | image_url: width: 150 }}" alt="{{ product.title | escape }}">
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <div class="product-info">
    <h1>{{ product.title }}</h1>
    <div class="product-price-row">
      <span class="product-price">{{ product.price | money }}</span>
      {%- if product.compare_at_price > product.price -%}
        <span class="product-compare-price">{{ product.compare_at_price | money }}</span>
      {%- endif -%}
    </div>
    <div class="product-description">{{ product.description }}</div>

    <form method="post" action="/cart/add">
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
      <input type="hidden" name="quantity" value="1">
      <button type="submit" class="product-buy-btn">
        {%- if product.available -%}
          {{ section.settings.buy_btn_text | default: 'BUY NOW' }}
        {%- else -%}
          SOLD OUT
        {%- endif -%}
      </button>
    </form>
  </div>
</section>

<script>
  function switchImage(thumb, url) {
    document.getElementById('main-img').src = url;
    document.querySelectorAll('.product-thumb').forEach(function(t) { t.classList.remove('active'); });
    thumb.classList.add('active');
  }
</script>

{% schema %}
{
  "name": "Product Page",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "buy_btn_text", "label": "Buy button text", "default": "BUY NOW" }
  ]
}
{% endschema %}
