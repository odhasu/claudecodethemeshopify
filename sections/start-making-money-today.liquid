{% comment %}
  Section: Start Making Money Today (CTA that scrolls to top)
  File: sections/start-making-money-today.liquid
{% endcomment %}

<section class="smmt" id="smmt-{{ section.id }}" role="region" aria-labelledby="smmt-title-{{ section.id }}">
  <style>
    .smmt {
      /* Mobile-first padding */
      padding: {{ section.settings.padding_top_mobile | default: 24 }}px 16px {{ section.settings.padding_bottom_mobile | default: 24 }}px;
      background: {{ section.settings.bg_color | default: 'transparent' }};
      color: {{ section.settings.text_color | default: '#FFFFFF' }};
    }
    @media (min-width: 990px) {
      .smmt {
        padding-top: {{ section.settings.padding_top_desktop | default: 32 }}px;
        padding-bottom: {{ section.settings.padding_bottom_desktop | default: 32 }}px;
      }
    }

    .smmt__inner {
      max-width: 1100px;
      margin: 0 auto;
      text-align: center;
    }

    .smmt__title {
      margin: 0 0 14px 0;
      font-weight: 800;
      line-height: 1.1;
      /* Adjustable heading size (mobile → desktop) */
      font-size: clamp({{ section.settings.heading_size_mobile | default: 28 }}px, 5vw, {{ section.settings.heading_size_desktop | default: 44 }}px);
      letter-spacing: -0.01em;
    }

    .smmt__sub { 
      margin: 0 0 22px 0; 
      opacity: 0.9; 
      /* Adjustable subtext size (mobile → desktop) */
      font-size: clamp({{ section.settings.subtext_size_mobile | default: 15 }}px, 2.5vw, {{ section.settings.subtext_size_desktop | default: 18 }}px);
      line-height: 1.45;
    }

    .smmt__cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: .5rem;
      min-height: 48px;
      padding: 12px 22px;
      border-radius: 12px;
      border: none;
      text-decoration: none;
      cursor: pointer;
      font-weight: 800;
      /* Adjustable button text size (mobile → desktop) */
      font-size: clamp({{ section.settings.btn_text_size_mobile | default: 16 }}px, 2.5vw, {{ section.settings.btn_text_size_desktop | default: 18 }}px);
      line-height: 1;
      background: {{ section.settings.cta_color | default: '#45A4D6' }};
      color: {{ section.settings.cta_text_color | default: '#0B0B0C' }};
      box-shadow: 0 6px 22px rgba(0,0,0,.35);
      transition: transform .12s ease, filter .12s ease, box-shadow .12s ease;

      /* Adjustable button width */
      width: {% if section.settings.btn_full_width_mobile %}100%{% else %}{{ section.settings.btn_width_mobile | default: 240 }}px{% endif %};
      max-width: 100%;
    }
    @media (min-width: 990px) {
      .smmt__cta {
        width: {{ section.settings.btn_width_desktop | default: 260 }}px;
      }
    }

    .smmt__cta:focus { outline: 2px solid rgba(255,255,255,.25); outline-offset: 2px; }
    .smmt__cta:hover { filter: brightness(1.07); box-shadow: 0 8px 28px rgba(0,0,0,.45); transform: translateY(-1px); }
    .smmt__cta:active { transform: translateY(0); }
  </style>

  <div class="smmt__inner">
    <h2 id="smmt-title-{{ section.id }}" class="smmt__title">
      {{ section.settings.heading | default: 'Start Making Money Today' }}
    </h2>

    {%- assign sub = section.settings.subtext | default: 'Unlock systems, tools, and coaching to start earning faster.' | strip -%}
    {%- if sub != '' -%}
      <p class="smmt__sub">{{ sub }}</p>
    {%- endif -%}

    <a
      id="smmt-btn-{{ section.id }}"
      class="smmt__cta"
      href="#top"
      aria-label="{{ section.settings.cta_label | default: 'Get Access' }}"
    >
      {{ section.settings.cta_label | default: 'Get Access' }}
    </a>
  </div>

  <script>
    (function() {
      var btn = document.getElementById('smmt-btn-{{ section.id }}');
      if (!btn) return;

      btn.addEventListener('click', function(e) {
        e.preventDefault();
        try {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        } catch (err) {
          document.documentElement.scrollTop = 0;
          document.body.scrollTop = 0;
        }
      });
    })();
  </script>
</section>

{% schema %}
{
  "name": "Start Making Money Today",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Start Making Money Today"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Optional subtext",
      "default": "Unlock systems, tools, and coaching to start earning faster."
    },

    { "type": "header", "content": "Colors" },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Get Access"
    },
    {
      "type": "color",
      "id": "cta_color",
      "label": "Button color",
      "default": "#45A4D6"
    },
    {
      "type": "color",
      "id": "cta_text_color",
      "label": "Button text color",
      "default": "#0B0B0C"
    },

    { "type": "header", "content": "Typography sizes" },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 18, "max": 80, "step": 1, "unit": "px",
      "label": "Heading size (mobile)",
      "default": 28
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "min": 24, "max": 120, "step": 1, "unit": "px",
      "label": "Heading size (desktop)",
      "default": 44
    },
    {
      "type": "range",
      "id": "subtext_size_mobile",
      "min": 12, "max": 32, "step": 1, "unit": "px",
      "label": "Subtext size (mobile)",
      "default": 15
    },
    {
      "type": "range",
      "id": "subtext_size_desktop",
      "min": 12, "max": 40, "step": 1, "unit": "px",
      "label": "Subtext size (desktop)",
      "default": 18
    },
    {
      "type": "range",
      "id": "btn_text_size_mobile",
      "min": 12, "max": 40, "step": 1, "unit": "px",
      "label": "Button text size (mobile)",
      "default": 16
    },
    {
      "type": "range",
      "id": "btn_text_size_desktop",
      "min": 12, "max": 48, "step": 1, "unit": "px",
      "label": "Button text size (desktop)",
      "default": 18
    },

    { "type": "header", "content": "Button width" },
    {
      "type": "checkbox",
      "id": "btn_full_width_mobile",
      "label": "Full-width on mobile",
      "default": false
    },
    {
      "type": "range",
      "id": "btn_width_mobile",
      "min": 120, "max": 600, "step": 10, "unit": "px",
      "label": "Button width (mobile, ignored if full-width)",
      "default": 240
    },
    {
      "type": "range",
      "id": "btn_width_desktop",
      "min": 140, "max": 720, "step": 10, "unit": "px",
      "label": "Button width (desktop)",
      "default": 260
    },

    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0, "max": 120, "step": 2, "unit": "px",
      "label": "Top padding (mobile)",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0, "max": 120, "step": 2, "unit": "px",
      "label": "Bottom padding (mobile)",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0, "max": 160, "step": 2, "unit": "px",
      "label": "Top padding (desktop)",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0, "max": 160, "step": 2, "unit": "px",
      "label": "Bottom padding (desktop)",
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "Start Making Money Today",
      "settings": {}
    }
  ]
}
{% endschema %}