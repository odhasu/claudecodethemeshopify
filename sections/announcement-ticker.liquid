{%- if section.settings.enable -%}
<div class="announcement-ticker" data-section-id="{{ section.id }}">
  <div class="ticker-track" style="animation-duration: {{ section.settings.speed_override | default: settings.ticker_speed }}s;">
    {%- capture ticker_items -%}
      <span class="ticker-item">
        <span class="ticker-highlight" data-countdown="true" data-hours="{{ section.settings.timer_hours }}" data-minutes="{{ section.settings.timer_minutes }}">
          Price goes up in <strong class="countdown-display">{{ section.settings.timer_hours }}h {{ section.settings.timer_minutes }}m</strong>
        </span>
      </span>
      <span class="ticker-dot">&#9679;</span>
      <span class="ticker-item">52 people viewing right now</span>
      <span class="ticker-dot">&#9679;</span>
      <span class="ticker-item">Rated 4.96/5 <span class="ticker-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span></span>
      <span class="ticker-dot">&#9679;</span>
      <span class="ticker-item">Free shipping on all orders</span>
      <span class="ticker-dot">&#9679;</span>
      {%- for block in section.blocks -%}
        <span class="ticker-item" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
        <span class="ticker-dot">&#9679;</span>
      {%- endfor -%}
    {%- endcapture -%}
    <div class="ticker-content">{{ ticker_items }}{{ ticker_items }}</div>
  </div>
</div>

<style>
  .announcement-ticker {
    background: var(--ticker-bg);
    color: var(--ticker-text);
    height: var(--ticker-height);
    overflow: hidden;
    position: relative;
    font-size: var(--ticker-font-size);
    font-family: var(--font-body-family);
    white-space: nowrap;
    display: flex;
    align-items: center;
  }

  .ticker-track {
    display: flex;
    align-items: center;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .ticker-content {
    display: inline-flex;
    align-items: center;
    gap: 0;
    animation: ticker-scroll var(--ticker-speed, 20s) linear infinite;
  }

  .ticker-track:hover .ticker-content {
    animation-play-state: paused;
  }

  @keyframes ticker-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .ticker-item {
    padding: 0 12px;
    letter-spacing: 0.5px;
  }

  .ticker-dot {
    color: var(--ticker-dot-color);
    font-size: 6px;
    padding: 0 4px;
    line-height: 1;
  }

  .ticker-highlight {
    color: var(--ticker-highlight);
  }

  .ticker-stars {
    color: var(--color-stars);
  }
</style>

<script>
  (function() {
    var section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;

    var countdownEl = section.querySelector('[data-countdown="true"]');
    if (!countdownEl) return;

    var hours = parseInt(countdownEl.getAttribute('data-hours')) || 0;
    var minutes = parseInt(countdownEl.getAttribute('data-minutes')) || 0;
    var totalSeconds = (hours * 3600) + (minutes * 60);
    var endTime = Date.now() + (totalSeconds * 1000);

    function updateCountdown() {
      var remaining = Math.max(0, Math.floor((endTime - Date.now()) / 1000));
      var h = Math.floor(remaining / 3600);
      var m = Math.floor((remaining % 3600) / 60);

      var displays = section.querySelectorAll('.countdown-display');
      displays.forEach(function(el) {
        el.textContent = h + 'h ' + m + 'm';
      });

      if (remaining > 0) {
        setTimeout(updateCountdown, 1000);
      }
    }

    updateCountdown();
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Ticker",
  "tag": "section",
  "class": "announcement-ticker-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable",
      "label": "Enable ticker",
      "default": true
    },
    {
      "type": "range",
      "id": "timer_hours",
      "label": "Countdown hours",
      "min": 0,
      "max": 48,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "timer_minutes",
      "label": "Countdown minutes",
      "min": 0,
      "max": 59,
      "step": 1,
      "default": 30
    },
    {
      "type": "range",
      "id": "speed_override",
      "label": "Scroll speed override (seconds, 0 = use global)",
      "min": 0,
      "max": 60,
      "step": 2,
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "custom_item",
      "name": "Custom Ticker Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Custom announcement"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Ticker"
    }
  ]
}
{% endschema %}
