{% comment %}
  Section: Simple Header (Centered Logo + Glassmorphic Menus + Elevated Cart Z)
  File: sections/header-simple.liquid
{% endcomment %}

{%- assign has_menu = false -%}
{%- if section.settings.menu != blank and section.settings.menu.links != blank -%}
  {%- assign has_menu = true -%}
{%- endif -%}

<style>
  /* ---------- Variables ---------- */
  .sh-header,
  .sh-nav-below {
    --glass-bg: rgba(18,18,22,0.52);
    --glass-border: rgba(255,255,255,0.18);
    --glass-shadow: rgba(0,0,0,0.35);
    --glass-hover: rgba(255,255,255,0.08);
  }

  /* ---------- Elevated z-index for cart UI (notification/drawer) ---------- */
  cart-notification,
  .cart-notification,
  .cart-notification__overlay,
  .cart-notification-wrapper,
  .cart-drawer,
  .cart-drawer__overlay,
  #CartDrawer,
  .drawer,
  .drawer__overlay { z-index: 10050 !important; }

  /* Disable page scroll when drawer is open */
  body.sh-no-scroll { overflow: hidden; touch-action: none; }

  /* ---------- Header layout ---------- */
  .sh-header {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto; /* left controls | spacer | right controls */
    align-items: center;
    gap: 1rem;
    /* Mobile-first padding */
    padding: {{ section.settings.padding_top_mobile | default: 12 }}px 16px {{ section.settings.padding_bottom_mobile | default: 12 }}px;
    /* no divider line */
    border-bottom: none;
  }
  @media (min-width: 990px) {
    .sh-header {
      /* Desktop-specific padding overrides */
      padding-top: {{ section.settings.padding_top_desktop | default: 16 }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop | default: 16 }}px;
    }
  }

  /* Perfect centering for the logo */
  .sh-header__logo {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%,-50%);
    margin: 0;
    pointer-events: auto;
  }
  .sh-header__logo a { display: inline-flex; align-items: center; text-decoration: none; color: inherit; }
  .sh-header__logo img { display: block; height: auto; width: auto; max-width: 100%; }

  .sh-left { display: flex; align-items: center; gap: .5rem; }
  .sh-right { justify-self: end; }

  /* ---------- Desktop nav BELOW the header (centered) ---------- */
  .sh-nav-below {
    display: none;
    width: 100%;
    padding: {{ section.settings.desktop_menu_gap | default: 24 }}px 16px 0 16px; /* space below logo */
  }
  .sh-nav-below__inner { display: flex; justify-content: center; }
  .sh-nav { display: inline-block; }
  .sh-nav__list {
    display: inline-flex;
    list-style: none;
    gap: 1.5rem;
    margin: 0;
    padding: 0;
  }
  /* Desktop top-level links — larger & bolder */
  .sh-nav__link,
  .sh-nav__summary {
    display: inline-flex;
    align-items: center;
    gap: .55rem;
    text-decoration: none;
    padding: .6rem 0;
    font: inherit;
    color: inherit;
    background: none;
    border: 0;
    cursor: pointer;
    font-size: 1.25rem;   /* 20px */
    font-weight: 700;
    line-height: 1.25;
  }
  .sh-nav__item { position: relative; }

  /* Top-level dropdown (desktop) */
  .sh-dropdown { position: relative; }
  .sh-dropdown[open] > .sh-dropdown__panel { opacity: 1; pointer-events: auto; transform: translateY(0); }
  .sh-dropdown__panel {
    position: absolute;
    top: calc(100% + 10px);
    left: 0;
    min-width: 260px;
    background: var(--glass-bg);
    -webkit-backdrop-filter: blur(14px) saturate(160%);
            backdrop-filter: blur(14px) saturate(160%);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    box-shadow: 0 18px 40px var(--glass-shadow);
    padding: 12px;
    opacity: 0; pointer-events: none; transform: translateY(6px);
    transition: opacity .18s ease, transform .18s ease;
    z-index: 700; /* below cart (10050), above page */
  }

  .sh-submenu {
    list-style: none; margin: 0; padding: 6px; display: grid; gap: 6px;
  }
  .sh-submenu a,
  .sh-sub-dropdown__summary {
    display: flex; justify-content: space-between; align-items: center;
    padding: 12px 14px; border-radius: 10px; color: inherit; text-decoration: none;
    background: transparent; border: 0; cursor: pointer; font: inherit;
    font-size: 1.125rem; /* 18px for submenu desktop */
    font-weight: 600;
  }
  .sh-submenu a:hover,
  .sh-sub-dropdown__summary:hover { background: var(--glass-hover); }

  /* Grandchild dropdown (flyout) */
  .sh-sub-dropdown { position: relative; }
  .sh-sub-dropdown[open] > .sh-sub-dropdown__panel { opacity: 1; pointer-events: auto; transform: translateX(0); }
  .sh-sub-dropdown__panel {
    position: absolute; top: -6px; left: calc(100% + 10px);
    min-width: 240px;
    background: var(--glass-bg);
    -webkit-backdrop-filter: blur(14px) saturate(160%);
            backdrop-filter: blur(14px) saturate(160%);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    box-shadow: 0 18px 40px var(--glass-shadow);
    padding: 12px;
    opacity: 0; pointer-events: none; transform: translateX(6px);
    transition: opacity .18s ease, transform .18s ease;
    z-index: 705;
  }

  /* Carets */
  .sh-icon { width: 18px; height: 18px; display: inline-block; }
  .sh-caret--down { transform: rotate(90deg); }
  .sh-caret--right { transform: rotate(0deg); }
  details[open] > summary .sh-caret--down { transform: rotate(-90deg); transition: transform .18s ease; }
  .sh-sub-dropdown[open] > summary .sh-caret--right { transform: rotate(90deg); transition: transform .18s ease; }

  /* ---------- Mobile glass drawer (flush with header, no divider) ---------- */
  .sh-drawer { display: flex; position: relative; }
  .sh-drawer__toggle {
    list-style: none;
    display: inline-flex; align-items: center; justify-content: center;
    width: 44px; height: 44px;
    border-radius: 12px;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    -webkit-backdrop-filter: blur(14px) saturate(160%);
            backdrop-filter: blur(14px) saturate(160%);
    box-shadow: 0 12px 30px var(--glass-shadow);
    cursor: pointer; user-select: none; padding: 0;
  }
  .sh-drawer__toggle::-webkit-details-marker { display: none; }

  /* Hamburger → X icon */
  .sh-hamburger {
    position: relative;
    width: 24px; height: 18px; display: inline-block;
  }
  .sh-hamburger span {
    position: absolute; left: 0; right: 0; height: 2px; background: currentColor; border-radius: 1px;
    transition: transform .2s ease, opacity .2s ease, top .2s ease;
  }
  .sh-hamburger span:nth-child(1) { top: 2px; }
  .sh-hamburger span:nth-child(2) { top: 8px; }
  .sh-hamburger span:nth-child(3) { top: 14px; }
  /* When open, morph to X */
  .sh-drawer[open] .sh-hamburger span:nth-child(1) { top: 8px; transform: rotate(45deg); }
  .sh-drawer[open] .sh-hamburger span:nth-child(2) { opacity: 0; }
  .sh-drawer[open] .sh-hamburger span:nth-child(3) { top: 8px; transform: rotate(-45deg); }

  /* Fullscreen overlay (starts exactly at header bottom) */
  .sh-drawer__overlay {
    position: fixed; left: 0; right: 0; top: 0; bottom: 0;
    background: rgba(10,10,14,0.36);
    -webkit-backdrop-filter: blur(2px);
            backdrop-filter: blur(2px);
    opacity: 0; pointer-events: none;
    transition: opacity .18s ease;
    z-index: 9800;
  }

  /* Drawer panel connects to header: full width, no top border/radius, no top inset line */
  .sh-drawer__panel {
    position: fixed; left: 0; right: 0; top: 0;
    background: linear-gradient(180deg, rgba(22,22,28,0.58), rgba(14,14,18,0.50));
    -webkit-backdrop-filter: blur(16px) saturate(170%);
            backdrop-filter: blur(16px) saturate(170%);
    border: 1px solid var(--glass-border);
    border-top: none; /* no divider line against header */
    border-top-left-radius: 0; border-top-right-radius: 0;
    border-bottom-left-radius: 16px; border-bottom-right-radius: 16px;
    box-shadow: 0 18px 40px var(--glass-shadow); /* removed inset top line */
    padding: 12px;
    z-index: 9900;
    opacity: 0; pointer-events: none; transform: translateY(-8px);
    transition: opacity .18s ease, transform .18s ease;
    max-height: calc(100vh - 24px);
    overflow: auto;
  }

  /* Open states */
  .sh-drawer[open] .sh-drawer__overlay { opacity: 1; pointer-events: auto; }
  .sh-drawer[open] .sh-drawer__panel { opacity: 1; pointer-events: auto; transform: translateY(0); }

  /* Mobile nav list — larger & bolder */
  .sh-mnav { list-style: none; margin: 0; padding: 0; display: grid; gap: 10px; }
  .sh-mnav a,
  .sh-mnav summary {
    display: flex; justify-content: space-between; align-items: center;
    padding: 14px; border-radius: 12px; text-decoration: none; color: inherit; background: transparent; border: 0; cursor: pointer;
    font-size: 1.3125rem;   /* 21px */
    font-weight: 700;
    line-height: 1.25;
  }
  .sh-mnav a:hover,
  .sh-mnav summary:hover { background: var(--glass-hover); }
  .sh-mnav details[open] > .sh-mnav__panel { display: grid; }
  .sh-mnav__panel { display: none; padding-left: 8px; gap: 8px; }
  .sh-mnav__panel a { font-size: 1.1875rem; font-weight: 600; } /* 19px for nested items */

  /* Reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .sh-drawer__panel,
    .sh-drawer__overlay,
    .sh-dropdown__panel,
    .sh-sub-dropdown__panel { transition: none !important; }
  }

  /* ---------- Responsive visibility ---------- */
  @media (min-width: 990px) {
    .sh-nav-below { display: block; }
    .sh-drawer { display: none; }
  }
</style>

<header class="sh-header" id="sh-header-{{ section.id }}">
  <div class="sh-left">
    {%- if has_menu -%}
    <!-- Mobile hamburger (icon morphs to X on open) -->
    <details class="sh-drawer" id="sh-drawer-{{ section.id }}" data-drawer>
      <summary class="sh-drawer__toggle" aria-label="Open navigation" aria-controls="sh-drawer-panel-{{ section.id }}" aria-expanded="false">
        <span class="sh-hamburger" aria-hidden="true">
          <span></span><span></span><span></span>
        </span>
      </summary>

      <div class="sh-drawer__overlay" role="button" aria-label="Close navigation"></div>

      <div class="sh-drawer__panel" id="sh-drawer-panel-{{ section.id }}" role="dialog" aria-modal="true" aria-label="Mobile navigation">
        <ul class="sh-mnav" role="list">
          {%- for link in section.settings.menu.links -%}
            <li>
              {%- if link.links != blank -%}
                <details>
                  <summary>
                    <span>{{ link.title | escape }}</span>
                    <svg class="sh-icon sh-caret--down" viewBox="0 0 10 10" aria-hidden="true"><path d="M1 2.5l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </summary>
                  <div class="sh-mnav__panel">
                    {%- for childlink in link.links -%}
                      {%- if childlink.links == blank -%}
                        <a href="{{ childlink.url }}" class="link">{{ childlink.title | escape }}</a>
                      {%- else -%}
                        <details>
                          <summary>
                            <span>{{ childlink.title | escape }}</span>
                            <svg class="sh-icon sh-caret--down" viewBox="0 0 10 10" aria-hidden="true"><path d="M1 2.5l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                          </summary>
                          <div class="sh-mnav__panel">
                            {%- for grandchildlink in childlink.links -%}
                              <a href="{{ grandchildlink.url }}" class="link">{{ grandchildlink.title | escape }}</a>
                            {%- endfor -%}
                          </div>
                        </details>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                </details>
              {%- else -%}
                <a href="{{ link.url }}" class="link">{{ link.title | escape }}</a>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      </div>
    </details>
    {%- endif -%}
  </div>

  <!-- Centered logo -->
  <h1 class="sh-header__logo" style="font-size:0;">
    <a href="{{ routes.root_url }}" class="sh-logo-link" aria-label="{{ shop.name | escape }}">
      {%- if settings.logo != blank -%}
        {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
        {%- assign logo_height = section.settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
        {% capture sizes %}(max-width: {{ section.settings.logo_width | times: 2 }}px) 50vw, {{ section.settings.logo_width }}px{% endcapture %}
        {% capture widths %}{{ section.settings.logo_width }}, {{ section.settings.logo_width | times: 1.5 | round }}, {{ section.settings.logo_width | times: 2 }}{% endcapture %}
        {{ settings.logo | image_url: width: 600 | image_tag:
          class: 'sh-logo',
          widths: widths,
          height: logo_height,
          width: section.settings.logo_width,
          alt: logo_alt,
          sizes: sizes,
          preload: true
        }}
      {%- else -%}
        <span class="h3" style="margin:0;">{{ shop.name }}</span>
      {%- endif -%}
    </a>
  </h1>

  <div class="sh-right"><!-- Optional right-side icons --></div>
</header>

{%- if has_menu -%}
<!-- Desktop nav centered and a bit below the logo -->
<nav class="sh-nav-below" role="navigation" aria-label="Main">
  <div class="sh-nav-below__inner">
    <div class="sh-nav">
      <ul class="sh-nav__list" role="list">
        {%- for link in section.settings.menu.links -%}
          <li class="sh-nav__item">
            {%- if link.links != blank -%}
              <details class="sh-dropdown">
                <summary class="sh-nav__summary" aria-haspopup="menu" aria-expanded="false">
                  <span>{{ link.title | escape }}</span>
                  <svg class="sh-icon sh-caret--down" viewBox="0 0 10 10" aria-hidden="true"><path d="M1 2.5l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </summary>
                <div class="sh-dropdown__panel">
                  <ul class="sh-submenu" role="list">
                    {%- for childlink in link.links -%}
                      <li>
                        {%- if childlink.links == blank -%}
                          <a href="{{ childlink.url }}">{{ childlink.title | escape }}</a>
                        {%- else -%}
                          <details class="sh-sub-dropdown">
                            <summary class="sh-sub-dropdown__summary">
                              <span>{{ childlink.title | escape }}</span>
                              <svg class="sh-icon sh-caret--right" viewBox="0 0 10 10" aria-hidden="true"><path d="M3 1l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            </summary>
                            <div class="sh-sub-dropdown__panel">
                              <ul class="sh-submenu" role="list">
                                {%- for grandchildlink in childlink.links -%}
                                  <li><a href="{{ grandchildlink.url }}">{{ grandchildlink.title | escape }}</a></li>
                                {%- endfor -%}
                              </ul>
                            </div>
                          </details>
                        {%- endif -%}
                      </li>
                    {%- endfor -%}
                  </ul>
                </div>
              </details>
            {%- else -%}
              <a class="sh-nav__link" href="{{ link.url }}">{{ link.title | escape }}</a>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </div>
</nav>
{%- endif -%}

<script>
  /* Mobile drawer behavior: toggle, ESC, overlay close, and align panel EXACTLY to header bottom */
  (function() {
    var drawer = document.getElementById('sh-drawer-{{ section.id }}');
    var header = document.getElementById('sh-header-{{ section.id }}');
    if (!drawer || !header) return;

    var summary = drawer.querySelector('summary.sh-drawer__toggle');
    var overlay = drawer.querySelector('.sh-drawer__overlay');
    var panel = drawer.querySelector('.sh-drawer__panel');

    function headerBottomPx() {
      var rect = header.getBoundingClientRect();
      var bottom = Math.max(rect.bottom, 0); // viewport px from top
      return bottom + 'px';
    }

    function syncTop() {
      var topPx = headerBottomPx();
      overlay.style.top = topPx;
      panel.style.top = topPx;
      /* keep bottom breathing room for rounded corners */
      var topVal = parseFloat(topPx) || 0;
      panel.style.maxHeight = 'calc(100vh - ' + (topVal + 16) + 'px)';
    }

    function openDrawer() {
      syncTop();
      drawer.setAttribute('open', '');
      summary.setAttribute('aria-expanded', 'true');
      document.body.classList.add('sh-no-scroll');
    }

    function closeDrawer() {
      drawer.removeAttribute('open');
      summary.setAttribute('aria-expanded', 'false');
      document.body.classList.remove('sh-no-scroll');
    }

    summary.addEventListener('click', function(e) {
      e.preventDefault();
      if (drawer.hasAttribute('open')) { closeDrawer(); } else { openDrawer(); }
    });

    if (overlay) overlay.addEventListener('click', closeDrawer);

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && drawer.hasAttribute('open')) { closeDrawer(); }
    });

    window.addEventListener('resize', function() {
      if (drawer.hasAttribute('open')) syncTop();
    });

    /* If theme uses sticky header and it changes height on scroll, track it */
    document.addEventListener('scroll', function() {
      if (drawer.hasAttribute('open')) syncTop();
    }, { passive: true });
  })();
</script>

{% schema %}
{
  "name": "Simple Header",
  "class": "section-header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 60,
      "max": 260,
      "step": 10,
      "unit": "px",
      "label": "Logo width",
      "default": 120
    },

    { "type": "header", "content": "Mobile padding" },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Padding top (mobile)",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom (mobile)",
      "default": 12
    },

    { "type": "header", "content": "Desktop padding" },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Padding top (desktop)",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom (desktop)",
      "default": 16
    },

    {
      "type": "range",
      "id": "desktop_menu_gap",
      "min": 0,
      "max": 64,
      "step": 2,
      "unit": "px",
      "label": "Desktop: space between logo and menu",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Simple Header",
      "settings": { "logo_width": 120 }
    }
  ]
}
{% endschema %}