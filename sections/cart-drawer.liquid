<section class="vx-shell" data-vx-section="cart-drawer">
  <div class="vx-editor-preview"></div>
</section>

<script type="application/json" data-vx-settings="cart-drawer">
{
  "title": {{ section.settings.title | default: 'Your Cart' | json }},
  "checkout_text": {{ section.settings.checkout_text | default: 'Checkout' | json }},
  "drawer_width": {{ section.settings.drawer_width | default: 400 }},
  "overlay_opacity": {{ section.settings.overlay_opacity | default: 60 }},
  "drawer_bg": {{ section.settings.drawer_bg | default: '#0a0a0a' | json }},
  "item_bg": {{ section.settings.item_bg | default: '#111111' | json }},
  "border_color": {{ section.settings.border_color | default: '#1a1a1a' | json }},
  "text_color": {{ section.settings.text_color | default: '#ffffff' | json }},
  "muted_color": {{ section.settings.muted_color | default: '#6b7280' | json }},
  "accent_color": {{ section.settings.accent_color | default: '#19d400' | json }},
  "btn_text_color": {{ section.settings.btn_text_color | default: '#000000' | json }}
}
</script>

{% schema %}
{
  "name": "Cart Drawer",
  "tag": "div",
  "limit": 1,
  "settings": [
    { "type": "header", "content": "General" },
    { "type": "text", "id": "title", "label": "Drawer title", "default": "Your Cart" },
    { "type": "text", "id": "checkout_text", "label": "Checkout button text", "default": "Checkout" },
    { "type": "range", "id": "drawer_width", "label": "Drawer width (px)", "min": 320, "max": 520, "step": 10, "default": 400 },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity (%)", "min": 20, "max": 90, "step": 5, "default": 60 },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "drawer_bg", "label": "Drawer background", "default": "#0a0a0a" },
    { "type": "color", "id": "item_bg", "label": "Item background", "default": "#111111" },
    { "type": "color", "id": "border_color", "label": "Border color", "default": "#1a1a1a" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" },
    { "type": "color", "id": "muted_color", "label": "Muted text color", "default": "#6b7280" },
    { "type": "color", "id": "accent_color", "label": "Accent / price color", "default": "#19d400" },
    { "type": "color", "id": "btn_text_color", "label": "Checkout button text", "default": "#000000" }
  ]
}
{% endschema %}
