<style>
  .auth-page { max-width:420px;margin:0 auto;padding:80px 20px;text-align:center; }
  .auth-page h1 { font-family:var(--font-heading);font-size:28px;text-transform:uppercase;margin-bottom:32px; }
  .auth-page form { display:flex;flex-direction:column;gap:16px; }
  .auth-page input { padding:14px 16px;border-radius:var(--radius-button);border:1px solid var(--color-border);background:var(--color-card-bg);color:#fff;font-size:14px; }
  .auth-page button { padding:14px;border-radius:var(--radius-button);background:var(--color-accent);color:#000;font-weight:800;font-size:14px;text-transform:uppercase;border:none;cursor:pointer; }
  .auth-page a { color:var(--color-text-muted);font-size:13px; }
</style>
<section class="auth-page">
  <h1>Create Account</h1>
  {%- form 'create_customer' -%}
    {{ form.errors | default_errors }}
    <input type="text" name="customer[first_name]" placeholder="First name" autocomplete="given-name">
    <input type="text" name="customer[last_name]" placeholder="Last name" autocomplete="family-name">
    <input type="email" name="customer[email]" placeholder="Email" autocomplete="email" required>
    <input type="password" name="customer[password]" placeholder="Password" autocomplete="new-password" required>
    <button type="submit">Create</button>
    <a href="/account/login">Already have an account? Sign in</a>
  {%- endform -%}
</section>
{% schema %}
{ "name": "Register", "tag": "section", "settings": [] }
{% endschema %}
