{%- liquid
  assign title = section.settings.title | default: 'Frequently Asked Questions'
  assign title_color = section.settings.title_color | default: '#ffffff'
  assign card_bg = section.settings.card_bg | default: '#111111'
  assign card_border = section.settings.card_border | default: '#2a2a2a'
  assign card_border_open = section.settings.card_border_open | default: '#39ff14'
  assign question_color = section.settings.question_color | default: '#ffffff'
  assign answer_color = section.settings.answer_color | default: '#9ca3af'
  assign toggle_bg = section.settings.toggle_bg | default: '#1a1a1a'
  assign toggle_bg_open = section.settings.toggle_bg_open | default: '#39ff14'
  assign toggle_icon_color = section.settings.toggle_icon_color | default: '#ffffff'
  assign toggle_icon_open = section.settings.toggle_icon_open | default: '#1a1a1a'
  assign max_width = section.settings.max_width | default: 700
-%}

<style>
  .faq-section {
    padding: {{ section.settings.padding_top | default: 60 }}px 20px {{ section.settings.padding_bottom | default: 60 }}px;
  }
  .faq-title {
    text-align: center;
    font-family: var(--font-heading);
    font-size: clamp(24px, 4vw, 36px);
    text-transform: uppercase;
    color: {{ title_color }};
    margin-bottom: 40px;
  }
  .faq-list {
    max-width: {{ max_width }}px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.item_gap | default: 12 }}px;
  }
  .faq-item {
    background: {{ card_bg }};
    border: 1px solid {{ card_border }};
    border-radius: {{ section.settings.card_radius | default: 12 }}px;
    overflow: hidden;
    transition: border-color 0.3s;
  }
  .faq-item.open { border-color: {{ card_border_open }}; }
  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: {{ section.settings.card_padding | default: 18 }}px;
    cursor: pointer;
    gap: 16px;
    width: 100%;
    background: none;
    border: none;
    text-align: left;
    color: {{ question_color }};
    font-size: {{ section.settings.question_font_size | default: 15 }}px;
    font-weight: 600;
    font-family: inherit;
  }
  .faq-toggle {
    width: {{ section.settings.toggle_size | default: 32 }}px;
    height: {{ section.settings.toggle_size | default: 32 }}px;
    border-radius: 50%;
    background: {{ toggle_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.3s, transform 0.3s;
  }
  .faq-toggle svg { width: 14px; height: 14px; stroke: {{ toggle_icon_color }}; transition: stroke 0.3s; }
  .faq-item.open .faq-toggle {
    background: {{ toggle_bg_open }};
    transform: rotate(180deg);
  }
  .faq-item.open .faq-toggle svg { stroke: {{ toggle_icon_open }}; }
  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease;
  }
  .faq-answer-inner {
    padding: 0 {{ section.settings.card_padding | default: 18 }}px {{ section.settings.card_padding | default: 18 }}px;
    font-size: {{ section.settings.answer_font_size | default: 14 }}px;
    color: {{ answer_color }};
    line-height: 1.7;
  }
</style>

<section class="faq-section">
  <h2 class="faq-title">{{ title }}</h2>
  <div class="faq-list">
    {%- for block in section.blocks -%}
      {%- if block.type == 'question' -%}
        <div class="faq-item" {{ block.shopify_attributes }}>
          <button class="faq-question" onclick="toggleFaq(this)">
            <span>{{ block.settings.question }}</span>
            <span class="faq-toggle">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">{{ block.settings.answer }}</div>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

<script>
  function toggleFaq(btn) {
    var item = btn.closest('.faq-item');
    var answer = item.querySelector('.faq-answer');
    var isOpen = item.classList.contains('open');
    // Close all
    document.querySelectorAll('.faq-item.open').forEach(function(el) {
      el.classList.remove('open');
      el.querySelector('.faq-answer').style.maxHeight = '0';
    });
    // Open clicked if was closed
    if (!isOpen) {
      item.classList.add('open');
      answer.style.maxHeight = answer.scrollHeight + 'px';
    }
  }
</script>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Frequently Asked Questions" },
    { "type": "color", "id": "title_color", "label": "Title color", "default": "#ffffff" },
    { "type": "header", "content": "Card Styling" },
    { "type": "color", "id": "card_bg", "label": "Card background", "default": "#111111" },
    { "type": "color", "id": "card_border", "label": "Card border", "default": "#2a2a2a" },
    { "type": "color", "id": "card_border_open", "label": "Card border (open)", "default": "#39ff14" },
    { "type": "range", "id": "card_radius", "label": "Border radius (px)", "min": 0, "max": 24, "step": 2, "default": 12 },
    { "type": "range", "id": "card_padding", "label": "Card padding (px)", "min": 12, "max": 28, "step": 2, "default": 18 },
    { "type": "range", "id": "item_gap", "label": "Gap between items (px)", "min": 4, "max": 24, "step": 2, "default": 12 },
    { "type": "range", "id": "max_width", "label": "Max width (px)", "min": 400, "max": 900, "step": 50, "default": 700 },
    { "type": "header", "content": "Text" },
    { "type": "color", "id": "question_color", "label": "Question color", "default": "#ffffff" },
    { "type": "color", "id": "answer_color", "label": "Answer color", "default": "#9ca3af" },
    { "type": "range", "id": "question_font_size", "label": "Question font size (px)", "min": 13, "max": 22, "step": 1, "default": 15 },
    { "type": "range", "id": "answer_font_size", "label": "Answer font size (px)", "min": 12, "max": 18, "step": 1, "default": 14 },
    { "type": "header", "content": "Toggle Icon" },
    { "type": "range", "id": "toggle_size", "label": "Toggle circle size (px)", "min": 24, "max": 44, "step": 2, "default": 32 },
    { "type": "color", "id": "toggle_bg", "label": "Toggle background", "default": "#1a1a1a" },
    { "type": "color", "id": "toggle_bg_open", "label": "Toggle background (open)", "default": "#39ff14" },
    { "type": "color", "id": "toggle_icon_color", "label": "Icon color", "default": "#ffffff" },
    { "type": "color", "id": "toggle_icon_open", "label": "Icon color (open)", "default": "#1a1a1a" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Top padding (px)", "min": 0, "max": 120, "step": 10, "default": 60 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding (px)", "min": 0, "max": 120, "step": 10, "default": 60 }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "FAQ Item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Is this legit?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Yes! All vendors are personally verified and tested.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "question", "settings": { "question": "Is this legit?", "answer": "<p>Yes! I personally use these suppliers and have verified every single one. These are real, working vendor contacts.</p>" } },
        { "type": "question", "settings": { "question": "How will I receive the vendors?", "answer": "<p>Once you purchase, vendor links are INSTANTLY sent through email. You'll have access within minutes.</p>" } },
        { "type": "question", "settings": { "question": "Can I get a refund?", "answer": "<p>Due to the digital nature of the product, all sales are final. However, we stand behind our product 100%.</p>" } },
        { "type": "question", "settings": { "question": "How many vendors are included?", "answer": "<p>Each bundle contains multiple verified vendors with contact information and pricing details.</p>" } }
      ]
    }
  ]
}
{% endschema %}
