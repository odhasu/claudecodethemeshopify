<style>
  #faq-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  #faq-{{ section.id }} .faq__container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }
  #faq-{{ section.id }} .faq__title {
    text-align: center;
    font-family: var(--font-heading, 'Clash Grotesk', sans-serif);
    font-weight: 700;
    font-size: 28px;
    text-transform: uppercase;
    color: {{ section.settings.title_color }};
    margin: 0 0 32px;
    line-height: 1.2;
  }
  #faq-{{ section.id }} .faq__items {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.item_gap }}px;
  }
  #faq-{{ section.id }} .faq__item {
    background: {{ section.settings.card_bg }};
    border: 1px solid {{ section.settings.card_border }};
    border-radius: {{ section.settings.card_radius }}px;
    padding: {{ section.settings.card_padding }}px;
    transition: border-color 0.3s ease;
  }
  #faq-{{ section.id }} .faq__item.is-open {
    border-color: {{ section.settings.card_border_open }};
  }
  #faq-{{ section.id }} .faq__question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    gap: 16px;
    -webkit-user-select: none;
    user-select: none;
  }
  #faq-{{ section.id }} .faq__question-text {
    color: {{ section.settings.question_color }};
    font-size: {{ section.settings.question_font_size }}px;
    font-weight: 600;
    line-height: 1.4;
    margin: 0;
  }
  #faq-{{ section.id }} .faq__toggle {
    width: {{ section.settings.toggle_size }}px;
    height: {{ section.settings.toggle_size }}px;
    min-width: {{ section.settings.toggle_size }}px;
    border-radius: 50%;
    background: {{ section.settings.toggle_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s ease;
  }
  #faq-{{ section.id }} .faq__item.is-open .faq__toggle {
    background: {{ section.settings.toggle_bg_open }};
  }
  #faq-{{ section.id }} .faq__toggle svg {
    width: 14px;
    height: 14px;
    transition: transform 0.3s ease;
    color: {{ section.settings.toggle_icon_color }};
  }
  #faq-{{ section.id }} .faq__item.is-open .faq__toggle svg {
    transform: rotate(180deg);
    color: {{ section.settings.toggle_icon_open }};
  }
  #faq-{{ section.id }} .faq__answer-wrapper {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease;
  }
  #faq-{{ section.id }} .faq__answer {
    padding-top: 12px;
    color: {{ section.settings.answer_color }};
    font-size: {{ section.settings.answer_font_size }}px;
    line-height: 1.6;
  }
  #faq-{{ section.id }} .faq__answer p {
    margin: 0;
  }
</style>

<div id="faq-{{ section.id }}">
  <div class="faq__container">
    <h2 class="faq__title">{{ section.settings.title }}</h2>
    <div class="faq__items" data-faq-accordion>
      {%- for block in section.blocks -%}
        {%- if block.type == 'question' -%}
          <div class="faq__item{% if forloop.first %} is-open{% endif %}" data-faq-item {{ block.shopify_attributes }}>
            <div class="faq__question" data-faq-trigger>
              <span class="faq__question-text">{{ block.settings.question }}</span>
              <div class="faq__toggle">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </div>
            </div>
            <div class="faq__answer-wrapper" data-faq-answer {% if forloop.first %}style="max-height: 500px;"{% endif %}>
              <div class="faq__answer">{{ block.settings.answer }}</div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<script>
  (function() {
    var section = document.getElementById('faq-{{ section.id }}');
    if (!section) return;

    var items = section.querySelectorAll('[data-faq-item]');

    items.forEach(function(item) {
      var trigger = item.querySelector('[data-faq-trigger]');
      var answer = item.querySelector('[data-faq-answer]');

      trigger.addEventListener('click', function() {
        var isOpen = item.classList.contains('is-open');

        // Close all items
        items.forEach(function(other) {
          other.classList.remove('is-open');
          var otherAnswer = other.querySelector('[data-faq-answer]');
          otherAnswer.style.maxHeight = '0';
        });

        // Open clicked item if it was closed
        if (!isOpen) {
          item.classList.add('is-open');
          answer.style.maxHeight = answer.scrollHeight + 'px';
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Frequently Asked Questions" },
    { "type": "color", "id": "title_color", "label": "Title color", "default": "#ffffff" },
    { "type": "header", "content": "Card Styling" },
    { "type": "color", "id": "card_bg", "label": "Card background", "default": "#111111" },
    { "type": "color", "id": "card_border", "label": "Card border", "default": "#2a2a2a" },
    { "type": "color", "id": "card_border_open", "label": "Card border (open)", "default": "#19d400" },
    { "type": "range", "id": "card_radius", "label": "Border radius (px)", "min": 0, "max": 24, "step": 2, "default": 12 },
    { "type": "range", "id": "card_padding", "label": "Card padding (px)", "min": 12, "max": 28, "step": 2, "default": 18 },
    { "type": "range", "id": "item_gap", "label": "Gap between items (px)", "min": 4, "max": 24, "step": 2, "default": 12 },
    { "type": "range", "id": "max_width", "label": "Max width (px)", "min": 400, "max": 900, "step": 50, "default": 700 },
    { "type": "header", "content": "Text" },
    { "type": "color", "id": "question_color", "label": "Question color", "default": "#ffffff" },
    { "type": "color", "id": "answer_color", "label": "Answer color", "default": "#9ca3af" },
    { "type": "range", "id": "question_font_size", "label": "Question font size (px)", "min": 13, "max": 22, "step": 1, "default": 15 },
    { "type": "range", "id": "answer_font_size", "label": "Answer font size (px)", "min": 12, "max": 18, "step": 1, "default": 14 },
    { "type": "header", "content": "Toggle Icon" },
    { "type": "range", "id": "toggle_size", "label": "Toggle circle size (px)", "min": 24, "max": 44, "step": 2, "default": 32 },
    { "type": "color", "id": "toggle_bg", "label": "Toggle background", "default": "#1a1a1a" },
    { "type": "color", "id": "toggle_bg_open", "label": "Toggle background (open)", "default": "#19d400" },
    { "type": "color", "id": "toggle_icon_color", "label": "Icon color", "default": "#ffffff" },
    { "type": "color", "id": "toggle_icon_open", "label": "Icon color (open)", "default": "#1a1a1a" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Top padding (px)", "min": 0, "max": 120, "step": 10, "default": 60 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding (px)", "min": 0, "max": 120, "step": 10, "default": 60 }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "FAQ Item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Is this legit?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Yes! All vendors are personally verified and tested.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "question", "settings": { "question": "Is this legit?", "answer": "<p>Yes! I personally use these suppliers and have verified every single one. These are real, working vendor contacts.</p>" } },
        { "type": "question", "settings": { "question": "How will I receive the vendors?", "answer": "<p>Once you purchase, vendor links are INSTANTLY sent through email. You'll have access within minutes.</p>" } },
        { "type": "question", "settings": { "question": "Can I get a refund?", "answer": "<p>Due to the digital nature of the product, all sales are final. However, we stand behind our product 100%.</p>" } },
        { "type": "question", "settings": { "question": "How many vendors are included?", "answer": "<p>Each bundle contains multiple verified vendors with contact information and pricing details.</p>" } }
      ]
    }
  ]
}
{% endschema %}
