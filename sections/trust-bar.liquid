{%- liquid
  assign bg_style = section.settings.bg_style | default: 'transparent'
  assign text_color = section.settings.text_color | default: settings.color_text_muted | default: '#9ca3af'
  assign icon_color = section.settings.icon_color | default: settings.color_accent | default: '#39ff14'
  assign sep_color = section.settings.separator_color | default: '#333333'
  assign bar_height = section.settings.bar_height | default: 48
  assign font_size = section.settings.font_size | default: 13
  assign speed = section.settings.scroll_speed | default: 25
  assign show_sep = section.settings.show_separators
-%}

<style>
  .trust-bar {
    {%- if bg_style == 'card' %}
    background: {{ settings.color_card_bg | default: '#111111' }};
    border-top: 1px solid {{ settings.color_border | default: '#2a2a2a' }};
    border-bottom: 1px solid {{ settings.color_border | default: '#2a2a2a' }};
    {%- elsif bg_style == 'gradient' %}
    background: linear-gradient(to right, transparent, rgba(255,255,255,0.03), transparent);
    border-top: 1px solid {{ settings.color_border | default: '#2a2a2a' }};
    border-bottom: 1px solid {{ settings.color_border | default: '#2a2a2a' }};
    {%- else %}
    background: transparent;
    {%- endif %}
    height: {{ bar_height }}px;
    overflow: hidden;
    padding: {{ section.settings.padding_top | default: 0 }}px 0 {{ section.settings.padding_bottom | default: 0 }}px;
  }
  .trust-track {
    display: flex;
    align-items: center;
    height: 100%;
    white-space: nowrap;
    animation: trustScroll {{ speed }}s linear infinite;
    width: max-content;
  }
  .trust-bar:hover .trust-track { animation-play-state: paused; }
  @keyframes trustScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0 28px;
    font-size: {{ font_size }}px;
    font-weight: 600;
    color: {{ text_color }};
    letter-spacing: 0.02em;
    white-space: nowrap;
  }
  .trust-badge-icon {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    color: {{ icon_color }};
  }
  .trust-badge-icon svg {
    width: 16px; height: 16px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .trust-badge-icon--filled svg { fill: currentColor; stroke: currentColor; }
  .trust-sep {
    display: inline-block;
    width: 4px; height: 4px;
    border-radius: 50%;
    background: {{ sep_color }};
    flex-shrink: 0;
    {%- unless show_sep %}display: none;{%- endunless %}
  }
</style>

<div class="trust-bar" role="region" aria-label="Trust indicators">
  <div class="trust-track">
    {%- for i in (1..2) -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'badge' -%}
          <span class="trust-badge" {{ block.shopify_attributes }}>
            {%- liquid
              assign icon = block.settings.icon | default: 'check'
            -%}
            <span class="trust-badge-icon{% if icon == 'users' or icon == 'shield' or icon == 'star' %} trust-badge-icon--filled{% endif %}">
              {%- if icon == 'check' -%}
                <svg viewBox="0 0 24 24"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
              {%- elsif icon == 'shield' -%}
                <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              {%- elsif icon == 'bolt' -%}
                <svg viewBox="0 0 24 24"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              {%- elsif icon == 'headset' -%}
                <svg viewBox="0 0 24 24"><path d="M3 18v-6a9 9 0 0118 0v6"/><path d="M21 19a2 2 0 01-2 2h-1a2 2 0 01-2-2v-3a2 2 0 012-2h3zM3 19a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 00-2-2H3z"/></svg>
              {%- elsif icon == 'lock' -%}
                <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
              {%- elsif icon == 'users' -%}
                <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
              {%- elsif icon == 'star' -%}
                <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {%- elsif icon == 'truck' -%}
                <svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {%- endif -%}
            </span>
            {{ block.settings.text }}
          </span>
          {%- unless forloop.last -%}<span class="trust-sep"></span>{%- endunless -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Trust Bar",
  "tag": "section",
  "settings": [
    { "type": "select", "id": "bg_style", "label": "Background", "default": "gradient", "options": [
      { "value": "transparent", "label": "Transparent" },
      { "value": "card", "label": "Card background" },
      { "value": "gradient", "label": "Subtle gradient" }
    ]},
    { "type": "color", "id": "text_color", "label": "Text colour", "default": "#9ca3af" },
    { "type": "color", "id": "icon_color", "label": "Icon colour", "default": "#39ff14" },
    { "type": "color", "id": "separator_color", "label": "Separator dot colour", "default": "#333333" },
    { "type": "checkbox", "id": "show_separators", "label": "Show separator dots", "default": true },
    { "type": "range", "id": "bar_height", "label": "Bar height (px)", "min": 36, "max": 72, "step": 4, "default": 48 },
    { "type": "range", "id": "font_size", "label": "Font size (px)", "min": 11, "max": 18, "step": 1, "default": 13 },
    { "type": "range", "id": "scroll_speed", "label": "Scroll speed (seconds)", "min": 10, "max": 60, "step": 5, "default": 25 },
    { "type": "range", "id": "padding_top", "label": "Top padding (px)", "min": 0, "max": 40, "step": 4, "default": 0 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding (px)", "min": 0, "max": 40, "step": 4, "default": 0 }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        { "type": "text", "id": "text", "label": "Badge text", "default": "Verified Seller" },
        { "type": "select", "id": "icon", "label": "Icon", "default": "check", "options": [
          { "value": "check", "label": "Checkmark" },
          { "value": "shield", "label": "Shield" },
          { "value": "bolt", "label": "Bolt / Lightning" },
          { "value": "headset", "label": "Headset / Support" },
          { "value": "lock", "label": "Lock" },
          { "value": "users", "label": "Users / People" },
          { "value": "star", "label": "Star" },
          { "value": "truck", "label": "Truck / Delivery" }
        ]}
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Bar",
      "blocks": [
        { "type": "badge", "settings": { "text": "5,000+ Happy Customers", "icon": "users" } },
        { "type": "badge", "settings": { "text": "Verified Seller", "icon": "shield" } },
        { "type": "badge", "settings": { "text": "24/7 Support", "icon": "headset" } },
        { "type": "badge", "settings": { "text": "Instant Access", "icon": "bolt" } }
      ]
    }
  ]
}
{% endschema %}
