<style>
  .page-content {
    max-width: 800px;
    margin: 0 auto;
    padding: 60px 20px;
    color: var(--color-text-muted);
    line-height: 1.8;
  }
  .page-content h1 {
    font-family: var(--font-heading);
    font-size: clamp(28px, 4vw, 42px);
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 24px;
  }
  .page-content h2, .page-content h3 { color: #fff; margin-top: 32px; margin-bottom: 12px; }
  .page-content a { color: var(--color-accent); text-decoration: underline; }
  .page-content p { margin-bottom: 16px; }
</style>

<section class="page-content">
  <h1>{{ page.title }}</h1>
  {{ page.content }}
</section>

{% schema %}
{
  "name": "Page Content",
  "tag": "section",
  "settings": []
}
{% endschema %}
