<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ shop.name }}</title>
  {{ content_for_header }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  <style>
    body { background: #000; color: #fff; font-family: system-ui, sans-serif; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
    .password-page { text-align: center; padding: 40px; }
    .password-page h1 { font-family: 'Anton', sans-serif; font-size: 3rem; text-transform: uppercase; margin-bottom: 20px; }
    .password-page p { color: #9ca3af; margin-bottom: 30px; }
    .password-page form input { padding: 12px 20px; border-radius: 8px; border: 1px solid #2a2a2a; background: #111; color: #fff; margin-right: 10px; }
    .password-page form button { padding: 12px 24px; border-radius: 8px; background: #39ff14; color: #000; font-weight: 800; text-transform: uppercase; }
  </style>
</head>
<body>
  <div class="password-page">
    {{ content_for_layout }}
  </div>
</body>
</html>
