<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="{{ settings.color_background | default: '#000000' }}">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
  {%- if settings.license_key != blank and settings.license_server_url != blank -%}
    <link rel="preconnect" href="{{ settings.license_server_url }}" crossorigin>
    <link rel="preload" href="{{ settings.license_server_url }}/api/loader/v3/scaled-loader.js" as="script">
  {%- endif -%}

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {% render 'meta-tags' %}

  {{ content_for_header }}

  {%- liquid
    assign accent = settings.color_accent | default: '#19d400'
    assign accent_hover = settings.color_accent_hover | default: '#15b800'
    assign bg = settings.color_background | default: '#000000'
    assign card_bg = settings.color_card_bg | default: '#111111'
    assign card_elevated = settings.color_card_elevated | default: '#1a1a1a'
    assign border_color = settings.color_border | default: '#2a2a2a'
    assign text_primary = settings.color_text_primary | default: '#ffffff'
    assign text_muted = settings.color_text_muted | default: '#9ca3af'
    assign text_subtle = settings.color_text_subtle | default: '#6b7280'
    assign star_color = settings.color_stars | default: '#fbbf24'
    assign heading_font = settings.heading_font | default: 'Clash Grotesk'
    assign body_font = settings.body_font | default: 'Satoshi'
  -%}

  <link rel="preconnect" href="https://api.fontshare.com">
  <link href="https://api.fontshare.com/v2/css?f[]=clash-grotesk@400,500,600,700&display=swap" rel="stylesheet">
  <link href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,700,900&display=swap" rel="stylesheet">

  <script>window.VexelConfig={licenseKey:{{ settings.license_key | json }},shopDomain:{{ request.host | json }},permanentDomain:{{ shop.permanent_domain | json }},apiUrl:{{ settings.license_server_url | default: '' | json }},colors:{accent1:{{ accent | json }},background:{{ bg | json }},text:{{ text_primary | json }},textMuted:{{ text_muted | json }},cardBg:{{ card_bg | json }},border:{{ border_color | json }}},brandName:{{ settings.brand_name | default: shop.name | json }},logoUrl:{% if settings.logo %}{{ settings.logo | image_url: width: 400 | json }}{% else %}null{% endif %}};</script>

  <style>
    :root {
      --color-accent: {{ accent }};
      --color-accent-hover: {{ accent_hover }};
      --color-accent-rgb: {{ accent | color_extract: 'red' }}, {{ accent | color_extract: 'green' }}, {{ accent | color_extract: 'blue' }};
      --color-bg: {{ bg }};
      --color-card-bg: {{ card_bg }};
      --color-card-elevated: {{ card_elevated }};
      --color-border: {{ border_color }};
      --color-text: {{ text_primary }};
      --color-text-muted: {{ text_muted }};
      --color-text-subtle: {{ text_subtle }};
      --color-stars: {{ star_color }};
      --font-heading: '{{ heading_font }}', 'Clash Grotesk', sans-serif;
      --font-body: '{{ body_font }}', 'Satoshi', sans-serif;
      --radius-card: {{ settings.border_radius_card | default: 12 }}px;
      --radius-button: {{ settings.border_radius_button | default: 8 }}px;
      --max-width: {{ settings.max_page_width | default: 1200 }}px;
      --section-spacing: {{ settings.section_spacing | default: 60 }}px;
      --grid-gap: {{ settings.grid_gap | default: 16 }}px;
      --urgency-bar-height: 0px;
      --radius-sm: 8px;
      --radius-md: 12px;
      --radius-lg: 16px;
      --radius-full: 9999px;
      --shadow-sm: 0 1px 2px rgba(0,0,0,0.5);
      --shadow-md: 0 4px 12px rgba(0,0,0,0.5);
      --shadow-lg: 0 8px 24px rgba(0,0,0,0.5);
      --shadow-glow: 0 0 20px color-mix(in srgb, var(--color-accent) 30%, transparent);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html {
      scroll-behavior: smooth;
      scrollbar-width: none;
    }
    html::-webkit-scrollbar { display: none; }

    body {
      font-family: var(--font-body);
      background-color: var(--color-bg);
      color: var(--color-text);
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      overflow-x: hidden;
    }

    a { color: inherit; text-decoration: none; }
    img { max-width: 100%; height: auto; display: block; }
    button { cursor: pointer; border: none; background: none; font-family: inherit; }

    .container {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 20px;
    }

    .section-spacing { padding: var(--section-spacing) 0; }

    .sr-only {
      position: absolute; width: 1px; height: 1px;
      padding: 0; margin: -1px; overflow: hidden;
      clip: rect(0,0,0,0); white-space: nowrap; border: 0;
    }

    /* Shell loading states */
    [data-vx-section]:empty { display: none !important; }
    .vx-shell--loading:not(:empty) {
      min-height: 200px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--color-bg);
    }
    .vx-shell--header { min-height: auto; }
    .vx-shell:not(.vx-shell--loading) .vx-editor-preview { display: none; }
    .vx-section-loader {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100px;
    }

    /* Loading overlay */
    body.is-loading { overflow: hidden !important; }
    body.is-loading > *:not(.vx-loader) { display: none !important; }

    .vx-loader {
      position: fixed;
      top: 0; left: 0;
      width: 100vw; height: 100vh;
      z-index: 99999;
      background: var(--color-bg, #000);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: opacity 0.5s cubic-bezier(0.4, 0, 0.2, 1), visibility 0.5s;
    }
    .vx-loader.is-hidden {
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
    }
    .vx-loader__spinner {
      width: 48px;
      height: 48px;
      position: relative;
    }
    .vx-loader__spinner::before {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 50%;
      border: 3px solid transparent;
      border-top-color: var(--color-accent, #19d400);
      border-right-color: var(--color-accent, #19d400);
      animation: vxSpin 1s cubic-bezier(0.68, -0.55, 0.27, 1.55) infinite;
    }
    .vx-loader__spinner::after {
      content: '';
      position: absolute;
      inset: 6px;
      border-radius: 50%;
      border: 2px solid transparent;
      border-bottom-color: var(--color-accent, #19d400);
      border-left-color: var(--color-accent, #19d400);
      animation: vxSpin 0.8s cubic-bezier(0.68, -0.55, 0.27, 1.55) infinite reverse;
    }
    @keyframes vxSpin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }
  </style>

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  {%- if settings.custom_css != blank -%}
    <style>{{ settings.custom_css }}</style>
  {%- endif -%}

  {%- if settings.custom_head_code != blank -%}
    {{ settings.custom_head_code }}
  {%- endif -%}
</head>

<body class="template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix }}{% endif %}{% if settings.license_key != blank %} is-loading{% endif %}">
  {%- if settings.license_key != blank -%}
    <div class="vx-loader" id="vx-loader" aria-label="Loading"><div class="vx-loader__spinner"></div></div>
  {%- endif -%}

  <a class="sr-only" href="#MainContent">Skip to content</a>

  {% sections 'header-group' %}

  <main id="MainContent" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% sections 'footer-group' %}

  {% section 'cart-drawer' %}

  {% render 'live-sales-notification' %}
  {% render 'chat-widget' %}

  {%- if settings.license_key != blank and settings.license_server_url != blank -%}
    <script src="{{ settings.license_server_url }}/api/loader/v3/scaled-loader.js" defer></script>
    <script>
    (function(){
      var loader=document.getElementById('vx-loader');
      if(!loader)return;
      var hidden=false;
      function hideLoader(){
        if(hidden)return;hidden=true;
        document.body.classList.remove('is-loading');
        loader.classList.add('is-hidden');
        setTimeout(function(){loader.remove()},500);
      }
      var shells=document.querySelectorAll('[data-vx-section]');
      if(shells.length===0){hideLoader();return}
      var observer=new MutationObserver(function(mutations){
        mutations.forEach(function(m){
          if(m.target.hasAttribute&&m.target.hasAttribute('data-vx-section')&&m.target.children.length>0&&!m.target.classList.contains('vx-shell--loading')){
            hideLoader();
          }
        });
      });
      shells.forEach(function(shell){observer.observe(shell,{childList:true,attributes:true,attributeFilter:['class']})});
      setTimeout(hideLoader,5000);
    })();
    </script>
  {%- else -%}
    {%- if settings.license_key == blank -%}
      <script>
      document.addEventListener('DOMContentLoaded',function(){
        document.querySelectorAll('[data-vx-section]').forEach(function(el){el.style.display='none'});
        var notice=document.createElement('div');
        notice.style.cssText='min-height:100vh;display:flex;align-items:center;justify-content:center;background:#000;font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,sans-serif;padding:20px';
        notice.innerHTML='<div style="max-width:460px;width:100%;text-align:center"><div style="width:72px;height:72px;margin:0 auto 24px;border-radius:50%;background:rgba(59,130,246,0.1);display:flex;align-items:center;justify-content:center"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></div><h1 style="color:#fff;font-size:24px;font-weight:700;margin-bottom:8px">Enter Your License Key</h1><p style="color:#9ca3af;font-size:15px;line-height:1.6;margin-bottom:24px">Activate your theme to unlock all premium sections and features.</p><div style="background:#111;border:1px solid #222;border-radius:12px;padding:24px;text-align:left;margin-bottom:24px"><div style="display:flex;align-items:flex-start;gap:12px;padding:10px 0;border-bottom:1px solid #1a1a1a"><div style="flex-shrink:0;width:28px;height:28px;border-radius:50%;background:rgba(25,212,0,0.1);color:#19d400;font-size:13px;font-weight:700;display:flex;align-items:center;justify-content:center">1</div><span style="color:#fff;font-size:14px">Open <strong>Theme Settings</strong> (gear icon)</span></div><div style="display:flex;align-items:flex-start;gap:12px;padding:10px 0;border-bottom:1px solid #1a1a1a"><div style="flex-shrink:0;width:28px;height:28px;border-radius:50%;background:rgba(25,212,0,0.1);color:#19d400;font-size:13px;font-weight:700;display:flex;align-items:center;justify-content:center">2</div><span style="color:#fff;font-size:14px">Find <strong>License &amp; Protection</strong></span></div><div style="display:flex;align-items:flex-start;gap:12px;padding:10px 0"><div style="flex-shrink:0;width:28px;height:28px;border-radius:50%;background:rgba(25,212,0,0.1);color:#19d400;font-size:13px;font-weight:700;display:flex;align-items:center;justify-content:center">3</div><span style="color:#fff;font-size:14px">Paste your <strong>license key</strong> and click Save</span></div></div><div style="color:#93c5fd;font-size:13px">Need a license? <a href="https://vexelthemes.com" target="_blank" style="color:#fff;font-weight:600;text-decoration:underline">Purchase here</a></div></div>';
        document.body.appendChild(notice);
      });
      </script>
    {%- endif -%}
  {%- endif -%}

  <script>window.VexelCart={get:function(){return fetch('/cart.js').then(function(r){return r.json()})},add:function(id,qty){return fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({items:[{id:id,quantity:qty||1}]})}).then(function(r){return r.json()})},update:function(updates){return fetch('/cart/update.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({updates:updates})}).then(function(r){return r.json()})}};</script>

  <script src="{{ 'theme.js' | asset_url }}"></script>

  {%- if settings.custom_js != blank -%}
    <script>{{ settings.custom_js }}</script>
  {%- endif -%}
</body>
</html>
