    // Show authentication error UI
    function showAuthError() {
      console.log('Showing authentication error overlay');
      
      // Create the overlay elements
      const { style, overlay } = createAuthOverlay();
      
      // Function to inject overlay
      function injectOverlay() {
        // Remove any existing overlay
        const existingOverlay = document.getElementById('scaled-auth-overlay');
        if (existingOverlay) {
          existingOverlay.remove();
        }
        
        // Remove any existing style
        const existingStyle = document.querySelector('style[data-scaled-auth]');
        if (existingStyle) {
          existingStyle.remove();
        }
        
        // Add data attribute to style for identification
        style.setAttribute('data-scaled-auth', 'true');
        
        // Inject style and overlay
        if (document.head) {
          document.head.appendChild(style);
        } else {
          document.documentElement.appendChild(style);
        }
        
        if (document.body) {
          document.body.appendChild(overlay);
          // Force reflow to ensure styles are applied
          overlay.offsetHeight;
        } else {
          document.documentElement.appendChild(overlay);
        }
        
        console.log('Authentication overlay injected');
      }
      
      // Try to inject immediately
      if (document.body || document.documentElement) {
        injectOverlay();
      } else {
        // If DOM not ready, wait for it
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', injectOverlay);
        } else {
          // Fallback: try again after a short delay
          setTimeout(injectOverlay, 10);
        }
      }
    }
    
    // Get authentication status from sessionStorage
    function getAuthStatus() {
      try {
        const stored = sessionStorage.getItem('scaled_auth_status');
        if (stored) {
          const parsed = JSON.parse(stored);
          // Check if auth is still valid (24 hour expiry)
          if (parsed.timestamp && (Date.now() - parsed.timestamp < 24 * 60 * 60 * 1000)) {
            return parsed.isAuthenticated;
          }
        }
      } catch (e) {}
      return false;
    }
    
    // Set authentication status
    function setAuthStatus(isAuthenticated) {
      try {
        sessionStorage.setItem('scaled_auth_status', JSON.stringify({
          isAuthenticated,
          timestamp: Date.now()
        }));
      } catch (e) {}
    }
    
    // Show success message
    function showAuthSuccess() {
      // Only show success message in theme editor
      if (!window.Shopify || !window.Shopify.designMode) return;
      
      // Check if we already showed success message
      if (sessionStorage.getItem('scaled_auth_success_shown')) return;
      
      const successHTML = `
        <div id="scaled-auth-success" style="
          position: fixed;
          top: 20px;
          right: 20px;
          background: #10b981;
          color: white;
          padding: 16px 24px;
          border-radius: 8px;
          font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
          font-size: 14px;
          box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
          z-index: 999999;
          animation: slideIn 0.3s ease-out;
        ">
          ✓ Authentication successful! Theme unlocked.
        </div>
      `;
      
      document.body.insertAdjacentHTML('beforeend', successHTML);
      sessionStorage.setItem('scaled_auth_success_shown', 'true');
      
      // Remove after 5 seconds
      setTimeout(() => {
        const successEl = document.getElementById('scaled-auth-success');
        if (successEl) {
          successEl.style.animation = 'slideIn 0.3s ease-out reverse';
          setTimeout(() => successEl.remove(), 300);
        }
      }, 5000);
    }
    
    // Validate API keys with backend
    async function validateKeys() {
      try {
        console.log('Validating keys...', new Date().toLocaleTimeString());
        const response = await fetch(API_ENDPOINT, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-API-Key': SCALED_API_KEY,
            'X-Secret-Key': SCALED_SECRET_KEY
          },
          body: JSON.stringify({
            apiKey: SCALED_API_KEY,
            secretKey: SCALED_SECRET_KEY,
            storeDomain: STORE_INFO.domain,
            themeId: STORE_INFO.themeId,
            metadata: {
              themeName: STORE_INFO.themeName,
              themeRole: STORE_INFO.themeRole,
              shopEmail: STORE_INFO.email,
              userAgent: navigator.userAgent,
              timestamp: new Date().toISOString(),
              inEditor: window.Shopify && window.Shopify.designMode,
              currentPath: window.location.pathname
            }
          })
        });
        
        if (!response.ok) {
          throw new Error(`Validation failed: ${response.status}`);
        }
        
        const data = await response.json();
        return data.valid === true;
      } catch (error) {
        console.error('Scaled.info authentication error:', error);
        return false;
      }
    }
    
    // Track theme usage
    async function trackUsage(event, data = {}) {
      if (!authState.isAuthenticated) return;
      
      try {
        await fetch(API_ENDPOINT + '/track', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-API-Key': SCALED_API_KEY
          },
          body: JSON.stringify({
            event,
            storeDomain: STORE_INFO.domain,
            themeId: STORE_INFO.themeId,
            timestamp: new Date().toISOString(),
            ...data
          })
        });
      } catch (error) {
        // Silently fail tracking
      }
    }
    
    // Initialize ScaledThemeAuth global
    window.ScaledThemeAuth = {
      getInstance: function() {
        return {
          isAuthenticated: () => authState.isAuthenticated,
          getStoreInfo: () => STORE_INFO,
          trackEvent: (event, data) => trackUsage(event, data),
          makeAuthenticatedRequest: async (url, options = {}) => {
            if (!authState.isAuthenticated) {
              throw new Error('Theme not authenticated');
            }
            
            return fetch(url, {
              ...options,
              headers: {
                ...options.headers,
                'X-Scaled-API-Key': SCALED_API_KEY,
                'X-Scaled-Store': STORE_INFO.domain
              }
            });
          }
        };
      }
    };
    
    // Main authentication flow
    async function initializeAuth() {
      console.log('Initializing authentication...');
      
      // Check if keys are configured
      if (!SCALED_API_KEY || !SCALED_SECRET_KEY) {
        console.log('No keys configured, showing error');
        showAuthError();
        return;
      }
      
      // Check cached auth status
      if (getAuthStatus()) {
        authState.isAuthenticated = true;
        // Remove any error overlay
        const errorOverlay = document.getElementById('scaled-auth-overlay');
        if (errorOverlay) {
          errorOverlay.remove();
        }
        trackUsage('page_view', { page: window.location.pathname });
        console.log('Using cached authentication');
        
        // Still set up periodic validation
        setInterval(async () => {
          console.log('Periodic validation check...');
          const stillValid = await validateKeys();
          if (!stillValid) {
            console.log('Validation failed, reloading...');
            setAuthStatus(false);
            sessionStorage.removeItem('scaled_auth_success_shown');
            location.reload();
          }
        }, 10 * 1000); // 10 seconds
        
        return;
      }
      
      try {
        const isValid = await validateKeys();
        console.log('Validation result:', isValid);
        
        if (isValid) {
          authState.isAuthenticated = true;
          setAuthStatus(true);
          
          // Remove any error overlay
          const errorOverlay = document.getElementById('scaled-auth-overlay');
          if (errorOverlay) {
            errorOverlay.remove();
          }
          
          // Show success message
          if (document.body) {
            showAuthSuccess();
          }
          
          // Track successful authentication
          trackUsage('theme_authenticated', {
            page: window.location.pathname,
            referrer: document.referrer,
            inEditor: window.Shopify && window.Shopify.designMode
          });
          
          // Set up validation every 10 seconds
          setInterval(async () => {
            console.log('Periodic validation check...');
            const stillValid = await validateKeys();
            if (!stillValid) {
              console.log('Validation failed, reloading...');
              setAuthStatus(false);
              sessionStorage.removeItem('scaled_auth_success_shown');
              location.reload();
            }
          }, 1 * 60 * 1000); // 5 minutes instead of 10 seconds
          
          // Track page views
          trackUsage('page_view', { page: window.location.pathname });
          
        } else {
          authState.isAuthenticated = false;
          setAuthStatus(false);
          console.log('Validation failed, showing error');
          showAuthError();
        }
      } catch (error) {
        console.error('Authentication initialization error:', error);
        authState.isAuthenticated = false;
        showAuthError();
      }
    }
    
    // Start authentication immediately
    initializeAuth();
    
    // Track navigation
    let lastPath = window.location.pathname;
    setInterval(() => {
      if (window.location.pathname !== lastPath) {
        lastPath = window.location.pathname;
        if (authState.isAuthenticated) {
          trackUsage('page_view', { page: lastPath });
        }
      }
    }, 1000);
  })();
</script>
