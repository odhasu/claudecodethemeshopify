<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="{{ settings.color_accent }}">
  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {% render 'meta-tags' %}

  {{ content_for_header }}

  {%- liquid
    assign accent = settings.color_accent | default: '#39ff14'
    assign accent_hover = settings.color_accent_hover | default: '#2de010'
    assign bg = settings.color_background | default: '#000000'
    assign card_bg = settings.color_card_bg | default: '#111111'
    assign card_elevated = settings.color_card_elevated | default: '#1a1a1a'
    assign border_color = settings.color_border | default: '#2a2a2a'
    assign text_primary = settings.color_text_primary | default: '#ffffff'
    assign text_muted = settings.color_text_muted | default: '#9ca3af'
    assign text_subtle = settings.color_text_subtle | default: '#6b7280'
    assign star_color = settings.color_stars | default: '#fbbf24'
    assign heading_font = settings.heading_font | default: 'Anton'
    assign body_font = settings.body_font | default: 'system-ui, -apple-system, sans-serif'
  -%}

  {%- comment -%}
    Preconnect to the theme protection server and Google Fonts.
    The server URL comes from theme settings so it can be updated without code changes.
  {%- endcomment -%}
  <link rel="preconnect" href="{{ settings.protection_server_url | default: 'https://your-app.up.railway.app' }}" crossorigin>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  {%- liquid
    assign gfonts = 'Anton,Satoshi,Inter,Bebas+Neue,Poppins,Montserrat,Oswald,Outfit,Space+Grotesk,DM+Sans,Rubik,Raleway'
    assign gfonts_arr = gfonts | split: ','
    assign load_fonts = ''
    for f in gfonts_arr
      assign load_fonts = load_fonts | append: 'family=' | append: f | append: ':wght@400;500;700;900&'
    endfor
  -%}
  <link href="https://fonts.googleapis.com/css2?{{ load_fonts }}display=swap" rel="stylesheet">

  {%- comment -%}
    ═══ CSS Variables ═══
    These are the ONLY styles in the Shell. The rest (layout, components, animations)
    come from the protection server. If the server doesn't respond or the license
    is invalid, the page shows a loading spinner → then a license error.
  {%- endcomment -%}
  <style>
    :root {
      --color-accent: {{ accent }};
      --color-accent-hover: {{ accent_hover }};
      --color-accent-rgb: {{ accent | color_extract: 'red' }}, {{ accent | color_extract: 'green' }}, {{ accent | color_extract: 'blue' }};
      --color-bg: {{ bg }};
      --color-card-bg: {{ card_bg }};
      --color-card-elevated: {{ card_elevated }};
      --color-border: {{ border_color }};
      --color-text: {{ text_primary }};
      --color-text-muted: {{ text_muted }};
      --color-text-subtle: {{ text_subtle }};
      --color-stars: {{ star_color }};
      --font-heading: '{{ heading_font }}', 'Anton', sans-serif;
      --font-body: {{ body_font }};
      --radius-card: {{ settings.border_radius_card | default: 12 }}px;
      --radius-button: {{ settings.border_radius_button | default: 8 }}px;
      --max-width: {{ settings.max_page_width | default: 1200 }}px;
      --section-spacing: {{ settings.section_spacing | default: 60 }}px;
      --grid-gap: {{ settings.grid_gap | default: 16 }}px;
    }

    /* Minimal Shell CSS — just enough to show the loader on a black screen.
       ALL layout CSS (grid, cards, header, footer, etc.) is served from the
       protection server. Without a valid license, none of it loads. */
    body {
      background-color: var(--color-bg, #000);
      color: var(--color-text, #fff);
      margin: 0;
      font-family: var(--font-body);
    }

    /* Loading Screen — the only visible element before server responds */
    .scaled-loader {
      position: fixed;
      top: 0; left: 0;
      width: 100vw; height: 100vh;
      z-index: 99999;
      background: var(--color-bg, #000);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: opacity 0.4s ease;
    }
    .scaled-loader.hide {
      opacity: 0;
      pointer-events: none;
    }
    .scaled-loader__spinner {
      width: 44px;
      height: 44px;
      position: relative;
    }
    .scaled-loader__spinner::before,
    .scaled-loader__spinner::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 50%;
    }
    .scaled-loader__spinner::before {
      border: 3px solid transparent;
      border-top-color: var(--color-accent, #39ff14);
      border-right-color: var(--color-accent, #39ff14);
      animation: scaledSpin 1s cubic-bezier(0.68, -0.55, 0.27, 1.55) infinite;
    }
    .scaled-loader__spinner::after {
      inset: 5px;
      border: 2px solid transparent;
      border-bottom-color: var(--color-accent, #39ff14);
      border-left-color: var(--color-accent, #39ff14);
      animation: scaledSpin 0.8s cubic-bezier(0.68, -0.55, 0.27, 1.55) infinite reverse;
    }
    @keyframes scaledSpin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    /* Hide ALL content until the server responds with layout CSS.
       This prevents "flash of unstyled content" AND ensures the theme
       is invisible without the license. */
    main, header, footer, .header-section, .footer-section {
      opacity: 0;
      transition: opacity 0.3s ease;
    }
    html.scaled-loaded main,
    html.scaled-loaded header,
    html.scaled-loaded footer,
    html.scaled-loaded .header-section,
    html.scaled-loaded .footer-section {
      opacity: 1;
    }
  </style>

  {%- if settings.custom_css != blank -%}
    <style>{{ settings.custom_css }}</style>
  {%- endif -%}

  {%- if settings.custom_head_code != blank -%}
    {{ settings.custom_head_code }}
  {%- endif -%}
</head>

<body class="template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">
  <!-- Loading Screen -->
  <div class="scaled-loader" id="scaled-loader">
    <div class="scaled-loader__spinner"></div>
  </div>

  <a class="sr-only" href="#MainContent">Skip to content</a>

  {% sections 'header-group' %}

  <main id="MainContent" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% sections 'footer-group' %}

  {% render 'live-sales-notification' %}
  {% render 'chat-widget' %}

  {%- comment -%}
    ═══ ScaledConfig — Theme Protection Handshake ═══
    This object tells the Loader where to find the server and what license to use.
    The license key and server URL are stored in theme settings so the store owner
    can update them without touching code.
  {%- endcomment -%}
  <script>
    window.ScaledConfig = {
      licenseKey: {{ settings.license_key | default: '' | json }},
      shopDomain: {{ request.host | json }},
      permanentDomain: {{ shop.permanent_domain | json }},
      apiUrl: {{ settings.protection_server_url | default: 'https://your-app.up.railway.app' | json }},
      colors: {
        accent: {{ accent | json }},
        background: {{ bg | json }},
        text: {{ text_primary | json }},
        textMuted: {{ text_muted | json }},
        cardBg: {{ card_bg | json }},
        border: {{ border_color | json }}
      },
      brandName: {{ shop.name | json }},
      logoUrl: {% if settings.logo %}{{ settings.logo | image_url: width: 200 | json }}{% else %}""{% endif %}
    };
  </script>

  {%- comment -%}
    ═══ Theme Loader — The Kill-Switch ═══
    This script is obfuscated in production (run `node server/build.js`).
    It fetches the critical CSS + JS from the protection server.
    Without it, the theme is just empty shells with no styling.

    In development, load the un-obfuscated version.
    In production, use the obfuscated asset file.
  {%- endcomment -%}
  {%- if settings.use_obfuscated_loader -%}
    <script src="{{ 'scaled-loader.js' | asset_url }}" defer></script>
  {%- else -%}
    <script src="{{ settings.protection_server_url | default: 'https://your-app.up.railway.app' }}/api/loader/scaled-loader.js" defer></script>
  {%- endif -%}

  {%- comment -%} theme.js is no longer needed — cart/header/FAQ JS comes from server {%- endcomment -%}

  {%- if settings.custom_js != blank -%}
    <script>{{ settings.custom_js }}</script>
  {%- endif -%}
</body>
</html>
